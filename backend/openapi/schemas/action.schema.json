{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoplan.local/schemas/action.schema.json",
  "title": "Long-running action contract",
  "$ref": "#/$defs/plan_action_request",
  "$defs": {
    "positive_id": {
      "type": "integer",
      "format": "int64",
      "minimum": 1
    },
    "utc_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "idempotency_key": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "plan_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "plan_id"],
      "properties": {
        "project_id": { "$ref": "#/$defs/positive_id" },
        "plan_id": { "$ref": "#/$defs/positive_id" }
      }
    },
    "task_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["project_id", "plan_id", "task_id"],
      "properties": {
        "project_id": { "$ref": "#/$defs/positive_id" },
        "plan_id": { "$ref": "#/$defs/positive_id" },
        "task_id": { "$ref": "#/$defs/positive_id" }
      }
    },
    "plan_preconditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_updated_at"],
      "properties": {
        "expected_updated_at": { "$ref": "#/$defs/utc_timestamp" }
      }
    },
    "task_preconditions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_task_updated_at", "expected_plan_updated_at"],
      "properties": {
        "expected_task_updated_at": { "$ref": "#/$defs/utc_timestamp" },
        "expected_plan_updated_at": { "$ref": "#/$defs/utc_timestamp" }
      }
    },
    "plan_action_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "target", "preconditions"],
      "properties": {
        "version": { "const": "v1" },
        "target": { "$ref": "#/$defs/plan_target" },
        "preconditions": { "$ref": "#/$defs/plan_preconditions" }
      }
    },
    "task_action_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "target", "preconditions"],
      "properties": {
        "version": { "const": "v1" },
        "target": { "$ref": "#/$defs/task_target" },
        "preconditions": { "$ref": "#/$defs/task_preconditions" }
      }
    },
    "task_batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_ids"],
      "properties": {
        "task_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/positive_id" },
          "uniqueItems": true
        }
      }
    },
    "run_batches_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["version", "target", "preconditions", "batches"],
      "properties": {
        "version": { "const": "v1" },
        "target": { "$ref": "#/$defs/plan_target" },
        "preconditions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["expected_plan_updated_at"],
          "properties": {
            "expected_plan_updated_at": { "$ref": "#/$defs/utc_timestamp" }
          }
        },
        "batches": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/task_batch" }
        }
      }
    },
    "operation_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "type", "status", "request_id", "accepted_at"],
      "properties": {
        "operation_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
        },
        "type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[._:-][a-z0-9]+)*$"
        },
        "status": { "const": "queued" },
        "request_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"
        },
        "accepted_at": { "$ref": "#/$defs/utc_timestamp" }
      }
    },
    "action_accepted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation"],
      "properties": {
        "operation": { "$ref": "#/$defs/operation_reference" }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoplan.local/schemas/attachment.schema.json",
  "title": "Safe attachment resource",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "display_name", "size", "mime_type", "download_url"],
  "properties": {
    "id": {"type": "integer", "format": "int64", "minimum": 1},
    "display_name": {"type": "string", "minLength": 1, "maxLength": 120},
    "size": {"type": "integer", "format": "int64", "minimum": 1, "maximum": 26214400},
    "mime_type": {"type": "string", "enum": ["application/pdf", "application/json", "text/plain", "image/apng", "image/avif", "image/bmp", "image/gif", "image/jpeg", "image/png", "image/webp"]},
    "download_url": {"type": "string", "format": "uri-reference", "pattern": "^/api/v1/attachments/[1-9][0-9]*/content$"}
  },
  "$defs": {
    "upload_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attachment", "state", "recovery_required"],
      "properties": {
        "attachment": {"$ref": "#"},
        "state": {"type": "string", "enum": ["ready", "complete", "failed", "staged", "deleting", "quarantined"]},
        "recovery_required": {"type": "boolean"}
      }
    },
    "delete_result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["attachment_id", "state", "recovery_required"],
      "properties": {
        "attachment_id": {"type": "integer", "format": "int64", "minimum": 1},
        "state": {"type": "string", "enum": ["complete", "failed", "deleting", "quarantined"]},
        "recovery_required": {"type": "boolean"}
      }
    }
  }
}

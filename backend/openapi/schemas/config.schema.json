{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoplan.local/schemas/config.schema.json",
  "title": "Loop and static configuration contracts",
  "$ref": "#/$defs/loop_config_request",
  "$defs": {
    "id": { "type": "integer", "format": "int64", "minimum": 1 },
    "nullable_string": { "type": ["string", "null"] },
    "plan_provider": { "type": ["string", "null"], "enum": ["", "codex", "claude", "opencode", "oh-my-pi", "openai", "deepseek", "anthropic", null] },
    "reasoning_effort": { "type": ["string", "null"], "enum": ["low", "medium", "high", "xhigh", null] },
    "env_var": { "type": "object", "additionalProperties": false, "required": ["name", "value"], "properties": { "name": { "type": "string", "minLength": 1, "maxLength": 256 }, "value": { "type": "string", "maxLength": 65536, "writeOnly": true } } },
    "loop_config_request": {
      "type": "object", "additionalProperties": false,
      "required": ["version", "interval_seconds", "validation_command", "project_prompt", "agent_cli_provider", "agent_cli_command", "plan_generation_strategy", "plan_generation_command", "plan_generation_model", "plan_execution_strategy", "plan_execution_command", "plan_execution_model"],
      "properties": {
        "version": { "$ref": "#/$defs/id" }, "interval_seconds": { "type": "integer", "format": "int64", "minimum": 1 }, "validation_command": { "type": "string", "maxLength": 65536 }, "project_prompt": { "type": "string", "maxLength": 1000000 }, "agent_cli_provider": { "type": "string", "enum": ["codex", "claude", "opencode", "oh-my-pi"] }, "agent_cli_command": { "type": "string", "maxLength": 65536 }, "codex_reasoning_effort": { "$ref": "#/$defs/reasoning_effort" },
        "plan_generation_strategy": { "type": "string", "enum": ["external-cli-markdown", "external-cli-structured", "builtin-llm-structured"] }, "plan_generation_provider": { "$ref": "#/$defs/plan_provider" }, "plan_generation_command": { "type": "string", "maxLength": 65536 }, "plan_generation_model": { "type": "string", "maxLength": 4096 }, "plan_generation_codex_reasoning_effort": { "$ref": "#/$defs/reasoning_effort" }, "plan_generation_claude_base_url": { "type": "string", "maxLength": 8192, "writeOnly": true }, "plan_generation_claude_auth_token": { "type": "string", "maxLength": 65536, "writeOnly": true }, "plan_generation_claude_model": { "type": "string", "maxLength": 4096, "writeOnly": true }, "plan_generation_claude_config_id": { "type": "integer", "format": "int64", "minimum": 0, "writeOnly": true },
        "plan_execution_strategy": { "type": "string", "enum": ["external-cli", "builtin-llm"] }, "plan_execution_provider": { "$ref": "#/$defs/plan_provider" }, "plan_execution_command": { "type": "string", "maxLength": 65536 }, "plan_execution_model": { "type": "string", "maxLength": 4096 }, "plan_execution_codex_reasoning_effort": { "$ref": "#/$defs/reasoning_effort" }, "plan_execution_claude_base_url": { "type": "string", "maxLength": 8192, "writeOnly": true }, "plan_execution_claude_auth_token": { "type": "string", "maxLength": 65536, "writeOnly": true }, "plan_execution_claude_model": { "type": "string", "maxLength": 4096, "writeOnly": true }, "plan_execution_claude_config_id": { "type": "integer", "format": "int64", "minimum": 0, "writeOnly": true },
        "env_vars": { "type": "array", "maxItems": 256, "items": { "$ref": "#/$defs/env_var" }, "writeOnly": true }
      }
    },
    "reset_request": { "type": "object", "additionalProperties": false, "required": ["version"], "properties": { "version": { "$ref": "#/$defs/id" } } },
    "ai_config": { "type": "object", "additionalProperties": false, "required": ["id", "project_id", "name", "provider", "base_url", "has_api_key", "masked_key", "model", "temperature", "thinking_depth", "thinking_budget_tokens", "created_at", "updated_at", "version"], "properties": { "id": { "$ref": "#/$defs/id" }, "project_id": { "type": ["integer", "null"] }, "name": { "type": "string" }, "provider": { "enum": ["openai", "deepseek", "anthropic", "codex"] }, "base_url": { "type": "string" }, "has_api_key": { "type": "boolean" }, "masked_key": { "type": "string" }, "model": { "type": "string" }, "temperature": { "type": "string" }, "thinking_depth": { "type": ["string", "null"] }, "thinking_budget_tokens": { "type": ["integer", "null"] }, "created_at": { "type": "string", "format": "date-time" }, "updated_at": { "type": "string", "format": "date-time" }, "version": { "$ref": "#/$defs/id" } } },
    "claude_config": { "type": "object", "additionalProperties": false, "required": ["id", "project_id", "name", "base_url", "has_auth_token", "masked_key", "model", "is_default", "created_at", "updated_at", "version"], "properties": { "id": { "$ref": "#/$defs/id" }, "project_id": { "type": ["integer", "null"] }, "name": { "type": "string" }, "base_url": { "type": "string" }, "has_auth_token": { "type": "boolean" }, "masked_key": { "type": "string" }, "model": { "type": "string" }, "is_default": { "type": "boolean" }, "created_at": { "type": "string", "format": "date-time" }, "updated_at": { "type": "string", "format": "date-time" }, "version": { "$ref": "#/$defs/id" } } },
    "mcp_config": { "type": "object", "additionalProperties": false, "required": ["enabled", "transport", "host", "port", "path", "port_explicit", "has_auth_token", "auth_token_masked"], "properties": { "enabled": { "type": "boolean" }, "transport": { "enum": ["http", "stdio"] }, "host": { "type": "string" }, "port": { "type": "integer", "minimum": 1, "maximum": 65535 }, "path": { "type": "string" }, "port_explicit": { "type": "boolean" }, "has_auth_token": { "type": "boolean" }, "auth_token_masked": { "type": "string" } } }
  }
}

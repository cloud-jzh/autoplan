{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoplan.local/schemas/error.schema.json",
  "title": "Error",
  "type": "object",
  "additionalProperties": false,
  "required": ["code", "message", "request_id", "retryable"],
  "properties": {
    "code": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:_[a-z0-9]+)*$"
    },
    "message": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "request_id": { "$ref": "#/$defs/request_id" },
    "retryable": { "type": "boolean" },
    "details": { "$ref": "#/$defs/safe_object" }
  },
  "$defs": {
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"
    },
    "safe_object": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/safe_property_name" },
      "patternProperties": {
        "(?:^|_)has_|Has[A-Z]": { "type": "boolean" },
        "(?:_masked|Masked)$": { "type": "string" },
        "(?:^|_)auth_header$|AuthHeader$": {
          "type": "string",
          "pattern": "^(?:$|.*<token>.*)$"
        },
        "(?:^|_|[a-z])(?:path|Path|cwd|Cwd|workdir|Workdir|log_file|logFile|file_path|filePath|source_path|sourcePath|stored_path|storedPath)$": {
          "oneOf": [
            { "type": "string", "pattern": "^(?!/|\\\\|[A-Za-z]:[\\\\/]).*$" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": { "$ref": "#/$defs/safe_value" }
    },
    "safe_property_name": {
      "anyOf": [
        { "pattern": "(?:^|_)has_|Has[A-Z]" },
        { "pattern": "(?:_masked|Masked)$" },
        {
          "not": {
            "pattern": "[Ww]orkspace[_-]?[Pp]ath|(?:^|_)[Ee]nv(?:$|_)|[Ee]nv[_-]?[Vv]ars|[Aa][Pp][Ii][_-]?[Kk]ey|[Aa]uth[_-]?[Tt]oken|[Aa]ccess[_-]?[Tt]oken|[Rr]efresh[_-]?[Tt]oken|[Tt]oken|[Pp]assword|[Ss]ecret|[Cc]redential|[Pp]rivate[_-]?[Kk]ey|[Aa]uthorization|[Cc]ookie|(?:^|_)[Ss]ession(?:$|_(?:[Tt]oken|[Ss]ecret|[Cc]redential))|[Ss]ession(?:Token|Secret|Credential)"
          }
        }
      ]
    },
    "safe_value": {
      "anyOf": [
        { "type": ["string", "number", "integer", "boolean", "null"] },
        { "$ref": "#/$defs/safe_object" },
        { "type": "array", "items": { "$ref": "#/$defs/safe_value" } }
      ]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoplan.local/schemas/event.schema.json",
  "title": "EventEnvelopeV1",
  "$ref": "#/$defs/EventEnvelope",
  "$defs": {
    "EventEnvelope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "event_class",
        "event_id",
        "project_id",
        "project_revision",
        "type",
        "operation_id",
        "request_id",
        "occurred_at",
        "payload"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "event_class": { "enum": ["business", "operation", "control"] },
        "event_id": { "$ref": "#/$defs/nullable_event_id" },
        "project_id": { "$ref": "#/$defs/positive_id" },
        "project_revision": { "$ref": "#/$defs/nullable_revision" },
        "type": { "type": "string", "maxLength": 128 },
        "operation_id": { "$ref": "#/$defs/nullable_identifier" },
        "request_id": { "$ref": "#/$defs/nullable_request_id" },
        "occurred_at": { "$ref": "#/$defs/utc_timestamp" },
        "payload": { "$ref": "#/$defs/safe_object" }
      },
      "allOf": [
        {
          "if": { "properties": { "event_class": { "const": "business" } }, "required": ["event_class"] },
          "then": {
            "properties": {
              "event_id": { "$ref": "#/$defs/event_id" },
              "project_revision": { "$ref": "#/$defs/revision" },
              "request_id": { "$ref": "#/$defs/request_id" },
              "type": {
                "pattern": "^(?:project\\.(?:snapshot|patch)|business\\.[a-z][a-z0-9]*(?:[._:-][a-z0-9]+)*)$"
              }
            }
          }
        },
        {
          "if": { "properties": { "event_class": { "const": "operation" } }, "required": ["event_class"] },
          "then": {
            "properties": {
              "event_id": { "$ref": "#/$defs/event_id" },
              "project_revision": { "$ref": "#/$defs/revision" },
              "request_id": { "$ref": "#/$defs/request_id" },
              "operation_id": { "$ref": "#/$defs/identifier" },
              "type": {
                "enum": [
                  "operation.queued",
                  "operation.running",
                  "operation.succeeded",
                  "operation.failed",
                  "operation.cancelled",
                  "operation.interrupted"
                ]
              }
            }
          }
        },
        {
          "if": { "properties": { "event_class": { "const": "control" } }, "required": ["event_class"] },
          "then": {
            "properties": {
              "event_id": { "type": "null" },
              "project_revision": { "type": "null" },
              "type": { "enum": ["heartbeat", "resync_required"] }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "heartbeat" } }, "required": ["type"] },
          "then": {
            "properties": {
              "operation_id": { "type": "null" },
              "request_id": { "type": "null" },
              "payload": { "const": {} }
            }
          }
        },
        {
          "if": { "properties": { "type": { "const": "resync_required" } }, "required": ["type"] },
          "then": { "properties": { "payload": { "$ref": "#/$defs/resync_payload" } } }
        }
      ]
    },
    "positive_id": { "type": "integer", "format": "int64", "minimum": 1 },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "nullable_identifier": {
      "oneOf": [
        { "$ref": "#/$defs/identifier" },
        { "type": "null" }
      ]
    },
    "event_id": {
      "type": "string",
      "description": "Opaque decimal cursor; compare as an integer, never as a JavaScript number.",
      "pattern": "^[1-9][0-9]{0,18}$"
    },
    "nullable_event_id": {
      "oneOf": [
        { "$ref": "#/$defs/event_id" },
        { "type": "null" }
      ]
    },
    "revision": { "type": "integer", "format": "int64", "minimum": 1 },
    "nullable_revision": {
      "oneOf": [
        { "$ref": "#/$defs/revision" },
        { "type": "null" }
      ]
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"
    },
    "nullable_request_id": {
      "oneOf": [
        { "$ref": "#/$defs/request_id" },
        { "type": "null" }
      ]
    },
    "utc_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "resync_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason"],
      "properties": {
        "reason": {
          "enum": [
            "last_event_id_invalid",
            "last_event_id_future",
            "history_expired",
            "revision_gap",
            "project_mismatch",
            "slow_consumer"
          ]
        }
      }
    },
    "safe_object": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/safe_property_name" },
      "patternProperties": {
        "(?:^|_)has_|Has[A-Z]": { "type": "boolean" },
        "(?:_masked|Masked)$": { "type": "string", "maxLength": 256 }
      },
      "additionalProperties": { "$ref": "#/$defs/safe_value" }
    },
    "safe_property_name": {
      "not": {
        "pattern": "[Ww]orkspace[_-]?[Pp]ath|[Uu]ser[_-]?[Dd]ata|(?:^|_)[Ee]nv(?:$|_)|[Ee]nv[_-]?[Vv]ars|[Aa][Pp][Ii][_-]?[Kk]ey|[Aa]uth[_-]?[Tt]oken|[Aa]ccess[_-]?[Tt]oken|[Rr]efresh[_-]?[Tt]oken|[Tt]oken|[Pp]assword|[Ss]ecret|[Cc]redential|[Pp]rivate[_-]?[Kk]ey|[Aa]uthorization|[Cc]ookie|[Ss]ession|[Cc]ommand|[Ss]tdout|[Ss]tderr|(?:^|_)[Pp]ath(?:$|_)|[Cc]wd|[Ww]orkdir"
      }
    },
    "safe_value": {
      "anyOf": [
        { "type": ["string", "number", "integer", "boolean", "null"], "maxLength": 2048 },
        { "$ref": "#/$defs/safe_object" },
        { "type": "array", "maxItems": 128, "items": { "$ref": "#/$defs/safe_value" } }
      ]
    }
  }
}

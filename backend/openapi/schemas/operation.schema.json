{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoplan.local/schemas/operation.schema.json",
  "title": "Operation",
  "$ref": "#/$defs/Operation",
  "$defs": {
    "OperationAccepted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "status", "request_id", "accepted_at"],
      "properties": {
        "operation_id": { "$ref": "#/$defs/identifier" },
        "status": { "const": "queued" },
        "request_id": { "$ref": "#/$defs/request_id" },
        "accepted_at": { "$ref": "#/$defs/utc_timestamp" }
      }
    },
    "Operation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "operation_id",
        "project_id",
        "type",
        "status",
        "request_id",
        "idempotency_key",
        "request_digest",
        "version",
        "cancel_requested_at",
        "created_at",
        "updated_at",
        "started_at",
        "finished_at",
        "result",
        "error"
      ],
      "properties": {
        "operation_id": { "$ref": "#/$defs/identifier" },
        "project_id": { "$ref": "#/$defs/positive_id" },
        "type": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9]*(?:[._:-][a-z0-9]+)*$"
        },
        "status": {
          "enum": ["queued", "running", "succeeded", "failed", "cancelled", "interrupted"]
        },
        "request_id": { "$ref": "#/$defs/request_id" },
        "idempotency_key": { "$ref": "#/$defs/nullable_identifier" },
        "request_digest": {
          "type": "string",
          "description": "Lowercase SHA-256 of canonicalized request intent; raw request data is never exposed.",
          "pattern": "^[a-f0-9]{64}$"
        },
        "version": { "type": "integer", "format": "int64", "minimum": 1 },
        "cancel_requested_at": { "$ref": "#/$defs/nullable_timestamp" },
        "created_at": { "$ref": "#/$defs/utc_timestamp" },
        "updated_at": { "$ref": "#/$defs/utc_timestamp" },
        "started_at": { "$ref": "#/$defs/nullable_timestamp" },
        "finished_at": { "$ref": "#/$defs/nullable_timestamp" },
        "result": { "$ref": "#/$defs/nullable_safe_object" },
        "error": { "$ref": "#/$defs/nullable_error_summary" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "queued" } }, "required": ["status"] },
          "then": {
            "properties": {
              "started_at": { "type": "null" },
              "finished_at": { "type": "null" },
              "cancel_requested_at": { "type": "null" },
              "error": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "running" } }, "required": ["status"] },
          "then": {
            "properties": {
              "started_at": { "$ref": "#/$defs/utc_timestamp" },
              "finished_at": { "type": "null" },
              "error": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "succeeded" } }, "required": ["status"] },
          "then": {
            "properties": {
              "started_at": { "$ref": "#/$defs/utc_timestamp" },
              "finished_at": { "$ref": "#/$defs/utc_timestamp" },
              "error": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "failed" } }, "required": ["status"] },
          "then": {
            "properties": {
              "started_at": { "$ref": "#/$defs/utc_timestamp" },
              "finished_at": { "$ref": "#/$defs/utc_timestamp" },
              "error": { "$ref": "#/$defs/error_summary" }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "cancelled" } }, "required": ["status"] },
          "then": {
            "properties": {
              "finished_at": { "$ref": "#/$defs/utc_timestamp" },
              "error": { "type": "null" }
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "interrupted" } }, "required": ["status"] },
          "then": {
            "properties": {
              "finished_at": { "$ref": "#/$defs/utc_timestamp" },
              "error": { "$ref": "#/$defs/error_summary" }
            }
          }
        }
      ]
    },
    "positive_id": { "type": "integer", "format": "int64", "minimum": 1 },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "nullable_identifier": {
      "oneOf": [
        { "$ref": "#/$defs/identifier" },
        { "type": "null" }
      ]
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"
    },
    "utc_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "nullable_timestamp": {
      "oneOf": [
        { "$ref": "#/$defs/utc_timestamp" },
        { "type": "null" }
      ]
    },
    "error_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "summary"],
      "properties": {
        "code": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]{0,63}$" },
        "summary": {
          "type": "string",
          "minLength": 1,
          "maxLength": 1024,
          "pattern": "^[^\\u0000-\\u001F\\u007F]+$"
        }
      }
    },
    "nullable_error_summary": {
      "oneOf": [
        { "$ref": "#/$defs/error_summary" },
        { "type": "null" }
      ]
    },
    "nullable_safe_object": {
      "oneOf": [
        { "$ref": "#/$defs/safe_object" },
        { "type": "null" }
      ]
    },
    "safe_object": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/safe_property_name" },
      "patternProperties": {
        "(?:^|_)has_|Has[A-Z]": { "type": "boolean" },
        "(?:_masked|Masked)$": { "type": "string", "maxLength": 256 }
      },
      "additionalProperties": { "$ref": "#/$defs/safe_value" }
    },
    "safe_property_name": {
      "not": {
        "pattern": "[Ww]orkspace[_-]?[Pp]ath|[Uu]ser[_-]?[Dd]ata|(?:^|_)[Ee]nv(?:$|_)|[Ee]nv[_-]?[Vv]ars|[Aa][Pp][Ii][_-]?[Kk]ey|[Aa]uth[_-]?[Tt]oken|[Aa]ccess[_-]?[Tt]oken|[Rr]efresh[_-]?[Tt]oken|[Tt]oken|[Pp]assword|[Ss]ecret|[Cc]redential|[Pp]rivate[_-]?[Kk]ey|[Aa]uthorization|[Cc]ookie|[Ss]ession|[Cc]ommand|[Ss]tdout|[Ss]tderr|(?:^|_)[Pp]ath(?:$|_)|[Cc]wd|[Ww]orkdir"
      }
    },
    "safe_value": {
      "anyOf": [
        { "type": ["string", "number", "integer", "boolean", "null"], "maxLength": 2048 },
        { "$ref": "#/$defs/safe_object" },
        { "type": "array", "maxItems": 128, "items": { "$ref": "#/$defs/safe_value" } }
      ]
    }
  }
}

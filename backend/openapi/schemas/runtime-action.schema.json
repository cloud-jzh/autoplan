{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoplan.local/schemas/runtime-action.schema.json",
  "title": "AutoPlan Runtime Actions",
  "$defs": {
    "empty": {
      "type": "object",
      "additionalProperties": false
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "plan_id": { "type": "integer", "format": "int64", "minimum": 1 }
      }
    },
    "batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["batches"],
      "properties": {
        "batches": {
          "type": "array",
          "minItems": 1,
          "maxItems": 64,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["task_ids"],
            "properties": {
              "task_ids": {
                "type": "array",
                "minItems": 1,
                "maxItems": 100,
                "uniqueItems": true,
                "items": { "type": "integer", "format": "int64", "minimum": 1 }
              }
            }
          }
        }
      }
    },
    "acceptance_target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_type", "id"],
      "properties": {
        "target_type": { "enum": ["plan", "task"] },
        "id": { "type": "integer", "format": "int64", "minimum": 1 },
        "supplement": { "type": "string", "maxLength": 2000 }
      }
    },
    "acceptance_batch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["targets"],
      "properties": {
        "targets": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": { "$ref": "#/$defs/acceptance_target" }
        }
      }
    },
    "operation_accepted": {
      "type": "object",
      "additionalProperties": false,
      "required": ["operation_id", "type", "status", "request_id", "accepted_at"],
      "properties": {
        "operation_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$" },
        "type": { "type": "string", "pattern": "^[a-z][a-z0-9]*(?:[._:-][a-z0-9]+)*$" },
        "status": { "enum": ["accepted", "queued", "running"] },
        "request_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$" },
        "accepted_at": { "type": "string", "format": "date-time" }
      }
    },
    "envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data", "request_id"],
      "properties": {
        "data": { "$ref": "#/$defs/operation_accepted" },
        "request_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$" }
      }
    }
  }
}

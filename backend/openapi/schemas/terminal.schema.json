{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoplan.local/schemas/terminal.schema.json",
  "title": "P14 frozen Terminal REST and WebSocket contracts",
  "$ref": "#/$defs/terminal_session",
  "$defs": {
    "project_id": { "type": "integer", "format": "int64", "minimum": 1 },
    "session_id": { "type": "string", "pattern": "^term_[a-z0-9][a-z0-9_-]{5,}$", "maxLength": 160 },
    "request_id": { "type": "string", "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$" },
    "utc_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "nullable_utc_timestamp": {
      "oneOf": [{ "$ref": "#/$defs/utc_timestamp" }, { "type": "null" }]
    },
    "sequence": { "type": "integer", "minimum": 1, "maximum": 9007199254740991 },
    "last_sequence": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 },
    "terminal_status": { "enum": ["starting", "running", "exited", "killed", "error"] },
    "terminal_profile": {
      "description": "Frozen TerminalProfile read projection. env is present for DTO compatibility but is always empty on REST reads; values are write-only creation intent and never persisted or logged.",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "kind", "shell_path", "args", "env"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 80 },
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "kind": { "enum": ["default", "custom"] },
        "shell_path": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "args": { "type": "array", "maxItems": 32, "items": { "type": "string", "maxLength": 512 } },
        "env": { "type": "object", "maxProperties": 0, "additionalProperties": false }
      }
    },
    "terminal_session": {
      "description": "Frozen TerminalSession REST projection. id is a string and never constitutes authorization. All timestamps are UTC. This is metadata only: it contains neither PTY handles, PID, raw input/output nor environment values.",
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "project_id", "title", "cwd", "shell", "status", "created_at", "ended_at", "exit_code", "cols", "rows", "profile", "closed", "runtime"],
      "properties": {
        "id": { "$ref": "#/$defs/session_id" },
        "project_id": { "$ref": "#/$defs/project_id" },
        "title": { "type": "string", "maxLength": 80 },
        "cwd": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "shell": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "status": { "$ref": "#/$defs/terminal_status" },
        "created_at": { "$ref": "#/$defs/utc_timestamp" },
        "ended_at": { "$ref": "#/$defs/nullable_utc_timestamp" },
        "exit_code": { "type": ["integer", "null"], "minimum": -2147483648, "maximum": 2147483647 },
        "cols": { "type": "integer", "minimum": 2, "maximum": 500 },
        "rows": { "type": "integer", "minimum": 1, "maximum": 200 },
        "profile": { "$ref": "#/$defs/terminal_profile" },
        "closed": { "type": "boolean" },
        "runtime": { "const": "go" }
      }
    },
    "terminal_profile_input": {
      "description": "A selection of a server-controlled profile. Shell paths, arguments and environment values are not accepted from REST.",
      "type": "object",
      "additionalProperties": false,
      "required": ["id"],
      "properties": { "id": { "type": "string", "minLength": 1, "maxLength": 80 } }
    },
    "env_input": {
      "description": "Write-only controlled input. The application service allow-lists and redacts it before PTY spawn; it never appears in a read DTO, SSE, outbox, snapshot, audit body, log, fixture or evidence.",
      "type": "object",
      "maxProperties": 64,
      "propertyNames": { "pattern": "^[A-Za-z_][A-Za-z0-9_]{0,127}$" },
      "additionalProperties": { "type": "string", "maxLength": 8192 }
    },
    "terminal_create_request": {
      "description": "REST admission requires cwd. profile_id selects a server-controlled configured profile; a profile object is accepted only for legacy shape validation and cannot supply a shell, args or environment.",
      "type": "object",
      "additionalProperties": false,
      "required": ["cwd"],
      "properties": {
        "cwd": { "type": "string", "minLength": 1, "maxLength": 2048 },
        "profile_id": { "type": "string", "maxLength": 80 },
        "profile": { "$ref": "#/$defs/terminal_profile_input" },
        "title": { "type": "string", "maxLength": 80 },
        "cols": { "type": "integer", "minimum": 2, "maximum": 500, "default": 80 },
        "rows": { "type": "integer", "minimum": 1, "maximum": 200, "default": 24 },
        "retain_on_exit": { "const": true, "default": true },
        "env": { "$ref": "#/$defs/env_input" }
      }
    },
    "terminal_write_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data"],
      "properties": { "data": { "type": "string", "minLength": 1, "maxLength": 65536 } }
    },
    "terminal_resize_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cols", "rows"],
      "properties": {
        "cols": { "type": "integer", "minimum": 2, "maximum": 500 },
        "rows": { "type": "integer", "minimum": 1, "maximum": 200 }
      }
    },
    "terminal_rename_request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title"],
      "properties": { "title": { "type": "string", "minLength": 1, "maxLength": 80 } }
    },
    "terminal_empty_request": { "type": "object", "additionalProperties": false, "maxProperties": 0 },
    "terminal_replay_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["seq", "data"],
      "properties": {
        "seq": { "$ref": "#/$defs/sequence" },
        "data": { "type": "string", "maxLength": 65536 }
      }
    },
    "terminal_replay": {
      "description": "A finite memory-only replay. Entries are strictly ascending and end immediately before live output. replay_gap/cursor_too_old is returned instead of inventing continuity.",
      "type": "object",
      "additionalProperties": false,
      "required": ["session", "first_seq", "last_seq", "entries", "replay_complete"],
      "properties": {
        "session": { "$ref": "#/$defs/terminal_session" },
        "first_seq": { "$ref": "#/$defs/last_sequence" },
        "last_seq": { "$ref": "#/$defs/last_sequence" },
        "entries": { "type": "array", "maxItems": 4096, "items": { "$ref": "#/$defs/terminal_replay_entry" } },
        "replay_complete": { "const": true }
      }
    },
    "terminal_error_result": {
      "description": "Legacy-compatible TerminalErrorResult. REST places this code in the normal error envelope, while IPC retains ok=false. details is a stable safe reason and never an OS, path, command, env or credential dump.",
      "type": "object",
      "additionalProperties": false,
      "required": ["ok", "code", "message"],
      "properties": {
        "ok": { "const": false },
        "code": { "enum": ["terminal_feature_disabled", "terminal_platform_blocked", "terminal_pty_unavailable", "terminal_invalid_payload", "terminal_invalid_session", "terminal_session_not_found", "terminal_project_not_found", "terminal_forbidden", "terminal_cwd_outside_workspace", "terminal_write_failed", "terminal_resize_failed", "terminal_kill_failed", "terminal_replay_gap", "terminal_cursor_too_old", "terminal_session_limit", "terminal_connection_limit", "terminal_rate_limited", "terminal_slow_consumer", "terminal_protocol_error"] },
        "message": { "type": "string", "minLength": 1, "maxLength": 256 },
        "details": { "type": "string", "maxLength": 256 }
      }
    },
    "terminal_envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["data", "request_id"],
      "properties": { "data": {}, "request_id": { "$ref": "#/$defs/request_id" } }
    },
    "terminal_ws_client": {
      "description": "Client-to-server JSON text frame. Unknown fields, duplicate JSON keys, invalid UTF-8, non-text frames and messages above 65536 bytes are rejected before dispatch.",
      "oneOf": [
        {
          "type": "object", "additionalProperties": false, "required": ["type", "data"],
          "properties": { "type": { "const": "input" }, "data": { "type": "string", "minLength": 1, "maxLength": 65536 } }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["type", "cols", "rows"],
          "properties": { "type": { "const": "resize" }, "cols": { "type": "integer", "minimum": 2, "maximum": 500 }, "rows": { "type": "integer", "minimum": 1, "maximum": 200 } }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["type", "nonce"],
          "properties": { "type": { "const": "ping" }, "nonce": { "type": "string", "minLength": 1, "maxLength": 128 } }
        }
      ]
    },
    "terminal_ws_server": {
      "description": "Server-to-client JSON text frame. output.seq is strictly increasing in one session; replay frames precede live frames and the unique exit frame precedes terminal status/closed frames.",
      "oneOf": [
        {
          "type": "object", "additionalProperties": false, "required": ["type", "seq", "data"],
          "properties": { "type": { "const": "output" }, "seq": { "$ref": "#/$defs/sequence" }, "data": { "type": "string", "maxLength": 65536 } }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["type", "exit_code", "signal"],
          "properties": { "type": { "const": "exit" }, "exit_code": { "type": ["integer", "null"], "minimum": -2147483648, "maximum": 2147483647 }, "signal": { "type": ["string", "null"], "maxLength": 64 } }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["type", "session"],
          "properties": { "type": { "const": "status" }, "session": { "$ref": "#/$defs/terminal_session" } }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["type", "closed", "session"],
          "properties": { "type": { "const": "closed" }, "closed": { "const": true }, "session": { "$ref": "#/$defs/terminal_session" } }
        },
        {
          "type": "object", "additionalProperties": false, "required": ["type", "nonce"],
          "properties": { "type": { "const": "pong" }, "nonce": { "type": "string", "minLength": 1, "maxLength": 128 } }
        }
      ]
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autoplan.local/schemas/ws-envelope-v1.schema.json",
  "title": "WSEnvelopeV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "event_id", "type", "request_id", "operation_id", "direction", "occurred_at", "data"],
  "properties": {
    "schema_version": { "const": 1 },
    "event_id": { "$ref": "#/$defs/identifier" },
    "type": { "$ref": "#/$defs/event_type" },
    "request_id": { "$ref": "#/$defs/request_id" },
    "operation_id": { "$ref": "#/$defs/nullable_identifier" },
    "terminal_session_id": { "$ref": "#/$defs/identifier" },
    "direction": { "enum": ["client_to_server", "server_to_client"] },
    "occurred_at": { "$ref": "#/$defs/utc_timestamp" },
    "data": { "$ref": "#/$defs/safe_object" }
  },
  "$defs": {
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,127}$"
    },
    "nullable_identifier": {
      "oneOf": [
        { "$ref": "#/$defs/identifier" },
        { "type": "null" }
      ]
    },
    "event_type": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(?:[._:-][a-z0-9]+)*$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{0,63}$"
    },
    "utc_timestamp": {
      "type": "string",
      "format": "date-time",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(?:\\.[0-9]+)?Z$"
    },
    "safe_object": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/safe_property_name" },
      "patternProperties": {
        "(?:^|_)has_|Has[A-Z]": { "type": "boolean" },
        "(?:_masked|Masked)$": { "type": "string" },
        "(?:^|_)auth_header$|AuthHeader$": {
          "type": "string",
          "pattern": "^(?:$|.*<token>.*)$"
        },
        "(?:^|_|[a-z])(?:path|Path|cwd|Cwd|workdir|Workdir|log_file|logFile|file_path|filePath|source_path|sourcePath|stored_path|storedPath)$": {
          "oneOf": [
            { "type": "string", "pattern": "^(?!/|\\\\|[A-Za-z]:[\\\\/]).*$" },
            { "type": "null" }
          ]
        }
      },
      "additionalProperties": { "$ref": "#/$defs/safe_value" }
    },
    "safe_property_name": {
      "anyOf": [
        { "pattern": "(?:^|_)has_|Has[A-Z]" },
        { "pattern": "(?:_masked|Masked)$" },
        {
          "not": {
            "pattern": "[Ww]orkspace[_-]?[Pp]ath|(?:^|_)[Ee]nv(?:$|_)|[Ee]nv[_-]?[Vv]ars|[Aa][Pp][Ii][_-]?[Kk]ey|[Aa]uth[_-]?[Tt]oken|[Aa]ccess[_-]?[Tt]oken|[Rr]efresh[_-]?[Tt]oken|[Tt]oken|[Pp]assword|[Ss]ecret|[Cc]redential|[Pp]rivate[_-]?[Kk]ey|[Aa]uthorization|[Cc]ookie|(?:^|_)[Ss]ession(?:$|_(?:[Tt]oken|[Ss]ecret|[Cc]redential))|[Ss]ession(?:Token|Secret|Credential)"
          }
        }
      ]
    },
    "safe_value": {
      "anyOf": [
        { "type": ["string", "number", "integer", "boolean", "null"] },
        { "$ref": "#/$defs/safe_object" },
        { "type": "array", "items": { "$ref": "#/$defs/safe_value" } }
      ]
    }
  }
}

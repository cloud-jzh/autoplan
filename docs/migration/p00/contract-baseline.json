  "stateMachines": [
    {
      "id": "state.plan",
      "source": "src/renderer/types.ts",
      "const": "PLAN_STATUS",
      "states": ["pending", "running", "ready_for_validation", "validation_failed", "completed", "interrupted", "draft"],
      "transitions": "draft->running; pending->running->ready_for_validation->completed|validation_failed; active->interrupted; interrupted|validation_failed->pending"
    },
    {
      "id": "state.task-event",
      "source": "src/loop/taskEvents.js",
      "const": "TASK_EVENT_STATUS",
      "states": ["pending", "running", "completed", "failed", "stopping", "stopped", "interrupted"],
      "transitions": "pending|blocked|failed->running; running->completed|pending(retry after failed event)|stopped|blocked(interrupted)"
    },
    {
      "id": "state.terminal",
      "source": "src/terminal/terminalTypes.js",
      "const": "TERMINAL_STATUS",
      "states": ["starting", "running", "exited", "killed", "error"],
      "transitions": "starting->running|error; running->exited|killed|error; terminal session may then be closed"
    },
    {
      "id": "state.terminal-errors",
      "source": "src/terminal/terminalTypes.js",
      "const": "TERMINAL_ERROR_CODES",
      "states": [
        "PTY_UNAVAILABLE", "INVALID_PROJECT", "INVALID_SESSION", "INVALID_PAYLOAD", "CWD_OUTSIDE_WORKSPACE",
        "SESSION_NOT_FOUND", "WRITE_FAILED", "RESIZE_FAILED", "KILL_FAILED"
      ],
      "transitions": "errors are returned as TerminalErrorResult and do not throw across IPC"
    },
    {
      "id": "state.loop-phase",
      "source": "src/loopService.js",
      "states": ["idle", "running", "scan", "generate-plan", "execute-task", "validate", "waiting", "stopped", "error"],
      "markers": [
        "VALUES (?, 0, 'idle', 5, '', ?)", "['running', nowIso(), projectId]", "this.setPhase(projectId, 'scan')",
        "this.setPhase(projectId, 'waiting')", "this.setPhase(projectId, 'idle')"
      ],
      "transitions": "start->running->scan->generate-plan|execute-task|validate->waiting|idle; stop->stopped; recordRuntimeError->error"
    },
    {
      "id": "state.chat-generation",
      "source": "src/chat/chatController.js",
      "states": ["idle", "active", "done", "aborted", "error", "max_rounds"],
      "markers": [
        "active = true;", "finishGeneration({ status: 'done'", "finishGeneration({ status: 'aborted'", "finishGeneration({ status: 'error'",
        "finishGeneration({ status: 'max_rounds' })"
      ],
      "transitions": "idle->active->done|aborted|error|max_rounds; terminal transition releases processing and pumps next queued item"
    },
    {
      "id": "state.chat-queue",
      "source": "src/chat/chatQueue.js",
      "states": ["queued", "processing", "removed"],
      "markers": [
        "const item = { id, content, state: 'queued' };", "item.state = 'processing';", "items = items.filter((it) => it.state !== 'processing');",
        "WHERE conversation_id = ? AND project_id = ? AND status = 'queued'", "ORDER BY id ASC"
      ],
      "transitions": "enqueue queued->markProcessing processing->release removed; cancel/clear affect queued only; persisted queued rows recover FIFO"
    }
  ],
  "errorContracts": [
    {
      "id": "error.invalid-project",
      "domain": "project/all project-scoped commands",
      "codeCandidate": "PROJECT_NOT_FOUND",
      "currentBehavior": "Most IPC handlers throw Error('项目不存在'); Chat and Terminal return structured negative results in selected paths.",
      "retryable": false,
      "currentTextBoundary": ["项目不存在", "对话不存在或不属于当前项目"]
    },
    {
      "id": "error.busy-workspace",
      "domain": "Loop/Task/Executor",
      "codeCandidate": "WORKSPACE_BUSY",
      "currentBehavior": "Throws when a workspace is already owned or a project runtime is busy; no write should occur before the guard.",
      "retryable": true,
      "currentTextBoundary": ["工作区正在被项目", "该项目已有任务在运行"]
    },
    {
      "id": "error.invalid-state",
      "domain": "Plan/Task/Acceptance",
      "codeCandidate": "INVALID_STATE_TRANSITION",
      "currentBehavior": "Throws current Chinese boundary text for non-running stop, non-completed redo/re-execute, or acceptance before completion.",
      "retryable": false,
      "currentTextBoundary": ["计划未在运行中", "仅可重新执行已完成的计划", "仅可验收已完成的计划/任务"]
    },
    {
      "id": "error.chat-command",
      "domain": "Chat",
      "codeCandidate": "CHAT_INVALID_REQUEST",
      "currentBehavior": "send/stop/clear return accepted|stopped|cleared=false plus error; history returns [] for missing or cross-project conversation.",
      "retryable": false,
      "currentTextBoundary": ["消息不能为空", "conversationId 不能为空", "对话不存在或不属于当前项目"]
    },
    {
      "id": "error.terminal-structured",
      "domain": "Terminal",
      "codeCandidate": "existing TERMINAL_ERROR_CODES",
      "currentBehavior": "All terminal handlers normalize failures to {ok:false,code,message,details?}; withTerminalError converts thrown errors to INVALID_PAYLOAD.",
      "retryable": true,
      "currentTextBoundary": ["终端请求无效", "终端会话不存在", "终端能力不可用"]
    },
    {
      "id": "error.file-policy",
      "domain": "File/Workspace",
      "codeCandidate": "PATH_NOT_ALLOWED",
      "currentBehavior": "Path policy/open failures return {ok:false,error} where defined or throw at validation boundaries; unauthorized paths must not be opened.",
      "retryable": false,
      "currentTextBoundary": ["invalid url", "非法的文件访问范围"]
    }
  ],
  "eventOrdering": [
    {
      "id": "order.snapshot-patch",
      "source": "src/renderer/hooks/useSnapshot.ts",
      "producer": "loop:update and loop:patch",
      "consumer": "useSnapshot",
      "payload": "AppSnapshot / WorkspaceSnapshotPatch",
      "ordering": "A scheduled full snapshot clears queued patches; at flush the full snapshot is applied before later per-project patches. Patches are coalesced by project key in an animation frame.",
      "ordered": [["queuedSnapshot = next;", "queuedPatches.clear();", "scheduleFrame();"], ["if (latestSnapshot) next = applySnapshotForProject", "for (const latestPatch of latestPatches)"]]
    },
    {
      "id": "order.task-lifecycle",
      "source": "src/loopService.js",
      "producer": "task execution/runtime",
      "consumer": "snapshot events and task rows",
      "payload": "task row plus task.* AppEvent meta",
      "ordering": "Task row persistence happens before addTaskLifecycleEvent; failure records a failed event while resetting the persisted task to pending for retry.",
      "ordered": [["const failedTask = this.finishTaskRun(task.id, TASK_EVENT_STATUS.PENDING", "this.addTaskLifecycleEvent(projectId, TASK_EVENT_TYPES.FAILED"]]
    },
    {
      "id": "order.chat-terminal",
      "source": "src/chat/chatController.js",
      "producer": "ChatController.finishGeneration",
      "consumer": "chat:queue and chat:done subscribers",
      "payload": "queue snapshot then ChatDoneEvent",
      "ordering": "Current compatibility order is active=false, clear abort handle, release processing (queue snapshot), pump next queued item, then emit done for the completed run.",
      "ordered": [["active = false;", "abortController = null;", "queue.releaseProcessing();", "pump();", "emitDone(payload);"]]
    },
    {
      "id": "order.terminal-lifecycle",
      "source": "src/terminal/terminalService.js",
      "producer": "PTY callbacks",
      "consumer": "terminal:data/status/exit/closed",
      "payload": "safe terminal events",
      "ordering": "Data is emitted as received; on exit the session status and endedAt are set before EXIT and STATUS. Explicit close emits CLOSED after session removal.",
      "ordered": [["session.status = session.killRequested ? TERMINAL_STATUS.KILLED : TERMINAL_STATUS.EXITED;", "session.endedAt = nowIso();", "this.emit(TERMINAL_CHANNELS.EXIT", "this.emit(TERMINAL_CHANNELS.STATUS"]]
    }
  ],
  "sideEffectContracts": [
    {
      "id": "effects.project-intake",
      "domain": "Project/Intake/Attachment",
      "success": "Database rows and attachment files are persisted, then an AppSnapshot is returned/emitted.",
      "failure": "Validation errors throw before mutation where guarded; multi-step legacy paths are not universally transactional and current partial-write risk remains frozen.",
      "idempotency": "Reads are idempotent; create is not idempotent; update is last-write-wins; delete requires existing scoped records and repeated deletion errors or returns no record by path.",
      "cancellation": "Intake plan generation can be interrupted through linked plan/task runtime operations.",
      "recovery": "Snapshot reloads database truth; retryIntakePlanGeneration creates a new attempt while retaining failure counters/log metadata."
    },
    {
      "id": "effects.plan-task-loop",
      "domain": "Loop/Plan/Task/Acceptance",
      "success": "State rows, plan/task files and events are updated around child-process execution; compatible mutations return AppSnapshot.",
      "failure": "Runtime error stores phase=error/last_error and emits loop.error; task failure event may coexist with persisted pending retry state.",
      "idempotency": "start on an already running runtime and runOnce while busy are no-ops; stop tolerates absent runtime work; acceptance timestamps are stateful writes.",
      "cancellation": "stopTask/stopPlan/stopLoop terminate child processes, archive operations and persist stopped/blocked/interrupted state before update emission.",
      "recovery": "Interrupted or validation-failed plans resume to pending; completed plans may re-execute; timed-out task retry may clear session context and reopen a new session."
    },
    {
      "id": "effects.script-executor",
      "domain": "Script/Executor",
      "success": "Definitions persist in the database; run actions spawn processes and store status, exit code, duration and bounded logs.",
      "failure": "Configuration/path/spawn errors are returned in run results or thrown at handler boundaries; last_status becomes bad where execution completed unsuccessfully.",
      "idempotency": "Definition updates are last-write-wins; plugin start rejects already-running; stop of an inactive process is tolerated by the runner path where supported.",
      "cancellation": "stop terminates one-shot or persistent plugin processes and archives the operation.",
      "recovery": "Persisted plugin_state is normalized after process exit; snapshots reconcile running state from the live runtime registry."
    },
    {
      "id": "effects.chat-config",
      "domain": "Chat/Conversation/AI/Claude config",
      "success": "Messages/queue/config/conversation rows persist before their corresponding complete snapshot or changed event.",
      "failure": "Chat generation produces done(error|aborted|max_rounds); command validation returns structured false results; config CRUD throws for missing records.",
      "idempotency": "History/list/get are idempotent; queue cancel/edit only affect queued items; clear is safe when no controller but reports current compatibility result.",
      "cancellation": "chatStop aborts the active backend and marks the latest assistant message aborted; queued items remain for sequential continuation.",
      "recovery": "queued database rows reload ordered by id; controllers resume queued work; secrets remain masked in config DTOs and change events."
    },
    {
      "id": "effects.terminal",
      "domain": "Terminal",
      "success": "Create spawns a PTY; write/resize/kill mutate the live session; replay returns bounded scrollback; close removes the retained session.",
      "failure": "Every command returns TerminalErrorResult without leaking process handles; invalid cwd/session/payload fails before PTY mutation.",
      "idempotency": "list/replay are reads; resize to the same dimensions is harmless; kill on a terminal session is normalized by current TerminalService behavior.",
      "cancellation": "kill requests PTY termination; process exit decides killed versus exited; close is a distinct final lifecycle action.",
      "recovery": "Terminal sessions are in-memory only; renderer refreshes list/replay while process lifetime remains owned by the desktop runtime."
    },
    {
      "id": "effects.desktop",

  "migrationSteps": [
    {"id":"migration.default-project","source":"src/database.js","contains":["ensureDefaultProject()", "SELECT * FROM loop_state WHERE id = 1", "从旧版单项目数据自动迁移"],"effect":"Create one default project from loop_state when projects is empty."},
    {"id":"migration.assign-project","source":"src/database.js","contains":["assignLegacyRows(projectId)", "UPDATE ${table} SET project_id = ? WHERE project_id IS NULL"],"effect":"Assign nullable legacy requirements/feedback/attachments/plans/events/scan rows to the default project."},
    {"id":"migration.intake-plan-links","source":"src/database.js","contains":["ensureIntakePlanLinksTable()", "backfillIntakePlanLinks()", "INSERT OR IGNORE INTO intake_plan_links"],"effect":"Create normalized intake-plan links and backfill valid same-project legacy linked_plan_id values."},
    {"id":"migration.plan-sort","source":"src/database.js","contains":["backfillPlanSortOrders()", "ORDER BY COALESCE(project_id, 0) ASC, created_at ASC, id ASC", "UPDATE plans SET sort_order = ? WHERE id = ?"],"effect":"Keep positive orders and allocate increasing orders to zero/invalid rows per project."},
    {"id":"migration.scan-rebuild","source":"src/database.js","contains":["ALTER TABLE scan_files RENAME TO scan_files_legacy", "PRIMARY KEY (project_id, scan_type, file_path)", "DROP TABLE scan_files_legacy"],"ordered":[["ALTER TABLE scan_files RENAME TO scan_files_legacy", "CREATE TABLE scan_files", "INSERT OR REPLACE INTO scan_files", "DROP TABLE scan_files_legacy"]],"effect":"Rebuild the old scan table to add project_id to the composite primary key."},
    {"id":"migration.ai-global-dedupe","source":"src/database.js","contains":["UPDATE ai_configs SET project_id = NULL", "groupRows.sort((a, b) => Number(a.id) - Number(b.id))", "DELETE FROM ai_configs WHERE id IN"],"effect":"Promote AI configs to global scope, keep the smallest identical id, remap conversations, then delete duplicates."},
    {"id":"migration.legacy-chat-config","source":"src/database.js","contains":["migrateChatToAiConfigs", "this.getSetting('chat.apiKey')", "INSERT INTO ai_configs"],"effect":"Create one global AI config from legacy chat.* settings only when no global config exists."},
    {"id":"migration.chat-conversations","source":"src/database.js","contains":["migrateChatMessagesToConversation", "UPDATE conversations SET project_id", "UPDATE chat_messages SET conversation_id"],"effect":"Repair message project scope and attach legacy unscoped messages to a per-project default conversation."},
    {"id":"migration.order","source":"src/database.js","contains":[],"ordered":[["migrateScanFilesTable(defaultProjectId)", "assignLegacyRows(defaultProjectId)", "backfillIntakePlanLinks()", "backfillPlanSortOrders()", "ensureProjectState(defaultProjectId)", "migrateAiConfigsToGlobal()", "migrateChatToAiConfigs(defaultProjectId)", "migrateChatMessagesToConversation(defaultProjectId)"]],"effect":"Freeze migration ordering because later backfills depend on project assignment and config remapping."}

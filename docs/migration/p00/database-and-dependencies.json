    {"id":"provenance.executor-required-columns","table":"executors","columns":["project_id","label","command","created_at","updated_at"],"freshDatabase":"initial CREATE requires values and has no DEFAULT","legacyDatabase":"ensureColumn adds compatibility defaults 1 or empty string","risk":"omitting these values can succeed on an upgraded legacy DB but fail on a fresh DB"},

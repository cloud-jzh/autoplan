  "tableSemantics": [
    {"table":"settings","primaryKey":"key","relations":"none","orphanRisk":"free-form keys are not schema-constrained","writers":"AppDatabase settings, MCP/update/chat/terminal/file policy","notes":"values are strings; several keys contain credentials or local paths"},
    {"table":"projects","primaryKey":"id AUTOINCREMENT","relations":"logical parent for most project_id columns","orphanRisk":"no SQLite foreign keys; deletion is manual multi-table cleanup","writers":"intakeService and main project handlers","notes":"workspace_path is required but may be empty"},
    {"table":"project_states","primaryKey":"project_id","relations":"logical 1:1 projects.id","orphanRisk":"no foreign key; legacy loop_state seeds the default row","writers":"LoopService/runtime/configuration","notes":"effective columns include plan backend config ids added only by ensureColumn"},
    {"table":"requirements","primaryKey":"id AUTOINCREMENT","relations":"project_id; linked_plan_id; intake_plan_links","orphanRisk":"nullable project/link columns and no foreign keys","writers":"intakeService, main, planGeneration, acceptance/deletion","notes":"linked_plan_id and Claude config id are absent from the initial CREATE and added later"},
    {"table":"feedback","primaryKey":"id AUTOINCREMENT","relations":"project_id; requirement_id; linked_plan_id; intake_plan_links","orphanRisk":"requirement_id/link/project are not constrained","writers":"intakeService, main, planGeneration, acceptance/deletion","notes":"linked_plan_id and Claude config id are ensureColumn-only"},
    {"table":"attachments","primaryKey":"id AUTOINCREMENT","relations":"owner_type + owner_id + project_id logical relation","orphanRisk":"owner deletion/file deletion can diverge without a foreign key","writers":"attachments.js and intake deletion","notes":"stored_path points to an external file"},
    {"table":"scan_files","primaryKey":"project_id, scan_type, file_path","relations":"logical projects.id","orphanRisk":"no foreign key; legacy rows are assigned to the fallback project","writers":"workspace scan worker aggregation","notes":"old primary key is rebuilt via rename/copy/drop"},
    {"table":"plans","primaryKey":"id AUTOINCREMENT","relations":"project_id; linked from intake_plan_links and legacy linked_plan_id","orphanRisk":"no foreign keys; file_path may be missing/stale","writers":"Loop/plan generation/lifecycle/parser/validation/Chat tools","notes":"sort/config ids and execution config have compatibility backfills"},
    {"table":"plan_tasks","primaryKey":"id AUTOINCREMENT","relations":"plan_id; UNIQUE(plan_id, task_key)","orphanRisk":"no foreign key, so deleted/missing plan can orphan tasks","writers":"plan parser/sync/execution/lifecycle/acceptance","notes":"duration/session/accepted fields are later compatibility columns on old databases"},
    {"table":"events","primaryKey":"id AUTOINCREMENT","relations":"logical project_id","orphanRisk":"project_id was nullable on legacy data and has no foreign key","writers":"LoopService and plan/task application services","notes":"meta is JSON-or-text and may contain paths/log fragments"},
    {"table":"scripts","primaryKey":"id AUTOINCREMENT","relations":"logical project_id","orphanRisk":"file-backed path can be invalid; project relation unconstrained","writers":"main script handlers and scriptHooks","notes":"source_type and schedule_cron are ensureColumn compatibility additions"},
    {"table":"executors","primaryKey":"id AUTOINCREMENT","relations":"logical project_id; dependencies stored as JSON labels","orphanRisk":"dependency labels and project_id are not foreign keys","writers":"executorStore/runner","notes":"command, args, env/options, actions and logs are JSON/text process inputs"},
    {"table":"chat_messages","primaryKey":"id AUTOINCREMENT","relations":"project_id + conversation_id logical relation","orphanRisk":"both relations lack foreign keys; legacy messages can start without conversation_id","writers":"chatController/chatQueue","notes":"conversation_id is ensureColumn-only for old/new base DDL"},
    {"table":"ai_configs","primaryKey":"id AUTOINCREMENT","relations":"conversation.ai_config_id logical relation; project_id migrated to NULL","orphanRisk":"conversation references are manually remapped on dedupe/delete","writers":"aiConfigService and legacy migration","notes":"api_key is secret; configs are globally scoped after migration"},
    {"table":"claude_cli_configs","primaryKey":"id AUTOINCREMENT","relations":"global rows use project_id NULL","orphanRisk":"no foreign keys; default uniqueness is application-enforced","writers":"claudeCliConfigService","notes":"auth_token is secret"},
    {"table":"conversations","primaryKey":"id AUTOINCREMENT","relations":"project_id and ai_config_id logical relations","orphanRisk":"messages/config refs are manually maintained","writers":"chatController and migrations","notes":"codex_session_id is an ensureColumn compatibility field"},
    {"table":"loop_state","primaryKey":"id CHECK id=1","relations":"legacy singleton seed for projects/project_states","orphanRisk":"retained compatibility table can diverge after migration","writers":"initial migration only in current flow","notes":"cannot reconstruct multi-project state from this table"},
    {"table":"intake_plan_links","primaryKey":"id AUTOINCREMENT","relations":"project/intake/plan logical relations; unique project+type+intake+plan and phase index","orphanRisk":"no foreign keys; missing plans/intakes remain possible","writers":"intakePlanLinks and backfill","notes":"table is created outside the initial DDL block"}
  ],

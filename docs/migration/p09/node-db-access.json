{
  "schema_version": 1,
  "purpose": "P001 reviewed Node database access inventory and Go command closure registry. Values are source-relative metadata only.",
  "report_contract": {
    "call_site_fields": ["source_path", "line", "category", "contract_id"],
    "permitted_categories": [
      "read",
      "write",
      "settings_read",
      "settings_write",
      "app_database_constructor",
      "sqljs_initialization",
      "database_export",
      "database_persist",
      "mirror_overwrite_risk",
      "backup_overwrite_risk",
      "database_close"
    ],
    "forbidden_content": "No row values, credentials, runtime configuration values, local roots, message bodies, or tool payloads are permitted."
  },
  "contracts": {
    "database_lifecycle": {
      "status": "planned_p003_p005",
      "application_service": "bootstrap database owner plus maintenance cutover",
      "rest": "internal lifecycle only",
      "input_dto": "database_owner_request",
      "output_dto": "database_owner_state",
      "dto_rule": "snake_case; no database locator is returned",
      "snapshot": "owner epoch only",
      "transaction": "exclusive owner before open; handoff is fail-closed",
      "side_effects": "schema migration, durable snapshot replacement, backup and close",
      "authorization": "desktop supervisor or maintenance operator",
      "error_codes": ["database_owner_locked", "database_schema_owned_by_go", "maintenance_required"]
    },
    "project_gateway": {
      "status": "existing",
      "application_service": "projects.Service and snapshot.Assembler",
      "rest": "/api/v1/projects and /api/v1/projects/{project_id}/snapshot",
      "input_dto": "project_create_update_delete_request",
      "output_dto": "project_snapshot",
      "dto_rule": "snake_case REST fields; snapshot preserves ordered collections",
      "snapshot": "project_snapshot after committed mutation",
      "transaction": "project-owned rows and audit event commit together",
      "side_effects": "project lifecycle and runtime stop request",
      "authorization": "project-scoped caller",
      "error_codes": ["not_found", "conflict", "forbidden", "invalid_request"]
    },
    "loop_runtime": {
      "status": "planned_p002",
      "application_service": "loop runtime application service",
      "rest": "/api/v1/projects/{project_id}/loop actions",
      "input_dto": "loop_command_request",
      "output_dto": "operation_snapshot",
      "dto_rule": "snake_case and explicit null/default handling",
      "snapshot": "post-transition project snapshot",
      "transaction": "state transition and event are atomic; process work starts after commit",
      "side_effects": "scheduler, agent and hook lifecycle",
      "authorization": "project-scoped caller",
      "error_codes": ["not_found", "conflict", "operation_cancelled", "service_unavailable"]
    },
    "intake": {
      "status": "existing",
      "application_service": "intake.Service",
      "rest": "/api/v1/projects/{project_id}/requirements and /api/v1/projects/{project_id}/feedback",
      "input_dto": "intake_create_update_link_request",
      "output_dto": "intake_snapshot",
      "dto_rule": "snake_case with explicit nullable links",
      "snapshot": "project snapshot after mutation",
      "transaction": "intake, links and audit event commit together",
      "side_effects": "plan linkage and runtime cancellation request",
      "authorization": "project-scoped caller",
      "error_codes": ["not_found", "duplicate", "conflict", "invalid_request"]
    },
    "attachments": {
      "status": "existing",
      "application_service": "attachments.Service",
      "rest": "/api/v1/projects/{project_id}/requirements/{intake_id}/attachments and attachment item routes",
      "input_dto": "attachment_upload_delete_request",
      "output_dto": "attachment_metadata",
      "dto_rule": "snake_case metadata only",
      "snapshot": "owner snapshot after committed metadata",
      "transaction": "staged object workflow with recovery record",
      "side_effects": "staged object promotion or quarantine",
      "authorization": "project-scoped caller",
      "error_codes": ["not_found", "invalid_attachment", "conflict", "storage_unavailable"]
    },
    "plans": {
      "status": "existing_queries_planned_runtime_p002",
      "application_service": "plans.Service and tasks application service",
      "rest": "/api/v1/plans/actions and /api/v1/tasks/actions",
      "input_dto": "plan_task_command_request",
      "output_dto": "plan_task_snapshot",
      "dto_rule": "snake_case; stable ordering and status values",
      "snapshot": "committed plan and task projection",
      "transaction": "plan, task, link and event mutation boundary",
      "side_effects": "plan file synchronization, validation and agent execution",
      "authorization": "project-scoped caller",
      "error_codes": ["not_found", "conflict", "invalid_state", "operation_cancelled"]
    },
    "chat_runtime": {
      "status": "planned_p002",
      "application_service": "chat application service",
      "rest": "/api/v1/projects/{project_id}/conversations runtime commands",
      "input_dto": "chat_queue_command_request",
      "output_dto": "conversation_runtime_snapshot",
      "dto_rule": "snake_case; content is not exposed by this audit",
      "snapshot": "ordered conversation and queue state",
      "transaction": "queue status transition and event boundary",
      "side_effects": "stream, queue pump and tool dispatch",
      "authorization": "project-scoped caller",
      "error_codes": ["not_found", "conflict", "operation_cancelled", "service_unavailable"]
    },
    "chat_config": {
      "status": "existing",
      "application_service": "config static service and chat history service",
      "rest": "/api/v1/ai-configs, /api/v1/claude-cli-configs and conversation routes",
      "input_dto": "chat_config_request",
      "output_dto": "chat_config_metadata",
      "dto_rule": "snake_case; secret material is represented by presence metadata",
      "snapshot": "ordered global configuration and conversation projection",
      "transaction": "configuration mutation and reference update commit together",
      "side_effects": "default selection and conversation binding",
      "authorization": "authorized local caller",
      "error_codes": ["not_found", "conflict", "invalid_request", "forbidden"]
    },
    "automation": {
      "status": "existing_static_planned_runtime_p002",
      "application_service": "automation application service",
      "rest": "/api/v1/projects/{project_id}/scripts and /api/v1/projects/{project_id}/executors",
      "input_dto": "automation_definition_request",
      "output_dto": "automation_snapshot",
      "dto_rule": "snake_case and stable list ordering",
      "snapshot": "committed script and executor projection",
      "transaction": "definition change and event commit together",
      "side_effects": "future hook or executor dispatch remains explicit",
      "authorization": "project-scoped caller",
      "error_codes": ["not_found", "conflict", "invalid_request", "service_unavailable"]
    },
    "mcp_runtime_bridge": {
      "status": "planned_p002",
      "application_service": "shared application services through MCP adapter",
      "rest": "/api/v1/capabilities and application command routes",
      "input_dto": "mcp_command_request",
      "output_dto": "mcp_command_result",
      "dto_rule": "snake_case with sanitized result metadata",
      "snapshot": "same snapshot contract as REST",
      "transaction": "delegates to the target application service",
      "side_effects": "MCP runtime lifecycle only after command commit",
      "authorization": "local MCP caller scope",
      "error_codes": ["forbidden", "not_found", "conflict", "service_unavailable"]
    },
    "config": {
      "status": "existing",
      "application_service": "config.Service",
      "rest": "/api/v1/projects/{project_id}/loop-config and /api/v1/mcp-config",
      "input_dto": "config_patch_request",
      "output_dto": "config_snapshot",
      "dto_rule": "snake_case with explicit defaults",
      "snapshot": "committed configuration projection",
      "transaction": "versioned configuration mutation",
      "side_effects": "runtime refresh is requested after commit",
      "authorization": "authorized project or local caller",
      "error_codes": ["not_found", "conflict", "invalid_request", "forbidden"]
    },
    "file_policy": {
      "status": "existing",
      "application_service": "files policy application service",
      "rest": "/api/v1/file-access-policy",
      "input_dto": "file_policy_request",
      "output_dto": "file_policy_snapshot",
      "dto_rule": "snake_case normalized policy fields",
      "snapshot": "committed policy projection",
      "transaction": "single policy replacement",
      "side_effects": "subsequent local file authorization",
      "authorization": "authorized local caller",
      "error_codes": ["invalid_request", "conflict", "forbidden"]
    },
    "terminal_config": {
      "status": "planned_p002",
      "application_service": "config application service",
      "rest": "/api/v1/terminal-config",
      "input_dto": "terminal_config_request",
      "output_dto": "terminal_config_snapshot",
      "dto_rule": "snake_case and explicit defaults",
      "snapshot": "committed terminal configuration",
      "transaction": "single configuration mutation",
      "side_effects": "new terminal session defaults only",
      "authorization": "authorized project or local caller",
      "error_codes": ["invalid_request", "conflict", "forbidden"]
    },
    "update_config": {
      "status": "planned_p002",
      "application_service": "config application service",
      "rest": "/api/v1/update-config",
      "input_dto": "update_config_request",
      "output_dto": "update_config_snapshot",
      "dto_rule": "snake_case with explicit defaults",
      "snapshot": "committed update preference projection",
      "transaction": "batched preference mutation",
      "side_effects": "future update scheduling only",
      "authorization": "authorized local caller",
      "error_codes": ["invalid_request", "conflict", "forbidden"]
    },
    "snapshot": {
      "status": "existing",
      "application_service": "snapshot.Assembler",
      "rest": "/api/v1/projects/{project_id}/snapshot",
      "input_dto": "snapshot_query",
      "output_dto": "app_snapshot",
      "dto_rule": "snake_case source contract with deterministic ordering",
      "snapshot": "read-only project projection",
      "transaction": "read transaction",
      "side_effects": "none",
      "authorization": "project-scoped caller",
      "error_codes": ["not_found", "forbidden", "service_unavailable"]
    }
  },
  "source_rules": {
    "src/attachments.js": {"contract_ids": ["attachments"], "methods": {"insert": 1}},
    "src/chat/aiConfigService.js": {"contract_ids": ["chat_config"], "methods": {"all": 1, "get": 6, "getSettings": 1, "insert": 1, "run": 3}, "settings_access": "reviewed"},
    "src/chat/chatController.js": {"contract_ids": ["chat_runtime"], "methods": {"all": 3, "get": 8, "insert": 1, "run": 13}},
    "src/chat/chatQueue.js": {"contract_ids": ["chat_runtime"], "methods": {"all": 1, "insert": 1, "run": 4}},
    "src/chat/chatTools.js": {"contract_ids": ["plans", "automation", "file_policy"], "methods": {"all": 3, "get": 5, "insert": 1, "run": 3}, "dynamic_sql": "reviewed"},
    "src/chat/claudeCliConfigService.js": {"contract_ids": ["chat_config"], "methods": {"all": 1, "get": 7, "insert": 1, "run": 3, "runBatch": 1}, "dynamic_sql": "reviewed"},
    "src/database.js": {"contract_ids": ["database_lifecycle"], "methods": {"run": 31}, "dynamic_sql": "reviewed", "direct_settings_sql": "reviewed", "lifecycle": {"sqljs_initialization": 1, "database_export": 1, "database_persist": 4, "mirror_overwrite_risk": 2, "backup_overwrite_risk": 2, "database_close": 2}},
    "src/executors/executorStore.js": {"contract_ids": ["automation"], "methods": {"all": 2, "get": 2, "insert": 1, "run": 4}, "dynamic_sql": "reviewed"},
    "src/fileAccess/policy.js": {"contract_ids": ["file_policy"], "methods": {"getSetting": 1}, "settings_access": "reviewed"},
    "src/intakeService.js": {"contract_ids": ["intake", "attachments"], "methods": {"all": 2, "get": 1, "insert": 3}},
    "src/loop/acceptance.js": {"contract_ids": ["plans", "intake"], "methods": {"get": 5, "run": 6}, "dynamic_sql": "reviewed"},
    "src/loop/intakeDeletion.js": {"contract_ids": ["intake", "attachments", "plans"], "methods": {"all": 1, "get": 3, "runBatch": 2}, "dynamic_sql": "reviewed"},
    "src/loop/intakeMentions.js": {"contract_ids": ["intake"], "methods": {"all": 1, "get": 1}, "dynamic_sql": "reviewed"},
    "src/loop/intakePlanLinks.js": {"contract_ids": ["intake", "plans"], "methods": {"all": 5, "get": 2, "runBatch": 3}, "dynamic_sql": "reviewed"},
    "src/loop/planAgentCli.js": {"contract_ids": ["plans", "intake"], "methods": {"all": 1, "get": 4}},
    "src/loop/planGeneration.js": {"contract_ids": ["plans", "intake"], "methods": {"all": 1, "run": 11}, "dynamic_sql": "reviewed"},
    "src/loop/planLifecycle.js": {"contract_ids": ["plans", "intake"], "methods": {"all": 1, "get": 22, "insert": 1, "run": 7, "runBatch": 6}, "dynamic_sql": "reviewed"},
    "src/loop/planParser.js": {"contract_ids": ["plans"], "methods": {"all": 2, "get": 4, "run": 6}},
    "src/loop/planTaskSync.js": {"contract_ids": ["plans"], "methods": {"all": 1, "get": 5, "run": 4}},
    "src/loop/runtime.js": {"contract_ids": ["loop_runtime"], "methods": {"run": 3, "runBatch": 1}, "dynamic_sql": "reviewed"},
    "src/loop/scriptHooks.js": {"contract_ids": ["automation", "loop_runtime"], "methods": {"all": 1, "get": 1, "run": 2}},
    "src/loop/snapshots.js": {"contract_ids": ["snapshot", "config"], "methods": {"all": 8, "get": 2, "getSettings": 1}, "settings_access": "reviewed"},
    "src/loop/taskExecution.js": {"contract_ids": ["plans", "loop_runtime"], "methods": {"all": 2, "get": 9, "run": 1}},
    "src/loop/validation.js": {"contract_ids": ["plans", "loop_runtime"], "methods": {"get": 6, "run": 7}, "dynamic_sql": "reviewed"},
    "src/loop/workspaceFiles.js": {"contract_ids": ["plans", "loop_runtime"], "methods": {"all": 1, "run": 1, "runBatch": 1}, "dynamic_sql": "reviewed"},
    "src/loopService.js": {"contract_ids": ["loop_runtime", "plans", "intake", "automation"], "methods": {"all": 3, "get": 31, "run": 14}, "dynamic_sql": "reviewed"},
    "src/main.js": {"contract_ids": ["project_gateway", "intake", "automation", "chat_runtime", "file_policy", "config"], "methods": {"all": 1, "get": 15, "getSetting": 1, "run": 13, "setSetting": 4}, "dynamic_sql": "reviewed", "direct_settings_sql": "reviewed", "settings_access": "reviewed", "lifecycle": {"app_database_constructor": 1}},
    "src/mcpConfig.js": {"contract_ids": ["config", "mcp_runtime_bridge"], "methods": {"getSetting": 2, "getSettings": 1, "setSetting": 2}, "settings_access": "reviewed"},
    "src/mcpServer.js": {"contract_ids": ["mcp_runtime_bridge", "database_lifecycle"], "methods": {}, "lifecycle": {"app_database_constructor": 1}},
    "src/mcpTools.js": {"contract_ids": ["mcp_runtime_bridge", "plans", "intake", "automation"], "methods": {"all": 5, "get": 6}, "dynamic_sql": "reviewed"},
    "src/terminal/terminalConfig.js": {"contract_ids": ["terminal_config"], "methods": {"getSettings": 2, "setSetting": 1}, "settings_access": "reviewed"},
    "src/updateChecker.js": {"contract_ids": ["update_config"], "methods": {"getSetting": 1, "getSettings": 1, "runBatch": 1, "setSetting": 1}, "dynamic_sql": "reviewed", "settings_access": "reviewed"}
  },
  "dynamic_sql_review": {
    "rule": "A dynamic statement is accepted only where its source rule is marked reviewed. Method counts still freeze the reviewed call surface, so adding, removing, or changing a database method is a failure until this registry is updated.",
    "reviewed_shapes": ["closed internal table selector", "closed internal column selector", "placeholder expansion", "batched statement list"]
  },
  "closure": {
    "node_owner_rule": "The registry describes legacy Node behavior only. It does not authorize Node access after Go ownership is selected.",
    "p002_rule": "Every planned runtime contract must use the same application service and REST command as REST, MCP and UI callers; raw SQL or table endpoints are not a replacement.",
    "error_rule": "Stable application error codes are returned without raw statement text or local filesystem details."
  }
}

{
  "schema_version": 1,
  "kind": "p12-evidence-policy",
  "run_root": "docs/migration/p12/evidence/runs",
  "immutable_run_directory": true,
  "required_artifacts": [
    "summary.json",
    "evidence-manifest.json",
    "sanitized command stdout/stderr logs"
  ],
  "required_summary_fields": [
    "run_id",
    "status",
    "started_at",
    "ended_at",
    "command_results",
    "source_hashes_start",
    "source_hashes_end",
    "fixture",
    "process_cleanup"
  ],
  "forbidden_content": [
    "credential values",
    "environment values",
    "real Electron user data locations",
    "external workspace locations",
    "raw process output",
    "real process identifiers"
  ]
}

            <span className="pill">
              <span className={`led ${state?.running ? 'running' : 'stopped'}`} />
              {state ? `${state.running ? 'running' : 'stopped'} · ${state.phase || 'idle'}` : 'idle'}
            </span>
            <button
              type="button"
              className={`btn btn-sm ${state?.running ? 'btn-danger' : 'btn-primary'}`}
              onClick={() =>
                runLoopAction(() =>
                  state?.running
                    ? window.autoplan.stopLoop({ projectId, manual: true })
                    : window.autoplan.startLoop({ projectId, manual: true }),
                )
              }
            >
              {state?.running ? '■ 停止' : '● 启动'}
            </button>
          </div>
        </header>

        <section className={`view ${activeTab === 'overview' ? 'active' : ''}`}>
          {error ? <div className="error-banner">{error}</div> : null}
          <OverviewView snapshot={snapshot} state={state} onGoTasks={() => setActiveTab('tasks')} />
        </section>

        <section className={`view ${activeTab === 'requirement' ? 'active' : ''}`}>
          {activeTab === 'requirement' ? (
            <IntakePanel
              emptyText="暂无需求。也可以把需求文件放到工作区 docs/issues。"
              heading="需求记录"
              items={snapshot.requirements}
              pendingAttachments={pendingAttachments.requirement}
              placeholder="输入需求，Enter 发送，Shift+Enter 换行"
              submitLabel="发送需求"
              subtitle="循环开启后自动扫描并生成计划"
              type="requirement"
              attachments={snapshot.attachments}
              onAddFiles={addPendingFiles}
              onDelete={deleteRequirement}
              onRemoveAttachment={removePendingAttachment}
              onSubmit={createRequirement}
              onUpdate={updateRequirement}
              onInterrupt={interruptIntake}
              onResume={resumeIntake}
              onAppendTask={appendIntakeTask}
            />
          ) : null}
        </section>

        <section className={`view ${activeTab === 'feedback' ? 'active' : ''}`}>
          {activeTab === 'feedback' ? (
            <IntakePanel
              emptyText="暂无反馈。"
              heading="反馈记录"
              items={snapshot.feedback}
              pendingAttachments={pendingAttachments.feedback}
              placeholder="输入反馈，Enter 发送，Shift+Enter 换行"
              submitLabel="发送反馈"
              subtitle="循环开启后自动扫描并生成计划"
              type="feedback"
              attachments={snapshot.attachments}
              onAddFiles={addPendingFiles}
              onDelete={deleteFeedback}
              onRemoveAttachment={removePendingAttachment}
              onSubmit={createFeedback}
              onUpdate={updateFeedback}
              onInterrupt={interruptIntake}
              onResume={resumeIntake}
              onAppendTask={appendIntakeTask}
            />
          ) : null}
        </section>

        <section className={`view ${activeTab === 'tasks' ? 'active' : ''}`}>
          {activeTab === 'tasks' ? (
            <div className="task-layout">
              <aside className="task-sidebar">
                <form className="editor card" onSubmit={submitLoopConfig}>
                  <div className="card-head">
                    <h2>循环控制</h2>
                  </div>
                  <label className="field">
                    工作区路径
                    <input
                      value={loopForm.workspacePath}
                      onChange={(event) => setLoopForm((current) => ({ ...current, workspacePath: event.target.value }))}
                      placeholder="D:\project\GitHub\my-app"
                    />
                  </label>
                  <label className="field">
                    间隔秒数
                    <input
                      min="1"
                      type="number"
                      value={loopForm.intervalSeconds}
                      onChange={(event) => setLoopForm((current) => ({ ...current, intervalSeconds: event.target.value }))}
                    />
                  </label>
                  <label className="field">
                    验收命令（留空则不校验）
                    <input
                      value={loopForm.validationCommand}
                      onChange={(event) => setLoopForm((current) => ({ ...current, validationCommand: event.target.value }))}
                      placeholder="flutter analyze"
                    />
                  </label>
                  <div className="button-row">
                    <button type="submit">保存配置</button>
                    <button
                      type="button"
                      onClick={() =>
                        runLoopAction(() =>
                          state?.running
                            ? window.autoplan.stopLoop({ projectId, manual: true })
                            : window.autoplan.startLoop({ projectId, manual: true }),
                        )
                      }
                    >
                      {state?.running ? '停止' : '启动'}
                    </button>
                  </div>
                </form>
                <section className="side-section card">
                  <div className="card-head">
                    <h2>事件</h2>
                  </div>
                  <EventList events={snapshot.events} />
                </section>
              </aside>

              <div className="task-main">
                <div className="task-status-grid">
                  <section className="card">
                    <div className="card-head">
                      <h2>Plan</h2>
                    </div>
                    <PlanList plans={snapshot.plans} />
                  </section>
                  <section className="card">
                    <div className="card-head">
                      <h2>任务</h2>
                    </div>
                    <TaskList
                      tasks={snapshot.tasks}
                      onRun={(task) => runLoopAction(() => window.autoplan.runTask({ projectId, taskId: task.id }))}
                      onStop={(task) => runLoopAction(() => window.autoplan.stopTask({ projectId, taskId: task.id }))}
                    />
                  </section>
                </div>
              </div>
            </div>
          ) : null}
        </section>

        <section className={`view ${activeTab === 'events' ? 'active' : ''}`}>
          {activeTab === 'events' ? (
            <section className="card">
              <div className="card-head">
                <h2>事件流</h2>
                <span className="hint">最近 80 条 · 实时更新</span>
              </div>
              <EventList events={snapshot.events} />
            </section>
          ) : null}
        </section>
      </div>
    </div>
  );
}

function WorkspaceSidebar({
  activeTab,
  onTab,
  onBack,
  projectId,
  projects,
  currentProject,
  state,
  onSwitchProject,
}: {
  activeTab: WorkspaceTab;
  onTab: (tab: WorkspaceTab) => void;
  onBack: () => void;
  projectId: number;
  projects: Project[];
  currentProject: Project | null;
  state: ProjectState | null;
  onSwitchProject: (id: number) => void;
}) {
  return (
    <aside className="sidebar">
      <div className="brand">
        <div className="brand-mark">A</div>
        <div>
          <div className="brand-name">AutoPlan</div>
          <div className="brand-sub">需求 · 计划 · 执行 · 验收</div>
        </div>
      </div>

      <button type="button" className="back-link" onClick={onBack}>
        ← 返回项目列表
      </button>

      <div className="project-switcher">
        <div className="project-label">当前项目</div>
        <select
          className="project-select"
          value={projectId}
          onChange={(event) => onSwitchProject(Number(event.target.value))}
        >
          {projects.map((project) => (
            <option key={project.id} value={project.id}>
              {project.name}
            </option>
          ))}
        </select>
        {currentProject ? <div className="project-path mono">{currentProject.workspace_path || '未设置工作区'}</div> : null}
      </div>

      <div className="nav-group-label">工作区</div>
      {tabs.map((tab) => (
        <button
          className={`nav-item ${activeTab === tab.id ? 'active' : ''}`}
          key={tab.id}
          type="button"
          onClick={() => onTab(tab.id)}
        >
          <span className="nav-ico">{tab.icon}</span> {tab.label}
        </button>
      ))}

      <div className="sidebar-footer">
        <div className="loop-mini">
          <span className={`led ${state?.running ? 'running' : 'stopped'}`} />
          <span>
            循环 <b>{state?.running ? '运行中' : '已停止'}</b>
          </span>
        </div>
        <div className="loop-config mono">
          间隔 {state?.interval_seconds || 5}s
          {state?.validation_command ? ` · ${state.validation_command}` : ' · 无验收命令'}
        </div>
      </div>
    </aside>
  );
}

function OverviewView({
  snapshot,
  state,
  onGoTasks,
}: {
  snapshot: AppSnapshot;
  state: ProjectState | null;
  onGoTasks: () => void;
}) {
  const reqCount = snapshot.requirements.length;
  const planCount = snapshot.plans.length;
  const runningPlan = snapshot.plans.find((plan) => !['completed'].includes(plan.status));
  const doneTasks = snapshot.tasks.filter((task) => task.status === 'completed').length;
  const totalTasks = snapshot.tasks.length;

  const phases = ['scan', 'generate-plan', 'execute-task', 'validate', 'completed'];
  const currentPhase = state?.phase || 'idle';
  const activeIndex = phases.indexOf(currentPhase);
  const operation = snapshot.activeOperation || snapshot.lastOperation;
  const operationActive = Boolean(snapshot.activeOperation);
  const operationTime = operation?.startedAt ? `开始于 ${formatChinaTime(operation.startedAt)}` : '';
  const operationExit =
    operation && !operationActive && typeof operation.exitCode === 'number'
      ? ` · 退出码 ${operation.exitCode}${operation.exitCode === 0 ? '（成功）' : '（失败）'}`
      : '';
  const operationHint = operation ? `${operationTime}${operationExit}` : '等待下一次执行';
  const operationTitle = operation ? `${operationActive ? '执行日志' : '最近执行'} · ${operation.label}` : '执行日志';

  return (
    <>
      <div className="stat-grid">
        <StatCard icon="◎" value={String(reqCount)} label="需求" accent="brand" />
        <StatCard
          icon="▤"
          value={String(planCount)}
          label="计划"
          sub={runningPlan ? `${runningPlan.completed_tasks}/${runningPlan.total_tasks} 任务` : '无进行中'}
          accent="info"
        />
        <StatCard icon="☑" value={`${doneTasks}/${totalTasks}`} label="任务进度" accent="success" />
        <StatCard icon="↻" value={`${state?.interval_seconds || 5}s`} label="循环间隔" accent="warning" />
      </div>

      <div className="overview-grid">
        <div className="overview-main-column">
          <section className="card live-log-card">
            <div className="card-head log-card-head">
              <div className="log-title-line">
                <h2>
                  <span className={`live-dot${operationActive ? '' : ' idle'}`} /> {operationTitle}
                </h2>
                <span className="hint">{operationHint}</span>
                <span className={`log-phase-chip ${state?.running ? 'running' : 'stopped'}`}>
                  {state?.running ? '循环运行中' : '循环已停止'} · {currentPhase}
                </span>
              </div>
              <div className="log-summary">
                <span>
                  计划草稿 <b>{snapshot.planDrafts.length}</b>
                </span>
                <span>
                  待确认草稿 <b>{snapshot.planDrafts.filter((draft) => draft.status !== 'accepted').length}</b>
                </span>
                <span>
                  反馈 <b>{snapshot.feedback.length}</b>
                </span>
              </div>
            </div>
            <CodexLog log={operation?.logTail || ''} activity={operation?.activity || []} />
          </section>
        </div>

        <div className="overview-side-column">
          <section className="card">
            <div className="card-head">
              <h2>循环阶段流水线</h2>
            </div>
            <div className="card-body">
              <div className="pipeline">
                {phases.map((phase, index) => {
                  const done = activeIndex > index;
                  const active = activeIndex === index;
                  return (
                    <div className={`pipe-step ${done ? 'done' : ''} ${active ? 'active' : ''}`} key={phase}>
                      <div className="pipe-node">{done ? '✓' : active ? '▶' : index + 1}</div>
                      <div className="pipe-label">{phaseLabel(phase)}</div>
                    </div>
                  );
                })}
              </div>
            </div>
          </section>

          <section className="card">
            <div className="card-head">
              <h2>近期事件</h2>
              <span className="spacer">
                <button type="button" className="btn-link" onClick={onGoTasks}>
                  查看任务 →
                </button>
              </span>
            </div>
            <div className="card-body">
              <EventList events={snapshot.events.slice(0, 8)} />
            </div>
          </section>
        </div>
      </div>
    </>
  );
}

function StatCard({
  icon,
  value,
  label,
  sub,
  accent,
}: {
  icon: string;
  value: string;
  label: string;
  sub?: string;
  accent: 'brand' | 'info' | 'success' | 'warning';
}) {
  return (
    <div className={`stat stat-${accent}`}>
      <div className="stat-ico">{icon}</div>
      <div className="stat-value">{value}</div>
      <div className="stat-label">{label}</div>
      {sub ? <div className="stat-delta">{sub}</div> : null}
    </div>
  );
}

function tabTitle(tab: WorkspaceTab) {
  return { overview: '概览', requirement: '需求模块', feedback: '反馈模块', tasks: '任务与计划', events: '事件流' }[tab];
}

function tabSubtitle(tab: WorkspaceTab, project: Project | null) {
  const base = {
    overview: '循环状态、阶段流水线与各模块一览',
    requirement: '收集需求，发送后自动生成计划草稿',
    feedback: '收集反馈，关联需求并生成计划草稿',
    tasks: '循环控制、计划草稿、Plan 与任务进度',
    events: '循环运行日志与任务执行记录',
  }[tab];
  return project ? `${base} · ${project.name}` : base;
}

function phaseLabel(phase: string) {
  return (
    {
      idle: '空闲',
      scan: '扫描',
      'generate-plan': '生成计划',
      'execute-task': '执行任务',
      validate: '验收',
      completed: '完成',
      waiting: '等待',
      error: '异常',
    }[phase] || phase
  );
}
--- src/styles.css ---
/* ============================================================
   设计系统 · Design Tokens
   ============================================================ */
:root {
  color-scheme: light;
  font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
  --font-mono: "Cascadia Code", Consolas, "Courier New", monospace;

  --brand-50: #eef4ff;
  --brand-100: #dbe7ff;
  --brand-500: #3b6ef5;
  --brand-600: #255fbd;
  --brand-700: #1d4a94;
  --brand-grad: linear-gradient(135deg, #4f7bff 0%, #6d5dfc 100%);

  --bg-app: #f4f6fb;
  --bg-elevated: #ffffff;
  --bg-soft: #f8fafd;
  --bg-hover: #eef2f9;
  --line: #e2e8f1;
  --line-soft: #eef2f8;

  --text-1: #172033;
  --text-2: #475067;
  --text-3: #7c879b;
  --text-4: #a4adc0;

  --success: #18a957;
  --success-bg: #e7f7ee;
  --warning: #e08600;
  --warning-bg: #fdf3e3;
  --danger: #e5484d;
  --danger-bg: #fdecec;
  --info: #2563eb;
  --info-bg: #e8f0ff;

  --r-sm: 6px;
  --r-md: 10px;
  --r-lg: 14px;
  --r-xl: 20px;
  --shadow-sm: 0 1px 2px rgba(23, 32, 51, 0.06);
  --shadow-md: 0 6px 18px rgba(23, 32, 51, 0.08);
  --shadow-lg: 0 18px 48px rgba(37, 62, 120, 0.14);

  background: var(--bg-app);
  color: var(--text-1);
}

* { box-sizing: border-box; }
html, body { height: 100%; margin: 0; }
body { overflow: hidden; font-size: 14px; -webkit-font-smoothing: antialiased; }
h1, h2, h3, p { margin: 0; }
button { font: inherit; cursor: pointer; }
a { color: var(--brand-600); text-decoration: none; }
.mono { font-family: var(--font-mono); }
#root { height: 100vh; }

.btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; padding: 9px 16px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-elevated); color: var(--text-1); font-size: 13px; font-weight: 600; transition: background 0.14s, border-color 0.14s, transform 0.06s; }
.btn:hover { background: var(--bg-hover); }
.btn:active { transform: translateY(1px); }
.btn-primary { background: var(--brand-600); border-color: var(--brand-600); color: #fff; }
.btn-primary:hover { background: var(--brand-700); }
.btn-danger { background: var(--danger); border-color: var(--danger); color: #fff; }
.btn-sm { padding: 6px 12px; font-size: 12px; }
.btn-link { background: transparent; border: 0; color: var(--brand-600); font-size: 12px; font-weight: 600; padding: 4px 8px; }
.btn-link:hover { text-decoration: underline; }

.card { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); box-shadow: var(--shadow-sm); }
.card-head { display: flex; align-items: center; gap: 12px; padding: 16px 18px; border-bottom: 1px solid var(--line-soft); }
.card-head h2 { font-size: 14.5px; font-weight: 700; }
.card-head .hint { font-size: 12px; color: var(--text-3); }
.card-head .spacer { margin-left: auto; }
.card-body { padding: 16px 18px; }

/* 表单型卡片（如循环控制）：head 之后给 body 留内边距 */
.editor.card { display: flex; flex-direction: column; min-height: 0; overflow: hidden; }
.editor > .card-head { flex: 0 0 auto; }
.editor > .field,
.editor > .button-row,
.editor > .control-row { padding: 0 18px; }
.editor > .field:first-of-type { padding-top: 16px; }
.editor > .button-row { padding: 4px 18px 18px; flex-wrap: wrap; }
.editor .button-row button {
  display: inline-flex; align-items: center; justify-content: center; gap: 6px;
  padding: 7px 14px; border: 1px solid var(--line); border-radius: var(--r-sm);
  background: var(--bg-elevated); color: var(--text-1); font-size: 12.5px; font-weight: 600;
  transition: background 0.14s, border-color 0.14s;
}
.editor .button-row button:hover { background: var(--bg-hover); }
.editor .button-row button[type="submit"] { background: var(--brand-600); border-color: var(--brand-600); color: #fff; }
.editor .button-row button[type="submit"]:hover { background: var(--brand-700); }

.chip { display: inline-flex; align-items: center; gap: 5px; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 700; letter-spacing: 0.02em; text-transform: uppercase; }
.chip::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
.chip-pending { color: var(--text-3); background: var(--bg-soft); }
.chip-running { color: var(--info); background: var(--info-bg); }
.chip-completed { color: var(--success); background: var(--success-bg); }
.chip-failed { color: var(--danger); background: var(--danger-bg); }
.chip-waiting { color: var(--warning); background: var(--warning-bg); }
.chip-accepted { color: var(--success); background: var(--success-bg); }

.empty { color: var(--text-3); padding: 28px 18px; text-align: center; font-size: 13px; }
.error-banner { padding: 12px 16px; margin-bottom: 16px; border-radius: var(--r-md); background: var(--danger-bg); border: 1px solid #f3c2c4; color: var(--danger); font-size: 13px; }
.req { color: var(--danger); }
.danger-text { color: var(--danger); }

.list { display: grid; gap: 10px; padding: 16px 18px; }
.list.compact { max-height: none; overflow: auto; }
.item { border: 1px solid var(--line-soft); border-radius: var(--r-md); padding: 12px; background: var(--bg-soft); }
.item-title { display: flex; justify-content: space-between; gap: 12px; font-weight: 650; align-items: center; }
.item-title > span:first-child { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.item-title-right { display: inline-flex; align-items: center; justify-content: flex-end; gap: 8px; flex: 0 0 auto; }
.item-actions { display: inline-flex; align-items: center; gap: 4px; }
.item-actions .btn-link { padding: 3px 6px; font-size: 12px; white-space: nowrap; }
.item-actions .danger-link { color: var(--danger); }
.item-actions .btn-link:disabled { color: var(--text-4); cursor: not-allowed; text-decoration: none; }
.item-body { margin-top: 10px; color: var(--text-2); }
.plain-text { line-height: 1.55; white-space: pre-wrap; word-break: break-word; }
.meta { margin-top: 6px; color: var(--text-3); font-size: 12px; word-break: break-all; }
.button-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 12px; }

/* 需求/反馈卡片：进度 + 操作脚 + 追加任务 */
.intake-progress { margin-top: 12px; }
.intake-item .item-foot {
  display: flex; align-items: center; gap: 12px; margin-top: 12px;
  padding-top: 10px; border-top: 1px solid var(--line-soft);
}
.intake-item .item-foot .meta { margin-top: 0; margin-left: auto; }
.intake-item .item-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 4px; }
.intake-item .danger-link { color: var(--danger); }
.intake-item .danger-link:hover { text-decoration: underline; }
.append-row {
  display: flex; gap: 8px; margin-top: 12px;
  padding: 10px; border-radius: var(--r-sm);
  background: var(--bg-soft); border: 1px dashed var(--line);
}
.append-input { flex: 1 1 auto; padding: 7px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); font: inherit; font-size: 12.5px; }
.append-input:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
.inline-editor { display: grid; gap: 10px; margin-top: 12px; }
.inline-editor .field { margin-bottom: 0; }
.inline-editor textarea { min-height: 140px; }
.attachment-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px; }
.attachment-thumb, .attachment-file { display: grid; gap: 6px; width: 120px; padding: 8px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--text-1); }
.attachment-thumb img { width: 100%; aspect-ratio: 1; border-radius: 4px; object-fit: cover; background: var(--brand-50); }
.attachment-thumb span, .attachment-file span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; }
.attachment-file small { color: var(--text-3); font-size: 12px; }

.app-header { display: flex; align-items: center; justify-content: space-between; padding: 18px 32px; background: var(--bg-elevated); border-bottom: 1px solid var(--line); }
.app-header .brand { display: flex; align-items: center; gap: 12px; }
.brand-mark { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 12px; background: var(--brand-grad); color: #fff; font-weight: 800; font-size: 18px; box-shadow: 0 8px 18px rgba(77, 110, 255, 0.35); }
.app-header h1 { font-size: 17px; font-weight: 700; }
.app-header p { font-size: 11px; color: var(--text-3); margin-top: 2px; }
.header-actions { display: flex; align-items: center; gap: 10px; }
.projects-main { height: calc(100vh - 77px); overflow: auto; padding: 28px 32px 48px; }
.projects-hero { display: flex; align-items: flex-end; gap: 20px; flex-wrap: wrap; margin-bottom: 22px; }
.projects-hero h2 { font-size: 24px; font-weight: 800; }
.projects-hero p { font-size: 13px; color: var(--text-3); margin-top: 6px; }
.hero-stats { margin-left: auto; display: flex; gap: 24px; }
.hero-stat { text-align: right; }
.hero-stat b { display: block; font-size: 22px; font-weight: 800; color: var(--text-1); }
.hero-stat span { font-size: 11px; color: var(--text-3); }
.projects-toolbar { margin-bottom: 20px; }
.search-input { width: 100%; max-width: 400px; padding: 10px 14px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-elevated); font: inherit; font-size: 13px; }
.search-input:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
.project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
.project-card { position: relative; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 18px; box-shadow: var(--shadow-sm); cursor: pointer; transition: transform 0.14s, box-shadow 0.14s, border-color 0.14s; }
.project-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: #cdd8ea; }
.project-card-top { display: flex; align-items: flex-start; gap: 12px; }
.project-avatar { width: 44px; height: 44px; flex: 0 0 auto; border-radius: 12px; background: var(--brand-grad); color: #fff; font-weight: 700; font-size: 18px; display: grid; place-items: center; }
.project-info { min-width: 0; flex: 1 1 auto; }
.project-name { font-size: 15px; font-weight: 700; color: var(--text-1); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.project-path { font-size: 11.5px; color: var(--text-3); margin-top: 3px; font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.project-card-menu { flex: 0 0 auto; }
.ctx-details { position: relative; }
.ctx-details > summary { list-style: none; width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center; color: var(--text-3); font-size: 18px; line-height: 1; cursor: pointer; }
.ctx-details > summary::-webkit-details-marker { display: none; }
.ctx-details > summary:hover { background: var(--bg-hover); color: var(--text-1); }
.ctx-menu { position: absolute; right: 0; top: calc(100% + 4px); z-index: 60; min-width: 150px; padding: 5px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-md); box-shadow: var(--shadow-lg); display: flex; flex-direction: column; gap: 2px; }
.ctx-menu button { display: flex; align-items: center; gap: 9px; width: 100%; padding: 8px 10px; border: 0; border-radius: var(--r-sm); background: transparent; color: var(--text-2); text-align: left; font-size: 12.5px; }
.ctx-menu button:hover { background: var(--bg-hover); color: var(--text-1); }
.ctx-menu .ctx-danger { color: var(--danger); }
.ctx-menu .ctx-danger:hover { background: var(--danger-bg); }
.project-desc { font-size: 12.5px; color: var(--text-2); line-height: 1.55; margin-top: 12px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.project-loop-status { display: flex; align-items: center; gap: 8px; margin-top: 12px; color: var(--text-2); font-size: 12px; font-weight: 600; }
.project-loop-status .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
.project-loop-status .led.stopped { box-shadow: 0 0 0 3px var(--line); }
.project-loop-interval { margin-left: auto; color: var(--text-3); font-family: var(--font-mono); font-weight: 500; }
.project-meta { font-size: 11px; color: var(--text-4); margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--line-soft); }

.workspace-shell { display: grid; grid-template-columns: 248px 1fr; height: 100vh; }
.workspace-main { display: flex; flex-direction: column; min-width: 0; height: 100vh; overflow: hidden; }
.sidebar { display: flex; flex-direction: column; gap: 6px; padding: 22px 14px 18px; background: var(--bg-elevated); border-right: 1px solid var(--line); height: 100vh; overflow-y: auto; }
.sidebar .brand { display: flex; align-items: center; gap: 12px; padding: 4px 10px 18px; }
.sidebar .brand-name { font-size: 17px; font-weight: 700; }
.sidebar .brand-sub { font-size: 11px; color: var(--text-3); margin-top: 2px; }
.back-link { display: flex; align-items: center; gap: 8px; margin: 0 4px 10px; padding: 8px 10px; border: 0; border-radius: var(--r-sm); background: transparent; color: var(--text-2); font-size: 12.5px; font-weight: 600; width: calc(100% - 8px); }
.back-link:hover { background: var(--bg-hover); color: var(--text-1); }
.project-switcher { margin: 0 4px 10px; padding: 10px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-soft); }
.project-label { font-size: 10.5px; letter-spacing: 0.1em; text-transform: uppercase; font-weight: 700; color: var(--text-4); margin-bottom: 8px; }
.project-select { width: 100%; padding: 8px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); font: inherit; font-size: 13px; font-weight: 600; color: var(--text-1); }
.project-switcher .project-path { margin-top: 8px; font-size: 11px; }
.nav-group-label { padding: 12px 12px 6px; font-size: 10.5px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-4); font-weight: 700; }
.nav-item { display: flex; align-items: center; gap: 12px; width: 100%; padding: 10px 12px; border: 0; border-radius: var(--r-md); background: transparent; color: var(--text-2); text-align: left; font-size: 13.5px; font-weight: 500; transition: background 0.14s, color 0.14s; }
.nav-item:hover { background: var(--bg-hover); color: var(--text-1); }
.nav-item.active { background: var(--brand-50); color: var(--brand-700); font-weight: 600; }
.nav-ico { width: 20px; height: 20px; flex: 0 0 auto; color: var(--text-3); display: grid; place-items: center; }
.nav-item.active .nav-ico { color: var(--brand-600); }
.sidebar-footer { margin-top: auto; padding: 12px; border-radius: var(--r-md); background: var(--bg-soft); border: 1px solid var(--line-soft); }
.loop-mini { display: flex; align-items: center; gap: 10px; font-size: 12px; color: var(--text-2); }
.loop-mini b { color: var(--text-1); }
.loop-config { font-size: 11px; color: var(--text-3); margin-top: 6px; }

.topbar { display: flex; align-items: center; gap: 16px; padding: 16px 28px; background: var(--bg-elevated); border-bottom: 1px solid var(--line); flex: 0 0 auto; }
.topbar-title h1 { font-size: 18px; font-weight: 700; }
.topbar-title p { font-size: 12px; color: var(--text-3); margin-top: 2px; }
.topbar-actions { margin-left: auto; display: flex; align-items: center; gap: 10px; }
.pill { display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; background: var(--bg-soft); border: 1px solid var(--line); color: var(--text-2); }
.led { width: 9px; height: 9px; border-radius: 50%; background: var(--success); box-shadow: 0 0 0 4px var(--success-bg); }
.pill .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
.led.running { animation: led-pulse 1.6s ease-in-out infinite; }
.led.stopped { background: var(--text-4); box-shadow: 0 0 0 4px var(--line); }
@keyframes led-pulse { 0%,100% { box-shadow: 0 0 0 4px var(--success-bg); } 50% { box-shadow: 0 0 0 7px rgba(24,169,87,0.15); } }
.view { flex: 1 1 auto; min-height: 0; overflow: auto; padding: 24px 28px 32px; display: none; }
.view.active { display: flex; flex-direction: column; }
/* 概览等纯流式内容视图：恢复 block，内部自己滚动 */
.view.active:has(.overview-grid),
.view.active:has(.stat-grid),
.view.active > section.card:only-child { display: block; }

.stat-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 20px; margin-bottom: 24px; }
.stat { position: relative; padding: 18px 20px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
.stat::after { content: ""; position: absolute; right: -18px; top: -18px; width: 84px; height: 84px; border-radius: 50%; opacity: 0.5; }
.stat-brand::after { background: var(--brand-50); }
.stat-info::after { background: var(--info-bg); }
.stat-success::after { background: var(--success-bg); }
.stat-warning::after { background: var(--warning-bg); }
.stat .stat-ico { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center; margin-bottom: 12px; position: relative; z-index: 1; }
.stat-brand .stat-ico { background: var(--brand-50); color: var(--brand-600); }
.stat-info .stat-ico { background: var(--info-bg); color: var(--info); }
.stat-success .stat-ico { background: var(--success-bg); color: var(--success); }
.stat-warning .stat-ico { background: var(--warning-bg); color: var(--warning); }
.stat .stat-value { font-size: 26px; font-weight: 800; line-height: 1; position: relative; z-index: 1; }
.stat .stat-label { font-size: 12px; color: var(--text-3); margin-top: 6px; position: relative; z-index: 1; }
.stat .stat-delta { font-size: 11px; margin-top: 8px; color: var(--success); font-weight: 600; position: relative; z-index: 1; }
.overview-grid { display: grid; grid-template-columns: minmax(0,1.25fr) minmax(380px,1fr); align-items: stretch; gap: 24px; }
.overview-main-column, .overview-side-column { display: flex; flex-direction: column; gap: 20px; min-width: 0; }
.overview-side-column .card-head h2 { white-space: nowrap; }
.loop-card { background: var(--brand-grad); color: #fff; border-radius: var(--r-lg); padding: 22px 24px; position: relative; overflow: hidden; box-shadow: 0 18px 40px rgba(77,110,255,0.28); }
.loop-card .lc-top { display: flex; align-items: center; gap: 12px; }
.loop-card .lc-status { font-size: 13px; opacity: 0.9; }
.loop-card .lc-phase { font-size: 22px; font-weight: 800; margin-top: 4px; }
.loop-card .lc-meta { display: flex; gap: 22px; margin-top: 16px; font-size: 12px; opacity: 0.92; }
.loop-card .lc-meta b { display: block; font-size: 15px; font-weight: 700; margin-top: 2px; }
.loop-card .lc-led { width: 12px; height: 12px; border-radius: 50%; background: #b6f5cf; box-shadow: 0 0 0 4px rgba(182,245,207,0.25); }
.loop-card .lc-led.running { animation: led-pulse 1.6s ease-in-out infinite; }
.loop-card .lc-led.stopped { background: #cfd6e6; box-shadow: 0 0 0 4px rgba(207,214,230,0.25); }

.pipeline { display: flex; align-items: flex-start; gap: 0; overflow-x: auto; }
.pipe-step { flex: 1 1 0; min-width: 0; text-align: center; position: relative; }
.pipe-node { width: 40px; height: 40px; margin: 0 auto; border-radius: 50%; display: grid; place-items: center; background: var(--bg-elevated); border: 2px solid var(--line); color: var(--text-3); font-weight: 700; font-size: 14px; position: relative; z-index: 1; }
.pipe-step.done .pipe-node { background: var(--success); border-color: var(--success); color: #fff; }
.pipe-step.active .pipe-node { background: var(--brand-600); border-color: var(--brand-600); color: #fff; box-shadow: 0 0 0 5px var(--brand-50); }
.pipe-step::before { content: ""; position: absolute; top: 20px; left: -50%; right: 50%; height: 2px; background: var(--line); z-index: 0; }
.pipe-step:first-child::before { display: none; }
.pipe-step.done::before, .pipe-step.active::before { background: var(--success); }
.pipe-label { font-size: 12px; font-weight: 600; margin-top: 10px; color: var(--text-2); }
.pipe-step.active .pipe-label { color: var(--brand-600); }

/* 实时执行日志（对话格式） */
.live-log-card { display: flex; flex-direction: column; min-height: 0; }
.live-log-card .card-head h2 { display: flex; align-items: center; gap: 8px; }
.overview-main-column > .live-log-card { height: 440px; }
.overview-main-column > .live-log-card .codex-log { flex: 1 1 auto; min-height: 0; max-height: none; }
.log-card-head { align-items: stretch; flex-direction: column; gap: 8px; padding: 12px 18px; }
.log-title-line { display: flex; align-items: center; gap: 12px; min-width: 0; }
.log-title-line h2 { flex: 0 0 auto; }
.log-title-line .hint { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.log-phase-chip { flex: 0 0 auto; border: 1px solid var(--line); border-radius: 999px; padding: 4px 9px; background: var(--bg-soft); color: var(--text-2); font-size: 12px; font-weight: 700; white-space: nowrap; }
.log-phase-chip.running { color: var(--success); background: var(--success-bg); border-color: transparent; }
.log-summary { display: flex; align-items: center; gap: 18px; color: var(--text-3); font-size: 12px; }
.log-summary b { color: var(--text-1); margin-left: 4px; }
.live-dot {
  width: 8px; height: 8px; border-radius: 50%; background: var(--success);
  box-shadow: 0 0 0 3px var(--success-bg);
  animation: led-pulse 1.4s ease-in-out infinite;
}
.live-dot.idle { background: var(--text-4); box-shadow: 0 0 0 3px var(--line); animation: none; }
.codex-log {
  margin: 0; padding: 10px;
  background: #1b2438; color: #d6e1f5;
  border-radius: 0 0 var(--r-lg) var(--r-lg);
  max-height: 380px; min-height: 120px; overflow: auto;
  font-family: var(--font-mono); font-size: 12px; line-height: 1.6;
}
.codex-raw { margin: 0; white-space: pre-wrap; word-break: break-word; color: #8a96b0; padding: 8px; }

/* 活动时间线行 */
.act-line {
  display: grid; grid-template-columns: 56px 52px 1fr; gap: 8px;
  align-items: baseline; padding: 4px 8px; border-radius: 4px;
}
.act-line:hover { background: rgba(255,255,255,0.04); }
.act-time { color: #5a6680; font-size: 11px; font-variant-numeric: tabular-nums; }
.act-tag {
  display: inline-block; font-size: 10px; font-weight: 700;
  padding: 1px 7px; border-radius: 999px; text-align: center;
  letter-spacing: 0.02em;
}
.act-text { color: #c8d3ec; word-break: break-word; white-space: pre-wrap; }

.act-codex .act-tag { background: rgba(109,93,252,0.3); color: #c4b8ff; }
.act-codex .act-text { color: #e0e6ff; }
.act-exec .act-tag { background: rgba(24,169,87,0.3); color: #7fe0a8; }
.act-exec .act-text { color: #9fd8b8; }
.act-thinking .act-tag { background: rgba(224,134,0,0.3); color: #ffc878; }
.act-thinking .act-text { color: #d8b878; font-style: italic; }
.act-error .act-tag { background: rgba(229,72,77,0.35); color: #ff9498; }
.act-error .act-text { color: #ff9498; }
.act-system .act-tag { background: rgba(124,135,155,0.3); color: #a0aac0; }
.act-system .act-text { color: #a0aac0; }
.act-user .act-tag { background: rgba(59,110,245,0.3); color: #8ab0ff; }
.act-user .act-text { color: #b8c8f0; }
.act-info .act-tag { background: rgba(124,135,155,0.25); color: #8a96b0; }
.act-info .act-text { color: #b0bbd6; }

.intake-layout { display: grid; grid-template-rows: minmax(0,1fr) auto; gap: 16px; flex: 1 1 0; min-height: 0; max-width: 880px; margin: 0 auto; width: 100%; }
.intake-layout > .composer { margin-bottom: 24px; }
.intake-stream { display: grid; grid-template-rows: auto minmax(0,1fr); min-height: 0; border: 1px solid var(--line); border-radius: var(--r-lg); background: var(--bg-elevated); padding: 18px; }
.section-heading { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
.section-heading h2 { margin-bottom: 0; }
.section-heading span { color: var(--text-3); font-size: 12px; }
.intake-list { min-height: 0; overflow: auto; padding-right: 4px; display: flex; flex-direction: column; gap: 10px; }

.composer { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-xl); padding: 14px 16px 12px; box-shadow: var(--shadow-lg); transition: border-color 0.16s, box-shadow 0.16s; }
.composer:focus-within { border-color: var(--brand-500); box-shadow: 0 18px 48px rgba(37,62,120,0.2); }
.composer.drag-over { border-color: var(--brand-500); background: var(--brand-50); }
.composer textarea { width: 100%; border: 0; outline: none; resize: none; background: transparent; font: inherit; font-size: 14.5px; line-height: 1.5; color: var(--text-1); min-height: 58px; max-height: 180px; overflow: auto; }
.composer textarea::placeholder { color: var(--text-4); }
.composer-bottom { display: flex; align-items: center; gap: 10px; margin-top: 8px; }
.composer-tools { display: flex; align-items: center; gap: 10px; min-width: 0; }
.attachment-trigger { display: grid; place-items: center; width: 40px; height: 40px; flex: 0 0 auto; padding: 0; border: 0; border-radius: 50%; background: transparent; color: var(--text-3); cursor: pointer; }
.attachment-trigger:hover, .attachment-trigger.drag-over { background: var(--bg-hover); }
.attachment-trigger input { display: none; }
.plus-icon { display: block; color: var(--text-3); font-size: 28px; font-weight: 300; line-height: 1; }
.composer-actions { display: flex; align-items: center; justify-content: end; gap: 10px; margin-left: auto; }
.composer-actions span { color: var(--text-3); font-size: 12px; }
.send-button { display: grid; place-items: center; width: 42px; height: 42px; flex: 0 0 auto; border: 0; border-radius: 50%; padding: 0; background: var(--brand-grad); color: #fff; font-size: 20px; line-height: 1; box-shadow: 0 6px 14px rgba(77,110,255,0.4); }
.send-button:hover { filter: brightness(1.05); }
.attachment-list.pending { display: flex; align-items: center; min-width: 0; max-width: min(520px,54vw); gap: 8px; overflow-x: auto; }
.pending-attachment { display: grid; grid-template-columns: 42px 1fr auto auto; align-items: center; gap: 8px; padding: 8px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-soft); }
.pending-thumb, .pending-file-icon { width: 42px; height: 42px; border-radius: var(--r-sm); background: var(--brand-50); }
.pending-thumb { object-fit: cover; }
.pending-file-icon { display: grid; place-items: center; color: var(--text-3); font-size: 12px; }
.pending-attachment span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.pending-attachment small { color: var(--text-3); }
.pending-attachment button { padding: 5px 8px; font-size: 12px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); }

.task-layout { display: grid; grid-template-columns: 320px minmax(0,1fr); gap: 18px; flex: 1 1 0; min-height: 0; }
.task-sidebar { display: grid; grid-template-rows: auto minmax(0,1fr); gap: 16px; min-height: 0; }
.task-sidebar > form.editor { min-height: 0; }
.task-main { display: grid; grid-template-rows: 1fr; gap: 16px; min-height: 0; }
.task-status-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 16px; min-height: 0; }
.primary-section, .side-section, .task-status-grid .card { min-height: 0; overflow: hidden; display: flex; flex-direction: column; }
.side-section .list, .task-status-grid .list, .primary-section .list { overflow: auto; }
.field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; color: var(--text-3); font-size: 11.5px; font-weight: 600; }
.field:last-child { margin-bottom: 0; }
input, textarea, select { width: 100%; border: 1px solid var(--line); border-radius: var(--r-sm); padding: 9px 11px; font: inherit; font-size: 13px; color: var(--text-1); background: var(--bg-elevated); font-weight: 400; }
input:focus, textarea:focus, select:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
textarea { min-height: 80px; resize: vertical; }
.plan-draft textarea { min-height: 240px; font-family: var(--font-mono); font-size: 12.5px; line-height: 1.5; margin-top: 12px; }
.draft-note { color: var(--text-2); font-size: 13px; }

.modal-mask { position: fixed; inset: 0; z-index: 100; background: rgba(23,32,51,0.42); backdrop-filter: blur(2px); display: flex; align-items: center; justify-content: center; padding: 24px; }
.modal { width: 100%; max-width: 480px; background: var(--bg-elevated); border-radius: var(--r-lg); box-shadow: var(--shadow-lg); overflow: hidden; }
.modal-confirm { max-width: 400px; text-align: center; padding: 28px 24px 0; }
.modal-head { display: flex; align-items: center; gap: 12px; padding: 18px 22px; border-bottom: 1px solid var(--line-soft); }
.modal-head h3 { font-size: 16px; font-weight: 700; }
.modal-close { margin-left: auto; width: 30px; height: 30px; border-radius: 8px; border: 0; background: transparent; color: var(--text-3); font-size: 20px; }
.modal-close:hover { background: var(--bg-hover); color: var(--text-1); }
.modal-form { padding: 20px 22px; }
.modal-confirm p { font-size: 13px; color: var(--text-2); line-height: 1.6; margin: 8px 0 4px; }
.modal-danger-icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 50%; background: var(--danger-bg); color: var(--danger); font-size: 24px; margin: 0 auto 14px; }
.modal-foot { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 22px; border-top: 1px solid var(--line-soft); background: var(--bg-soft); }

@media (max-width: 1080px) {
  body { overflow: auto; }
  .workspace-shell { grid-template-columns: 1fr; height: auto; }
  .sidebar { height: auto; }
  .workspace-main { height: auto; min-height: 100vh; }
  .task-layout { grid-template-columns: 1fr; }
  .task-main { grid-template-rows: auto auto; }
  .task-status-grid { grid-template-columns: 1fr; }
  .overview-grid { grid-template-columns: 1fr; }
  .overview-main-column > .live-log-card { height: 360px; }
}

::-webkit-scrollbar { width: 9px; height: 9px; }
::-webkit-scrollbar-thumb { background: #d4dce8; border-radius: 999px; border: 2px solid transparent; background-clip: content-box; }
::-webkit-scrollbar-thumb:hover { background: #b9c5d8; background-clip: content-box; }

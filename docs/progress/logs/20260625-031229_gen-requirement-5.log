   1: import type { AppEvent, Plan, PlanDraft, PlanTask } from '../types';
   2: import { RecordCard } from './IntakePanel';
   3: import { formatChinaDateTime, formatDuration, getRunningDurationMs } from '../utils/time';
   4: 
   5: type TimedPlanTask = PlanTask & {
   6:   plan_id?: number | null;
   7:   started_at?: string | null;
   8:   finished_at?: string | null;
   9:   duration_ms?: number | null;
  10: };
  11: 
  12: function readDurationMs(task: TimedPlanTask) {
  13:   if (task.duration_ms === null || typeof task.duration_ms === 'undefined') return null;
  14:   const duration = Number(task.duration_ms);
  15:   return Number.isFinite(duration) && duration >= 0 ? duration : null;
  16: }
  17: 
  18: function getTaskDurationMs(task: TimedPlanTask) {
  19:   if (task.status === 'running') return getRunningDurationMs(readDurationMs(task), task.started_at);
  20:   return readDurationMs(task);
  21: }
  22: 
  23: function readPlanId(task: TimedPlanTask) {
  24:   if (task.plan_id === null || typeof task.plan_id === 'undefined') return null;
  25:   const planId = Number(task.plan_id);
  26:   return Number.isFinite(planId) ? planId : null;
  27: }
  28: 
  29: function formatTaskDuration(task: TimedPlanTask) {
  30:   const duration = getTaskDurationMs(task);
  31:   if (task.status === 'running') return `已运行 ${formatDuration(duration, '0秒')}`;
  32:   if (duration === null || (duration === 0 && !task.started_at && !task.finished_at)) return '未开始';
  33:   return `耗时 ${formatDuration(duration, '0秒')}`;
  34: }
  35: 
  36: function tasksForPlan(tasks: PlanTask[], plan: Plan, planCount: number) {
  37:   const timedTasks = tasks as TimedPlanTask[];
  38:   const hasPlanIds = timedTasks.some((task) => readPlanId(task) !== null);
  39:   if (!hasPlanIds) return planCount === 1 ? timedTasks : [];
  40:   return timedTasks.filter((task) => readPlanId(task) === plan.id);
  41: }
  42: 
  43: function formatPlanDurationSummary(tasks: TimedPlanTask[]) {
  44:   const totalMs = tasks.reduce((sum, task) => sum + (getTaskDurationMs(task) ?? 0), 0);
  45:   const completedMs = tasks.reduce(
  46:     (sum, task) => sum + (task.status === 'completed' ? getTaskDurationMs(task) ?? 0 : 0),
  47:     0,
  48:   );
  49: 
  50:   return `总耗时 ${formatDuration(totalMs, '0秒')} · 已完成 ${formatDuration(completedMs, '0秒')}`;
  51: }
  52: 
  53: export function PlanDraftList({
  54:   drafts,
  55:   draftTextById,
  56:   onAccept,
  57:   onChange,
  58:   onSave,
  59: }: {
  60:   drafts: PlanDraft[];
  61:   draftTextById: Record<number, string>;
  62:   onAccept: (draft: PlanDraft) => void;
  63:   onChange: (id: number, markdown: string) => void;
  64:   onSave: (draft: PlanDraft) => void;
  65: }) {
  66:   if (!drafts.length) {
  67:     return <div className="empty">暂无计划草稿。发送需求或反馈后会自动生成。</div>;
  68:   }
  69: 
  70:   return (
  71:     <div className="list compact">
  72:       {drafts.map((draft) => {
  73:         const accepted = draft.status === 'accepted';
  74:         return (
  75:           <article className="item plan-draft" key={draft.id}>
  76:             <div className="item-title">
  77:               <span>
  78:                 草稿 #{draft.id} · {draft.source_type === 'feedback' ? '反馈' : '需求'} #{draft.source_id}
  79:               </span>
  80:               <span className={`chip ${accepted ? 'chip-accepted' : 'chip-waiting'}`}>{draft.status}</span>
  81:             </div>
  82:             <textarea
  83:               readOnly={accepted}
  84:               value={draftTextById[draft.id] ?? draft.markdown ?? ''}
  85:               onChange={(event) => onChange(draft.id, event.target.value)}
  86:             />
  87:             <div className="button-row">
  88:               {accepted ? (
  89:                 <span className="draft-note">已加入任务系统：Plan #{draft.linked_plan_id || ''}</span>
  90:               ) : (
  91:                 <>
  92:                   <button type="button" onClick={() => onSave(draft)}>
  93:                     保存调整
  94:                   </button>
  95:                   <button className="btn-primary" type="button" onClick={() => onAccept(draft)}>
  96:                     确认加入任务系统
  97:                   </button>
  98:                 </>
  99:               )}
 100:             </div>
 101:           </article>
 102:         );
 103:       })}
 104:     </div>
 105:   );
 106: }
 107: 
 108: export function PlanList({ plans, tasks = [] }: { plans: Plan[]; tasks?: PlanTask[] }) {
 109:   if (!plans.length) return <div className="empty">暂无 plan。</div>;
 110: 
 111:   return (
 112:     <div className="list compact">
 113:       {plans.map((plan) => {
 114:         const durationSummary = formatPlanDurationSummary(tasksForPlan(tasks, plan, plans.length));
 115:         return (
 116:           <RecordCard
 117:             key={plan.id}
 118:             title={plan.file_path}
 119:             status={plan.status}
 120:             body={`${plan.completed_tasks}/${plan.total_tasks} tasks · ${durationSummary} · validation ${
 121:               plan.validation_passed ? 'passed' : 'pending'
 122:             }`}
 123:             meta={`${plan.hash?.slice(0, 12) || ''} · ${formatChinaDateTime(plan.updated_at)}`}
 124:           />
 125:         );
 126:       })}
 127:     </div>
 128:   );
 129: }
 130: 
 131: export function TaskList({
 132:   tasks,
 133:   onRun,
 134:   onStop,
 135: }: {
 136:   tasks: PlanTask[];
 137:   onRun?: (task: PlanTask) => void;
 138:   onStop?: (task: PlanTask) => void;
 139: }) {
 140:   if (!tasks.length) return <div className="empty">暂无任务。</div>;
 141: 
 142:   return (
 143:     <div className="list compact">
 144:       {tasks.map((task) => {
 145:         const running = task.status === 'running';
 146:         const completed = task.status === 'completed';
 147:         const durationLabel = formatTaskDuration(task as TimedPlanTask);
 148:         return (
 149:           <RecordCard
 150:             actions={
 151:               <div className="item-actions">
 152:                 <button type="button" className="btn-link" disabled={completed || running} onClick={() => onRun?.(task)}>
 153:                   执行
 154:                 </button>
 155:                 <button type="button" className="btn-link danger-link" disabled={!running} onClick={() => onStop?.(task)}>
 156:                   停止
 157:                 </button>
 158:               </div>
 159:             }
 160:             key={task.id}
 161:             title={task.title}
 162:             status={task.status}
 163:             body={task.file_path}
 164:             meta={`${task.task_key} · ${durationLabel} · ${formatChinaDateTime(task.updated_at)}`}
 165:           />
 166:         );
 167:       })}
 168:     </div>
 169:   );
 170: }
 171: 
 172: export function EventList({ events }: { events: AppEvent[] }) {
 173:   if (!events.length) return <div className="empty">暂无事件。</div>;
 174: 
 175:   return (
 176:     <div className="list compact">
 177:       {events.map((event) => (
 178:         <RecordCard key={event.id} title={event.type} body={event.message} meta={formatChinaDateTime(event.created_at)} />
 179:       ))}
 180:     </div>
 181:   );
 182: }

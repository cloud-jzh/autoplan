+    activeProjectId: null,
+    activeProject: null,
+    projects,
+    state: null,
+    requirements: [],
+    feedback: [],
+    attachments: [],
+    planDrafts: [],
+    plans: [],
+    tasks: [],
+    events: [],
+    scans: [],
+    activeOperation: null,
+    activeOperations: [],
+    lastOperation: null,
+  };

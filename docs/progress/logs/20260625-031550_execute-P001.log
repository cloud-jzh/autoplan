-  async validatePlan(workspace, plan) {
-    this.setPhase(plan.project_id, 'validate');
-    const planFile = path.join(workspace, plan.file_path);
-    const command = String(this.status(plan.project_id)?.validation_command || '').trim();
-    if (!command) {
-      // 验收命令为空：跳过校验，直接标记完成。

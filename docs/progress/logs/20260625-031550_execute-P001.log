+            planId: runtime.activeOperation.planId || null,
+            taskId: runtime.activeOperation.taskId || null,
+            startedAt: runtime.activeOperation.startedAt || null,
+            logTail: (runtime.activeOperation.logBuffer || '').slice(-8000),

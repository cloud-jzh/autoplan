-         (project_id, scan_type, file_path, hash, size, modified_at, scanned_at)
-         VALUES (?, ?, ?, ?, ?, ?, ?)`,
-        [projectId, type, file.path, file.hash, file.size, file.modifiedAt, scannedAt],
-      );
-    }
-  }

+
+function killChildProcess(child) {
+  if (!child || child.killed) return;
+  if (process.platform === 'win32' && child.pid) {
+    const killer = spawn('taskkill', ['/pid', String(child.pid), '/T', '/F'], { windowsHide: true });
+    killer.on('error', () => child.kill());
+    return;
+  }
+  child.kill('SIGTERM');

-      taskId: task.id,
-      parallel: Boolean(options.parallel),
-    }, planFile);
-    if (result.exitCode !== 0) {
-      this.db.run('UPDATE plan_tasks SET status = ?, updated_at = ? WHERE id = ?', ['pending', nowIso(), task.id]);
-      this.emitUpdate(plan.project_id);

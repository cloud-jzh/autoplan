  66:   if (!drafts.length) {
  67:     return <div className="empty">暂无计划草稿。发送需求或反馈后会自动生成。</div>;
  68:   }
  69: 
  70:   return (
  71:     <div className="list compact">
  72:       {drafts.map((draft) => {
  73:         const accepted = draft.status === 'accepted';
  74:         return (
  75:           <article className="item plan-draft" key={draft.id}>
  76:             <div className="item-title">
  77:               <span>
  78:                 草稿 #{draft.id} · {draft.source_type === 'feedback' ? '反馈' : '需求'} #{draft.source_id}
  79:               </span>
  80:               <span className={`chip ${accepted ? 'chip-accepted' : 'chip-waiting'}`}>{draft.status}</span>
  81:             </div>
  82:             <textarea
  83:               readOnly={accepted}
  84:               value={draftTextById[draft.id] ?? draft.markdown ?? ''}
  85:               onChange={(event) => onChange(draft.id, event.target.value)}
  86:             />
  87:             <div className="button-row">
  88:               {accepted ? (
  89:                 <span className="draft-note">已加入任务系统：Plan #{draft.linked_plan_id || ''}</span>
  90:               ) : (
  91:                 <>
  92:                   <button type="button" onClick={() => onSave(draft)}>
  93:                     保存调整
  94:                   </button>
  95:                   <button className="btn-primary" type="button" onClick={() => onAccept(draft)}>
  96:                     确认加入任务系统
  97:                   </button>
  98:                 </>
  99:               )}
 100:             </div>
 101:           </article>
 102:         );
 103:       })}
 104:     </div>
 105:   );
 106: }
 107: 
 108: export function PlanList({ plans, tasks = [] }: { plans: Plan[]; tasks?: PlanTask[] }) {
 109:   if (!plans.length) return <div className="empty">暂无 plan。</div>;
 110: 
 111:   return (
 112:     <div className="list compact">
 113:       {plans.map((plan) => {
 114:         const durationSummary = formatPlanDurationSummary(tasksForPlan(tasks, plan, plans.length));
 115:         return (
 116:           <RecordCard
 117:             key={plan.id}
 118:             title={plan.file_path}
 119:             status={plan.status}
 120:             body={`${plan.completed_tasks}/${plan.total_tasks} tasks · ${durationSummary} · validation ${
 121:               plan.validation_passed ? 'passed' : 'pending'
 122:             }`}
 123:             meta={`${plan.hash?.slice(0, 12) || ''} · ${formatChinaDateTime(plan.updated_at)}`}
 124:           />
 125:         );
 126:       })}
 127:     </div>
 128:   );
 129: }
 130: 
 131: export function TaskList({
 132:   tasks,
 133:   onRun,
 134:   onStop,
 135: }: {
 136:   tasks: PlanTask[];
 137:   onRun?: (task: PlanTask) => void;
 138:   onStop?: (task: PlanTask) => void;
 139: }) {
 140:   if (!tasks.length) return <div className="empty">暂无任务。</div>;
 141: 
 142:   return (
 143:     <div className="list compact">
 144:       {tasks.map((task) => {
 145:         const running = task.status === 'running';
 146:         const completed = task.status === 'completed';
 147:         const durationLabel = formatTaskDuration(task as TimedPlanTask);
 148:         return (
 149:           <RecordCard
 150:             actions={
 151:               <div className="item-actions">
 152:                 <button type="button" className="btn-link" disabled={completed || running} onClick={() => onRun?.(task)}>
 153:                   执行
 154:                 </button>
 155:                 <button type="button" className="btn-link danger-link" disabled={!running} onClick={() => onStop?.(task)}>
 156:                   停止
 157:                 </button>
 158:               </div>
 159:             }
 160:             key={task.id}
 161:             title={task.title}
 162:             status={task.status}
 163:             body={task.file_path}
 164:             meta={`${task.task_key} · ${durationLabel} · ${formatChinaDateTime(task.updated_at)}`}
 165:           />
 166:         );
 167:       })}
 168:     </div>
 169:   );
 170: }
 171: 
 172: export function EventList({ events }: { events: AppEvent[] }) {
 173:   if (!events.length) return <div className="empty">暂无事件。</div>;
 174: 
 175:   return (
 176:     <div className="list compact">
 177:       {events.map((event) => (
 178:         <RecordCard key={event.id} title={event.type} body={event.message} meta={formatChinaDateTime(event.created_at)} />
 179:       ))}
 180:     </div>
 181:   );
 182: }
--- src/renderer/utils/time.ts lines 1-90 ---
   1: const CHINA_TIME_ZONE = 'Asia/Shanghai';
   2: 
   3: function parseTimestamp(value?: string | null) {
   4:   if (!value) return null;
   5:   const raw = String(value).trim();
   6:   if (!raw) return null;
   7: 
   8:   if (/^\d{2}:\d{2}:\d{2}$/.test(raw)) {
   9:     return new Date(`${new Date().toISOString().slice(0, 10)}T${raw}Z`);
  10:   }
  11: 
  12:   let normalized = raw.includes(' ') ? raw.replace(' ', 'T') : raw;
  13:   if (!/[zZ]$|[+-]\d{2}:?\d{2}$/.test(normalized)) normalized += 'Z';
  14: 
  15:   const date = new Date(normalized);
  16:   return Number.isNaN(date.getTime()) ? null : date;
  17: }
  18: 
  19: function normalizeDurationMs(value?: number | null) {
  20:   if (value === null || typeof value === 'undefined') return null;
  21:   const duration = Number(value);
  22:   if (!Number.isFinite(duration) || duration < 0) return null;
  23:   return duration;
  24: }
  25: 
  26: function chinaParts(date: Date) {
  27:   const parts = new Intl.DateTimeFormat('zh-CN', {
  28:     timeZone: CHINA_TIME_ZONE,
  29:     year: 'numeric',
  30:     month: '2-digit',
  31:     day: '2-digit',
  32:     hour: '2-digit',
  33:     minute: '2-digit',
  34:     second: '2-digit',
  35:     hour12: false,
  36:   }).formatToParts(date);
  37: 
  38:   return Object.fromEntries(parts.map((part) => [part.type, part.value]));
  39: }
  40: 
  41: export function formatChinaTime(value?: string | null) {
  42:   const date = parseTimestamp(value);
  43:   if (!date) return value || '';
  44:   const parts = chinaParts(date);
  45:   return `${parts.hour}:${parts.minute}:${parts.second}`;
  46: }
  47: 
  48: export function formatChinaDateTime(value?: string | null) {
  49:   const date = parseTimestamp(value);
  50:   if (!date) return value || '';
  51:   const parts = chinaParts(date);
  52:   return `${parts.year}-${parts.month}-${parts.day} ${parts.hour}:${parts.minute}:${parts.second}`;
  53: }
  54: 
  55: export function formatDuration(milliseconds?: number | null, fallback = '未开始') {
  56:   const duration = normalizeDurationMs(milliseconds);
  57:   if (duration === null) return fallback;
  58: 
  59:   const totalSeconds = duration > 0 ? Math.max(1, Math.round(duration / 1000)) : 0;
  60:   const hours = Math.floor(totalSeconds / 3600);
  61:   const minutes = Math.floor((totalSeconds % 3600) / 60);
  62:   const seconds = totalSeconds % 60;
  63: 
  64:   if (hours > 0) {
  65:     return minutes > 0 ? `${hours}小时${minutes}分` : `${hours}小时`;
  66:   }
  67: 
  68:   if (minutes > 0) {
  69:     return seconds > 0 ? `${minutes}分${seconds}秒` : `${minutes}分`;
  70:   }
  71: 
  72:   return `${seconds}秒`;
  73: }
  74: 
  75: export function getRunningDurationMs(durationMs?: number | null, startedAt?: string | null, now = Date.now()) {
  76:   const baseDuration = normalizeDurationMs(durationMs) ?? 0;
  77:   const startedDate = parseTimestamp(startedAt);
  78:   if (!startedDate) return normalizeDurationMs(durationMs);
  79: 
  80:   return baseDuration + Math.max(0, now - startedDate.getTime());
  81: }

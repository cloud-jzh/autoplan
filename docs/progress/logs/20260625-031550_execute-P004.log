+    ? formatTaskEvent(event, meta)
+    : null;
+  if (taskDisplay) return taskDisplay;
+
+  return {
+    title: event.type || '事件',
+    body: event.message || '',
+    meta: formatChinaDateTime(event.created_at),
+  };
+}

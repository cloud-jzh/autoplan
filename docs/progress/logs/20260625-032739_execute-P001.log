+  const shouldHide = ariaHidden === undefined ? !hasAccessibleName : isAriaHidden(ariaHidden);
+  const labelledBy = title && !shouldHide ? titleId : undefined;
+  const iconStyle = {
+    '--icon-size': formatIconSize(size),
+    ...style,
+  } as React.CSSProperties;

powershell.exe -Command '$ErrorActionPreference='"'Stop'; [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;
function Show-Ranges("'$path, $ranges) {
  $lines = Get-Content -LiteralPath $path -Encoding UTF8
  Write-Host "--- $path ---"
  foreach ($range in $ranges) {
    $start=$range[0]; $end=$range[1]
    Write-Host "@@ $start-$end"
    for ($i=$start; $i -le $end; $i++) { if ($i -le $lines.Length) { '"'{0,4}: {1}' -f "'$i,$lines[$i-1] } }
  }
}

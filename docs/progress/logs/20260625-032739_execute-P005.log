静态校验误把 JS 模板占位当成真实引用；我会排除模板占位后重跑。
exec
powershell.exe -Command '$ErrorActionPreference='"'Stop';
"'$env:PYTHONIOENCODING='"'utf-8'; [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;
@'
from pathlib import Path
import re
html_files = [Path('ui/projects.html'), Path('ui/workspace.html')]
for path in html_files:
    text = path.read_text(encoding='utf-8')
    symbols = set(re.findall(r'<symbol\\s+id=\"(["'^"]+)"'"', text))
    uses = [u for u in re.findall(r'<use\\s+href=\"#(["'^"]+)"'"', text) if '"'$'"' not in u]
    missing = sorted(set(uses) - symbols)

逐项扫描被 PowerShell 转义成问号了；我会用 Unicode 码点重跑，避免误判三元表达式。
exec
powershell.exe -Command '$ErrorActionPreference='"'Stop';
"'$env:PYTHONIOENCODING='"'utf-8'; [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;
@'
from pathlib import Path
import re
html_files = [Path('ui/projects.html'), Path('ui/workspace.html')]
for path in html_files:
    text = path.read_text(encoding='utf-8')
    symbols = set(re.findall(r'<symbol\\s+id=\"(["'^"]+)"'"', text))
    uses = [u for u in re.findall(r'<use\\s+href=\"#(["'^"]+)"'"', text) if '"'$'"' not in u]
    missing = sorted(set(uses) - symbols)
    if missing:
        raise SystemExit(f'{path}: missing symbols {missing}')
    print(f'{path}: {len(uses)} static SVG uses, {len(symbols)} local symbols, all static references resolved')

legacy_codes = {
    'ui/projects.html': [0x2315,0x2197,0x26A0,0x270E,0x1F5D1,0xFF0B,0x00D7,0x25CF,0x25A0,0x25B6,0x25D1,0x25CE,0x25A4,0x2611,0x2261,0x22EF,0x29C9,0x25A6,0x1F4CE,0x1F41B,0x2713,0x21BB],
    'ui/workspace.html': [0xFF0B,0x00D7,0x25CF,0x25A0,0x25B6,0x25D1,0x25CE,0x25A4,0x2611,0x2261,0x22EF,0x29C9,0x25A6,0x2304,0x25BE,0x25BC,0x25B2,0x270E,0x1F4CE,0x1F41B,0x2713,0x21BB],
}
for file_name, codes in legacy_codes.items():
    tokens = [chr(code) for code in codes]
    text = Path(file_name).read_text(encoding='utf-8')
    hits = []
    for i, line in enumerate(text.splitlines(), 1):
        found = [f'U+{ord(token):04X}' for token in tokens if token in line]
        if found:
            hits.append((i, found, line.strip()))
    if hits:
        raise SystemExit(f'{file_name}: legacy icon chars remain: {hits[:5]}')
    print(f'{file_name}: no legacy icon characters remain')

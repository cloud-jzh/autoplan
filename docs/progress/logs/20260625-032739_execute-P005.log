 197:       .loop-mini { display: flex; align-items: center; gap: 10px; font-size: 12px; color: var(--text-2); }
 198:       .loop-mini b { color: var(--text-1); }
 199:       .led { width: 9px; height: 9px; border-radius: 50%; background: var(--success); box-shadow: 0 0 0 4px var(--success-bg); }
 200:       .led.running { animation: led-pulse 1.6s ease-in-out infinite; }
 201:       @keyframes led-pulse { 0%,100% { box-shadow: 0 0 0 4px var(--success-bg); } 50% { box-shadow: 0 0 0 7px rgba(24,169,87,.15); } }
 202: 
 203:       /* 主区 */
 204:       .main { display: flex; flex-direction: column; min-width: 0; height: 100vh; overflow: hidden; }
 205:       .topbar {
 206:         display: flex; align-items: center; gap: 16px; padding: 16px 28px;
 207:         background: var(--bg-elevated); border-bottom: 1px solid var(--line); flex: 0 0 auto;
 208:       }
 209:       .topbar-title h1 { font-size: 18px; font-weight: 700; }
 210:       .topbar-title p { font-size: 12px; color: var(--text-3); margin-top: 2px; }
 211:       .topbar-actions { margin-left: auto; display: flex; align-items: center; gap: 10px; }
 212:       .pill {
 213:         display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px;
 214:         border-radius: 999px; font-size: 12px; font-weight: 600;
 215:         background: var(--bg-soft); border: 1px solid var(--line); color: var(--text-2);
 216:       }
 217:       .pill .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
 218: 
 219:       .view { flex: 1 1 auto; min-height: 0; overflow: auto; padding: 24px 28px 32px; display: none; }
 220:       .view.active { display: block; }
 221: 
 222:       /* 通用组件 */
 223:       .btn {
 224:         display: inline-flex; align-items: center; justify-content: center; gap: 8px;
 225:         padding: 9px 16px; border: 1px solid var(--line); border-radius: var(--r-md);
 226:         background: var(--bg-elevated); color: var(--text-1); font-size: 13px; font-weight: 600;
 227:         transition: background .14s, border-color .14s, transform .06s;
 228:       }
 229:       .btn:hover { background: var(--bg-hover); }
 230:       .btn:active { transform: translateY(1px); }
 231:       .btn-primary { background: var(--brand-600); border-color: var(--brand-600); color: #fff; }
 232:       .btn-primary:hover { background: var(--brand-700); }
 233:       .btn-sm { padding: 6px 12px; font-size: 12px; }
 234: 
 235:       .card { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); box-shadow: var(--shadow-sm); }
 236:       .card-head { display: flex; align-items: center; gap: 12px; padding: 16px 18px; border-bottom: 1px solid var(--line-soft); }
 237:       .card-head h2 { font-size: 14.5px; font-weight: 700; }
 238:       .card-head .hint { font-size: 12px; color: var(--text-3); }
 239:       .card-head .spacer { margin-left: auto; }
 240:       .card-body { padding: 16px 18px; }
 241: 
 242:       .chip {
 243:         display: inline-flex; align-items: center; gap: 5px; padding: 3px 9px;
 244:         border-radius: 999px; font-size: 11px; font-weight: 700; letter-spacing: .02em; text-transform: uppercase;
 245:       }
 246:       .chip::before { content: ""; width: 6px; height: 6px; border-radius: 50%; background: currentColor; }
 247:       .chip-pending { color: var(--text-3); background: var(--bg-soft); }
 248:       .chip-running { color: var(--info); background: var(--info-bg); }
 249:       .chip-completed { color: var(--success); background: var(--success-bg); }
 250:       .chip-failed { color: var(--danger); background: var(--danger-bg); }
 251:       .chip-waiting { color: var(--warning); background: var(--warning-bg); }
 252:       .chip-accepted { color: var(--success); background: var(--success-bg); }
 253: 
 254:       /* 概览 */
 255:       .stat-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 16px; margin-bottom: 20px; }
 256:       .stat {
 257:         position: relative; padding: 18px 20px; background: var(--bg-elevated);
 258:         border: 1px solid var(--line); border-radius: var(--r-lg); box-shadow: var(--shadow-sm); overflow: hidden;
 259:       }
 260:       .stat::after { content:""; position:absolute; right:-18px; top:-18px; width:84px; height:84px; border-radius:50%; background:var(--stat-accent,var(--brand-50)); opacity:.6; }

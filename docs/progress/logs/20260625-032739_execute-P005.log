符号引用已通过；遗留字符扫描的正则对特殊符号不稳，我会改用逐项字符检查。
exec
powershell.exe -Command '$ErrorActionPreference='"'Stop';
"'$env:PYTHONIOENCODING='"'utf-8'; [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;
@'
from pathlib import Path
import re
html_files = [Path('ui/projects.html'), Path('ui/workspace.html')]
for path in html_files:
    text = path.read_text(encoding='utf-8')
    symbols = set(re.findall(r'<symbol\\s+id=\"(["'^"]+)"'"', text))
    uses = [u for u in re.findall(r'<use\\s+href=\"#(["'^"]+)"'"', text) if '"'$'"' not in u]
    missing = sorted(set(uses) - symbols)
    if missing:
        raise SystemExit(f'{path}: missing symbols {missing}')
    print(f'{path}: {len(uses)} static SVG uses, {len(symbols)} local symbols, all static references resolved')

legacy_tokens = {
    'ui/projects.html': list('⌕↗⚠✎＋×●■▶◑◎▤☑≡⋯⧉▦') + ['🗑', '📎', '🐛', '✓', '↻'],
    'ui/workspace.html': list('＋×●■▶◑◎▤☑≡⋯⧉▦⌄▾▼▲✎') + ['📎', '🐛', '✓', '↻'],
}
for file_name, tokens in legacy_tokens.items():
    text = Path(file_name).read_text(encoding='utf-8')
    hits = []
    for i, line in enumerate(text.splitlines(), 1):
        found = [token for token in tokens if token in line]
        if found:
            hits.append((i, ''.join(found), line.strip()))
    if hits:
        raise SystemExit(f'{file_name}: legacy icon chars remain: {hits[:5]}')

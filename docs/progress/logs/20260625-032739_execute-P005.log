先做文件级校验，再用浏览器快速打开静态页确认图标可见。
exec
powershell.exe -Command '$ErrorActionPreference='"'Stop';
"'$env:PYTHONIOENCODING='"'utf-8'; [Console]::OutputEncoding=[System.Text.Encoding]::UTF8;
@'
from pathlib import Path
import re
html_files = [Path('ui/projects.html'), Path('ui/workspace.html')]
for path in html_files:
    text = path.read_text(encoding='utf-8')
    symbols = set(re.findall(r'<symbol\\s+id=\"(["'^"]+)"'"', text))
    uses = re.findall(r'<use\\s+href=\"#(["'^"]+)"'"', text)
    missing = sorted(set(uses) - symbols)
    if missing:
        raise SystemExit(f'{path}: missing symbols {missing}')
    print(f'{path}: {len(uses)} SVG uses, {len(symbols)} local symbols, all references resolved')

legacy_patterns = {
    'ui/projects.html': r'[⌕↗⚠✎🗑＋×●■▶◑◎▤☑≡⋯⧉▦]|📎|🐛|✓|↻',
    'ui/workspace.html': r'[＋×●■▶◑◎▤☑≡⋯⧉▦⌄▾▼▲]|📎|🐛|✓|↻|✎',
}
for file_name, pattern in legacy_patterns.items():
    text = Path(file_name).read_text(encoding='utf-8')
    hits = [(i, line.strip()) for i, line in enumerate(text.splitlines(), 1) if re.search(pattern, line)]
    if hits:
        raise SystemExit(f'{file_name}: legacy icon chars remain: {hits[:5]}')
    print(f'{file_name}: no legacy icon characters remain')

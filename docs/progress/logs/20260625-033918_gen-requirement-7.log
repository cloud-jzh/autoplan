1036:   async runCodex(workspace, prompt, label, operation = {}) {
1037:     const projectIdForEmit = operation.projectId;
1038:     const runtime = this.runtime(projectIdForEmit);
1039:     if (!runtime) throw new Error('projectId is required for codex operations');

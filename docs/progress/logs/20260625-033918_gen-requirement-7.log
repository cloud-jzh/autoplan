1272: function taskEventMeta(task, overrides = {}) {
1273:   const meta = {
1274:     ...compactEventMeta({
1275:       taskId: task?.id,
1276:       taskKey: task?.task_key,
1277:       taskTitle: task?.title,
1278:       planId: task?.plan_id,
1279:       status: task?.status,
1280:       startedAt: task?.started_at,
1281:       finishedAt: task?.finished_at,
1282:     }),
1283:     ...compactEventMeta(overrides),
1284:   };
1285:   meta.taskId = normalizeOptionalNumber(meta.taskId);
1286:   meta.planId = normalizeOptionalNumber(meta.planId);
1287:   meta.taskKey = normalizeOptionalString(meta.taskKey);
1288:   meta.taskTitle = normalizeOptionalString(meta.taskTitle);
1289:   meta.status = normalizeOptionalString(meta.status);
1290:   meta.startedAt = normalizeOptionalString(meta.startedAt);
1291:   meta.finishedAt = normalizeOptionalString(meta.finishedAt);
1292:   const compacted = compactEventMeta(meta);
1293:   return Object.keys(compacted).length ? compacted : null;
1294: }

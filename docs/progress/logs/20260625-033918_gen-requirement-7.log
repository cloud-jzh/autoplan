1045:     const args = [
1046:       'exec',
1047:       '--cd',
1048:       workspace,
1049:       '--color',
1050:       'never',
1051:       '-o',
1052:       lastFile,
1053:       '--sandbox',
1054:       'danger-full-access',
1055:       '-',
1056:     ];
1057:     const child = spawn('codex', args, { shell: process.platform === 'win32', cwd: workspace });
1058:     const activeOperation = {
1059:       ...operation,
1060:       label,
1061:       logBuffer: '',
1062:       activity: new CodexActivityPrinter(200),
1063:       startedAt: nowIso(),
1064:     };
1065:     const operationKey = registerRuntimeOperation(runtime, child, activeOperation);
1066:     child.stdin.setDefaultEncoding('utf8');
1067:     child.stdin.end(prompt);
1068:     const stream = fs.createWriteStream(logFile, { encoding: 'utf8' });

   1: import { useEffect, useState } from 'react';
   2: import type { AppSnapshot } from '../types';
   3: 
   4: /**
   5:  * Subscribe to main-process snapshots.
   6:  * Project pages ignore updates for other projects while keeping the project list fresh.
   7:  */
   8: export function useSnapshot(projectId: number | null) {
   9:   const [snapshot, setSnapshot] = useState<AppSnapshot | null>(null);
  10:   const [error, setError] = useState<string | null>(null);
  11: 
  12:   useEffect(() => {
  13:     let disposed = false;
  14:     const showError = (e: unknown) => {
  15:       const msg = e instanceof Error ? e.message : String(e);
  16:       if (!disposed) setError(msg);
  17:     };
  18: 
  19:     const unsubscribe = window.autoplan.onLoopUpdate((next) => {
  20:       if (disposed) return;
  21:       if (projectId === null || Number(next.activeProjectId) === Number(projectId)) {
  22:         setSnapshot(next);
  23:         return;
  24:       }
  25:       setSnapshot((current) => (current ? { ...current, projects: next.projects } : current));
  26:     });
  27: 
  28:     window.autoplan
  29:       .snapshot(projectId)
  30:       .then((next) => {
  31:         if (!disposed) setSnapshot(next);
  32:       })
  33:       .catch(showError);
  34: 
  35:     return () => {
  36:       disposed = true;
  37:       unsubscribe();
  38:     };
  39:   }, [projectId]);
  40: 
  41:   return { snapshot, setSnapshot, error, setError };
  42: }

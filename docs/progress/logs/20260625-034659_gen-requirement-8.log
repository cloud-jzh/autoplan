 744:   parallelTaskBatch(tasks) {
 745:     const selected = [];
 746:     const usedScopes = new Set();
 747:     for (const task of tasks) {
 748:       if (selected.length >= MAX_PARALLEL_TASKS) break;
 749:       const scopes = taskParallelScopes(task);
 750:       if (!scopes.length) {
 751:         if (!selected.length) return [task];
 752:         continue;
 753:       }
 754:       if (scopes.some((scope) => usedScopes.has(scope))) continue;
 755:       selected.push(task);
 756:       for (const scope of scopes) usedScopes.add(scope);
 757:     }
 758:     return selected.length > 1 ? selected : [tasks[0]];
 759:   }

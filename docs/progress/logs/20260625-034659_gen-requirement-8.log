 785:               error: error?.message || String(error),
 786:             }),
 787:           );
 788:           return { task, result: { exitCode: -1 } };
 789:         }
 790:       }),
 791:     );
 792:     for (const { task, result } of results) {
 793:       if (result.exitCode === 0) {
 794:         this.completeTask(workspace, plan, task, result);
 795:       }
 796:     }
 797:   }

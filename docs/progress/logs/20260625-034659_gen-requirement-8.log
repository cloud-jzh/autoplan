 236: export function PlanList({ plans, tasks = [] }: { plans: Plan[]; tasks?: PlanTask[] }) {
 237:   if (!plans.length) return <div className="empty">暂无 plan。</div>;
 238: 
 239:   return (
 240:     <div className="list compact">
 241:       {plans.map((plan) => {
 242:         const durationSummary = formatPlanDurationSummary(tasksForPlan(tasks, plan, plans.length));
 243:         return (
 244:           <RecordCard
 245:             key={plan.id}
 246:             title={plan.file_path}
 247:             status={plan.status}
 248:             body={`${plan.completed_tasks}/${plan.total_tasks} tasks · ${durationSummary} · validation ${
 249:               plan.validation_passed ? 'passed' : 'pending'
 250:             }`}
 251:             meta={`${plan.hash?.slice(0, 12) || ''} · ${formatChinaDateTime(plan.updated_at)}`}
 252:           />
 253:         );
 254:       })}
 255:     </div>
 256:   );
 257: }
 258: 
 259: export function TaskList({
 260:   tasks,
 261:   onRun,
 262:   onStop,
 263: }: {
 264:   tasks: PlanTask[];
 265:   onRun?: (task: PlanTask) => void;
 266:   onStop?: (task: PlanTask) => void;
 267: }) {
 268:   if (!tasks.length) return <div className="empty">暂无任务。</div>;
 269: 
 270:   return (
 271:     <div className="list compact">
 272:       {tasks.map((task) => {
 273:         const running = task.status === 'running';
 274:         const completed = task.status === 'completed';
 275:         const durationLabel = formatTaskDuration(task as TimedPlanTask);
 276:         return (
 277:           <RecordCard
 278:             actions={
 279:               <div className="item-actions">
 280:                 <button type="button" className="btn-link" disabled={completed || running} onClick={() => onRun?.(task)}>
 281:                   执行
 282:                 </button>
 283:                 <button type="button" className="btn-link danger-link" disabled={!running} onClick={() => onStop?.(task)}>
 284:                   停止
 285:                 </button>
 286:               </div>
 287:             }
 288:             key={task.id}
 289:             title={task.title}
 290:             status={task.status}
 291:             body={task.file_path}
 292:             meta={`${task.task_key} · ${durationLabel} · ${formatChinaDateTime(task.updated_at)}`}
 293:           />
 294:         );
 295:       })}
 296:     </div>
 297:   );
 298: }
 299: 
 300: export function EventList({ events }: { events: AppEvent[] }) {
 301:   if (!events.length) return <div className="empty">暂无事件。</div>;
 302: 
 303:   return (
 304:     <div className="list compact event-list">
 305:       {events.map((event) => {
 306:         const display = formatEvent(event);
 307:         return (
 308:           <article className={`item event-item ${display.tone ? `event-item-${display.tone}` : ''}`} key={event.id}>
 309:             <div className="item-title event-title">
 310:               <span>{display.title}</span>
 311:               {display.badge ? <span className={`event-badge event-badge-${display.tone}`}>{display.badge}</span> : null}
 312:             </div>
 313:             {display.body ? <div className="item-body plain-text">{display.body}</div> : null}
 314:             <div className="meta event-meta">{display.meta}</div>
 315:           </article>
 316:         );
 317:       })}
 318:     </div>
 319:   );
 320: }


 214:     if (!key) return null;
 215:     for (const [id, runtime] of this.runtimes.entries()) {
 216:       if (Number(id) === Number(projectId)) continue;
 217:       if (!runtime.running && !runtime.busy && !runtime.activeChild) continue;
 218:       const project = this.project(id);
 219:       if (workspaceKey(project?.workspace_path) === key) return project;
 220:     }

  64: 
  65:   runtime(projectId) {
  66:     const id = Number(projectId || 0);
  67:     if (!id) return null;
  68:     let runtime = this.runtimes.get(id);
  69:     if (!runtime) {
  70:       runtime = createProjectRuntime();
  71:       this.runtimes.set(id, runtime);
  72:     }
  73:     return runtime;
  74:   }
  75: 
  76:   existingRuntime(projectId) {
  77:     return this.runtimes.get(Number(projectId || 0)) || null;
  78:   }
  79: 
  80:   projects() {
  81:     return this.db
  82:       .all('SELECT * FROM projects ORDER BY updated_at DESC, id DESC')
  83:       .map((project) => this.withProjectRuntimeSummary(project));
  84:   }
  85: 
  86:   withProjectRuntimeSummary(project) {
  87:     const state =
  88:       this.db.get(
  89:         'SELECT phase, interval_seconds, validation_command FROM project_states WHERE project_id = ?',
  90:         [project.id],
  91:       ) || {};
  92:     const runtime = this.existingRuntime(project.id);
  93:     const running = runtime?.running ? 1 : 0;
  94:     let phase = state.phase || 'idle';
  95:     if (!running && !runtime?.busy && ACTIVE_RUNTIME_PHASES.has(String(phase || ''))) {
  96:       phase = 'stopped';
  97:     }
  98:     return {
  99:       ...project,
 100:       running,
 101:       phase,
 102:       interval_seconds: Number(state.interval_seconds || 5),
 103:       validation_command: state.validation_command || '',
 104:     };
 105:   }
 106: 
 107:   project(projectId) {
 108:     if (!projectId) return null;
 109:     return this.db.get('SELECT * FROM projects WHERE id = ?', [projectId]);
 110:   }
 111: 
 112:   defaultProjectId() {
 113:     return this.projects()[0]?.id || null;
 114:   }
 115: 
 116:   ensureProjectState(projectId) {
 117:     if (!projectId) return;
 118:     this.db.run(
 119:       `INSERT OR IGNORE INTO project_states
 120:        (project_id, running, phase, interval_seconds, validation_command, updated_at)
 121:        VALUES (?, 0, 'idle', 5, 'flutter analyze', ?)`,
 122:       [projectId, nowIso()],
 123:     );
 124:   }
 125: 
 126:   resetRuntimeState() {
 127:     const now = nowIso();
 128:     this.db.run(
 129:       `UPDATE project_states
 130:        SET running = 0,
 131:            phase = CASE WHEN phase IN ${ACTIVE_RUNTIME_PHASE_SQL} THEN 'stopped' ELSE phase END,
 132:            updated_at = ?
 133:        WHERE running != 0 OR phase IN ${ACTIVE_RUNTIME_PHASE_SQL}`,
 134:       [now],
 135:     );
 136:     this.db.run(
 137:       `UPDATE loop_state
 138:        SET running = 0,
 139:            phase = CASE WHEN phase IN ${ACTIVE_RUNTIME_PHASE_SQL} THEN 'stopped' ELSE phase END,
 140:            updated_at = ?
 141:        WHERE id = 1 AND (running != 0 OR phase IN ${ACTIVE_RUNTIME_PHASE_SQL})`,
 142:       [now],
 143:     );
 144:     this.db.run('UPDATE plan_tasks SET status = ?, updated_at = ? WHERE status = ?', ['pending', now, 'running']);
 145:   }
 146: 
 147:   status(projectId = this.defaultProjectId()) {
 148:     if (!projectId) return null;
 149:     this.ensureProjectState(projectId);
 150:     return this.normalizeRuntimeStatus(projectId, this.db.get('SELECT * FROM project_states WHERE project_id = ?', [projectId]));
 151:   }
 152: 
 153:   normalizeRuntimeStatus(projectId, state) {
 154:     if (!state) return null;
 155:     const runtime = this.existingRuntime(projectId);
 156:     const runtimeRunning = Boolean(runtime?.running);
 157:     const normalized = {
 158:       ...state,
 159:       running: runtimeRunning ? 1 : 0,
 160:     };
 161: 
 162:     if (!runtimeRunning && !runtime?.busy && ACTIVE_RUNTIME_PHASES.has(String(normalized.phase || ''))) {
 163:       normalized.phase = 'stopped';
 164:     }
 165: 
 166:     return normalized;
 167:   }
 168: 
 169:   configure(projectId, { workspacePath, intervalSeconds, validationCommand }) {
 170:     const current = this.status(projectId);
 171:     const project = this.project(projectId);
 172:     const runtime = this.existingRuntime(projectId);
 173:     const nextWorkspace = workspacePath ?? project?.workspace_path;
 174:     const workspaceOwner = this.activeProjectForWorkspace(nextWorkspace, projectId);
 175:     if ((runtime?.running || runtime?.busy) && workspaceOwner) {
 176:       throw new Error(`工作区正在被项目「${workspaceOwner.name}」使用，请先停止对应循环`);
 177:     }
 178:     if (!project || !current) throw new Error('项目不存在');
 179: 
 180:     this.db.run(
 181:       `UPDATE projects
 182:        SET workspace_path = ?, updated_at = ?
 183:        WHERE id = ?`,
 184:       [nextWorkspace, nowIso(), projectId],
 185:     );
 186:     const nextInterval = Number(intervalSeconds || current.interval_seconds || 5);
 187:     this.db.run(
 188:       `UPDATE project_states
 189:        SET interval_seconds = ?, validation_command = ?, updated_at = ?
 190:        WHERE project_id = ?`,
 191:       [
 192:         nextInterval,
 193:         validationCommand ?? current.validation_command,
 194:         nowIso(),
 195:         projectId,
 196:       ],
 197:     );
 198:     if (runtime?.running) this.scheduleProject(projectId, nextInterval);
 199:     this.emitUpdate(projectId);
 200:   }
 201: 
 202:   scheduleProject(projectId, intervalSeconds) {
 203:     const runtime = this.runtime(projectId);
 204:     if (!runtime) return;
 205:     if (runtime.timer) clearInterval(runtime.timer);
 206:     runtime.timer = setInterval(() => {
 207:       if (!runtime.running) return;
 208:       this.runOnce(projectId).catch((error) => this.recordError(projectId, error));
 209:     }, Math.max(1, Number(intervalSeconds || 5)) * 1000);
 210:   }
 211: 
 212:   activeProjectForWorkspace(workspace, projectId) {

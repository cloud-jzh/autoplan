248:.workspace-search { display: flex; align-items: center; gap: 10px; flex: 1 1 420px; max-width: 580px; min-width: 280px; margin-left: auto; }
249:.workspace-search + .topbar-actions { margin-left: 0; }
250:.workspace-search-field { position: relative; flex: 1 1 auto; min-width: 0; }
251:.workspace-search-input.search-input { max-width: none; padding: 9px 38px 9px 36px; color: var(--text-1); transition: background 0.14s, border-color 0.14s, box-shadow 0.14s; }
252:.workspace-search-input.search-input:hover:not(:disabled) { background: var(--bg-soft); border-color: #cdd8ea; }
253:.workspace-search-input.search-input:disabled { background: var(--bg-soft); color: var(--text-4); cursor: not-allowed; }
254:.workspace-search-icon { position: absolute; left: 13px; top: 50%; z-index: 1; color: var(--text-3); transform: translateY(-50%); pointer-events: none; }
255:.workspace-search-clear { position: absolute; right: 6px; top: 50%; display: grid; place-items: center; width: 28px; height: 28px; padding: 0; border: 0; border-radius: 8px; background: transparent; color: var(--text-3); transform: translateY(-50%); transition: background 0.14s, color 0.14s; }
256:.workspace-search-clear:hover { background: var(--bg-hover); color: var(--text-1); }
257:.workspace-search-clear:focus-visible { outline: none; box-shadow: 0 0 0 3px var(--brand-50); color: var(--brand-600); }
258:.workspace-search-clear:disabled { color: var(--text-4); cursor: not-allowed; }

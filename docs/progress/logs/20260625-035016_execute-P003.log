542:function OverviewView({
543:  snapshot,
544:  state,
545:  onGoTasks,
546:}: {
547:  snapshot: AppSnapshot;
548:  state: ProjectState | null;
549:  onGoTasks: () => void;
550:}) {
551:  const reqCount = snapshot.requirements.length;
552:  const planCount = snapshot.plans.length;
553:  const runningPlan = snapshot.plans.find((plan) => !['completed'].includes(plan.status));
554:  const doneTasks = snapshot.tasks.filter((task) => task.status === 'completed').length;
555:  const totalTasks = snapshot.tasks.length;
556:
557:  const phases = ['scan', 'generate-plan', 'execute-task', 'validate', 'completed'];
558:  const currentPhase = state?.phase || 'idle';
559:  const activeIndex = phases.indexOf(currentPhase);
560:  const operation = snapshot.activeOperation || snapshot.lastOperation;
561:  const operationActive = Boolean(snapshot.activeOperation);
562:  const operationTime = operation?.startedAt ? `开始于 ${formatChinaTime(operation.startedAt)}` : '';
563:  const operationExit =
564:    operation && !operationActive && typeof operation.exitCode === 'number'
565:      ? ` · 退出码 ${operation.exitCode}${operation.exitCode === 0 ? '（成功）' : '（失败）'}`
566:      : '';
567:  const operationHint = operation ? `${operationTime}${operationExit}` : '等待下一次执行';
568:  const operationTitle = operation ? `${operationActive ? '执行日志' : '最近执行'} · ${operation.label}` : '执行日志';
569:
570:  return (
571:    <>
572:      <div className="stat-grid">
573:        <StatCard icon="◎" value={String(reqCount)} label="需求" accent="brand" />
574:        <StatCard
575:          icon="▤"
576:          value={String(planCount)}
577:          label="计划"
578:          sub={runningPlan ? `${runningPlan.completed_tasks}/${runningPlan.total_tasks} 任务` : '无进行中'}
579:          accent="info"
580:        />
581:        <StatCard icon="☑" value={`${doneTasks}/${totalTasks}`} label="任务进度" accent="success" />
582:        <StatCard icon="↻" value={`${state?.interval_seconds || 5}s`} label="循环间隔" accent="warning" />
583:      </div>
584:
585:      <div className="overview-grid">
586:        <div className="overview-main-column">
587:          <section className="card live-log-card">
588:            <div className="card-head log-card-head">
589:              <div className="log-title-line">
590:                <h2>
591:                  <span className={`live-dot${operationActive ? '' : ' idle'}`} /> {operationTitle}
592:                </h2>
593:                <span className="hint">{operationHint}</span>
594:                <span className={`log-phase-chip ${state?.running ? 'running' : 'stopped'}`}>
595:                  {state?.running ? '循环运行中' : '循环已停止'} · {currentPhase}
596:                </span>
597:              </div>
598:              <div className="log-summary">
599:                <span>
600:                  计划草稿 <b>{snapshot.planDrafts.length}</b>
601:                </span>
602:                <span>
603:                  待确认草稿 <b>{snapshot.planDrafts.filter((draft) => draft.status !== 'accepted').length}</b>
604:                </span>
605:                <span>
606:                  反馈 <b>{snapshot.feedback.length}</b>
607:                </span>
608:              </div>
609:            </div>
610:            <CodexLog log={operation?.logTail || ''} activity={operation?.activity || []} />
611:          </section>
612:        </div>
613:
614:        <div className="overview-side-column">
615:          <section className="card">
616:            <div className="card-head">
617:              <h2>循环阶段流水线</h2>
618:            </div>
619:            <div className="card-body">
620:              <div className="pipeline">
621:                {phases.map((phase, index) => {

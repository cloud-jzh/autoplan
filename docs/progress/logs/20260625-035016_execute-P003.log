241:  return (
242:    <svg
243:      viewBox="0 0 24 24"
244:      fill="none"
245:      stroke="currentColor"
246:      strokeWidth={1.8}
247:      strokeLinecap="round"
248:      strokeLinejoin="round"
249:      focusable="false"
250:      {...svgProps}
251:      className={['app-icon', className].filter(Boolean).join(' ')}
252:      style={iconStyle}
253:      aria-hidden={shouldHide ? true : undefined}
254:      aria-labelledby={labelledBy}
255:      aria-label={labelledBy ? undefined : ariaLabel}
256:      role={role ?? (!shouldHide && hasAccessibleName ? 'img' : undefined)}
257:    >
258:      {labelledBy ? <title id={labelledBy}>{title}</title> : null}
259:      {ICONS[name]}
260:    </svg>
261:  );

+function WorkspaceSearchBox({
+  hitCount,
+  onQueryChange,
+  query,
+  totalCount,
+}: {
+  hitCount: number;
+  onQueryChange: (query: string) => void;
+  query: string;
+  totalCount: number;
+}) {

260:.workspace-search-count.is-empty { color: var(--warning); }
261:.pill { display: inline-flex; align-items: center; gap: 8px; padding: 6px 12px; border-radius: 999px; font-size: 12px; font-weight: 600; background: var(--bg-soft); border: 1px solid var(--line); color: var(--text-2); }
262:.led { width: 9px; height: 9px; border-radius: 50%; background: var(--success); box-shadow: 0 0 0 4px var(--success-bg); }
263:.pill .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
264:.led.running { animation: led-pulse 1.6s ease-in-out infinite; }
265:.led.stopped { background: var(--text-4); box-shadow: 0 0 0 4px var(--line); }
266:@keyframes led-pulse { 0%,100% { box-shadow: 0 0 0 4px var(--success-bg); } 50% { box-shadow: 0 0 0 7px rgba(24,169,87,0.15); } }
267:.view { flex: 1 1 auto; min-height: 0; overflow: auto; padding: 24px 28px 32px; display: none; }
268:.view.active { display: flex; flex-direction: column; }

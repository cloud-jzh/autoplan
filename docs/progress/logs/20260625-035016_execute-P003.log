+          aria-label="搜索当前工作区"
+          className="workspace-search-input search-input"
+          onChange={(event) => onQueryChange(event.target.value)}
+          onKeyDown={(event) => {
+            if (event.key === 'Escape' && query) {
+              event.preventDefault();
+              onQueryChange('');
+            }
+          }}
+          placeholder="搜索需求、反馈、任务、Plan 或事件"
+          value={query}
+        />
+        {query ? (
+          <button

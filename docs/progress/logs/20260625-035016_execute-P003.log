234:  const shouldHide = ariaHidden === undefined ? !hasAccessibleName : isAriaHidden(ariaHidden);
235:  const labelledBy = title && !shouldHide ? titleId : undefined;
236:  const iconStyle = {
237:    '--icon-size': formatIconSize(size),
238:    ...style,
239:  } as React.CSSProperties;

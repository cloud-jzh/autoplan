        </div>
      </div>
    </aside>
  );
}

function WorkspaceSearchBox({
  hitCount,
  onQueryChange,
  query,
  totalCount,
}: {
  hitCount: number;
  onQueryChange: (query: string) => void;
  query: string;
  totalCount: number;
}) {
  const hasQuery = Boolean(normalizeSearchQuery(query));
  const resultLabel = hasQuery ? `鍛戒腑 ${hitCount} 鏉 : `鍙悳绱?${totalCount} 鏉;

  return (
    <div className="workspace-search" role="search" aria-label="宸ヤ綔鍖烘悳绱?>
      <div className="workspace-search-field">
        <Icon name="search" size={16} className="workspace-search-icon" aria-hidden="true" />
        <input
          aria-label="鎼滅储褰撳墠宸ヤ綔鍖?
          className="workspace-search-input search-input"
          onChange={(event) => onQueryChange(event.target.value)}
          onKeyDown={(event) => {
            if (event.key === 'Escape' && query) {
              event.preventDefault();
              onQueryChange('');
            }
          }}
          placeholder="鎼滅储闇€姹傘€佸弽棣堛€佷换鍔°€丳lan 鎴栦簨浠?
          value={query}
        />
        {query ? (
          <button
            type="button"
            className="workspace-search-clear"
            onClick={() => onQueryChange('')}
            aria-label="娓呯┖宸ヤ綔鍖烘悳绱㈠叧閿瓧"
          >
            <Icon name="close" size={15} aria-hidden="true" />
          </button>
        ) : null}
      </div>
      <span className={`workspace-search-count${hasQuery && hitCount === 0 ? ' is-empty' : ''}`} aria-live="polite">
        {resultLabel}
      </span>
    </div>
  );
}

function normalizeSearchQuery(value: string) {
  return value.trim().toLowerCase().replace(/\s+/g, ' ');
}

function countSearchableItems(snapshot: AppSnapshot) {
  return (
    snapshot.requirements.length +
    snapshot.feedback.length +
    snapshot.planDrafts.length +
    snapshot.plans.length +
    snapshot.tasks.length +
    snapshot.events.length
  );
}

function countWorkspaceSearchMatches(snapshot: AppSnapshot, normalizedQuery: string) {
  const groups: unknown[][] = [
    snapshot.requirements,
    snapshot.feedback,
    snapshot.planDrafts,
    snapshot.plans,
    snapshot.tasks,
    snapshot.events,
  ];

  return groups.reduce(
    (count, group) => count + group.filter((item) => normalizeSearchQuery(toSearchText(item)).includes(normalizedQuery)
).length,
    0,
  );
}

function toSearchText(value: unknown, depth = 0): string {
  if (value === null || value === undefined || depth > 6) return '';
  if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') return String(value);
  if (Array.isArray(value)) return value.map((item) => toSearchText(item, depth + 1)).join(' ');
  if (typeof value === 'object') {
    return Object.values(value as Record<string, unknown>)
      .map((item) => toSearchText(item, depth + 1))
      .join(' ');
  }
  return '';
}

function OverviewView({
  snapshot,
  state,
  onGoTasks,
}: {
  snapshot: AppSnapshot;
  state: ProjectState | null;
  onGoTasks: () => void;
}) {
  const reqCount = snapshot.requirements.length;
  const planCount = snapshot.plans.length;
  const runningPlan = snapshot.plans.find((plan) => !['completed'].includes(plan.status));
  const doneTasks = snapshot.tasks.filter((task) => task.status === 'completed').length;
  const totalTasks = snapshot.tasks.length;

  const phases = ['scan', 'generate-plan', 'execute-task', 'validate', 'completed'];
  const currentPhase = state?.phase || 'idle';
  const activeIndex = phases.indexOf(currentPhase);
  const operation = snapshot.activeOperation || snapshot.lastOperation;
  const operationActive = Boolean(snapshot.activeOperation);
  const operationTime = operation?.startedAt ? `寮€濮嬩簬 ${formatChinaTime(operation.startedAt)}` : '';
  const operationExit =
    operation && !operationActive && typeof operation.exitCode === 'number'
      ? ` 路 閫€鍑虹爜 ${operation.exitCode}${operation.exitCode === 0 ? '锛堟垚鍔燂級' : '锛堝け璐ワ級'}`
      : '';
  const operationHint = operation ? `${operationTime}${operationExit}` : '绛夊緟涓嬩竴娆℃墽琛?;
  const operationTitle = operation ? `${operationActive ? '鎵ц鏃ュ織' : '鏈€杩戞墽琛?} 路 ${operation.label}` : '鎵ц鏃ュ織';

  return (
    <>
      <div className="stat-grid">
        <StatCard icon="鈼? value={String(reqCount)} label="闇€姹? accent="brand" />
        <StatCard
          icon="鈻?
          value={String(planCount)}
          label="璁″垝"
          sub={runningPlan ? `${runningPlan.completed_tasks}/${runningPlan.total_tasks} 浠诲姟` : '鏃犺繘琛屼腑'}
          accent="info"
        />
        <StatCard icon="鈽? value={`${doneTasks}/${totalTasks}`} label="浠诲姟杩涘害" accent="success" />
        <StatCard icon="鈫? value={`${state?.interval_seconds || 5}s`} label="寰幆闂撮殧" accent="warning" />
      </div>

      <div className="overview-grid">
        <div className="overview-main-column">
          <section className="card live-log-card">
            <div className="card-head log-card-head">
              <div className="log-title-line">
                <h2>
                  <span className={`live-dot${operationActive ? '' : ' idle'}`} /> {operationTitle}
                </h2>
                <span className="hint">{operationHint}</span>
                <span className={`log-phase-chip ${state?.running ? 'running' : 'stopped'}`}>
                  {state?.running ? '寰幆杩愯涓? : '寰幆宸插仠姝?} 路 {currentPhase}
                </span>
              </div>
              <div className="log-summary">
                <span>
                  璁″垝鑽夌 <b>{snapshot.planDrafts.length}</b>
                </span>
                <span>
                  寰呯‘璁よ崏绋?<b>{snapshot.planDrafts.filter((draft) => draft.status !== 'accepted').length}</b>
                </span>
                <span>
                  鍙嶉 <b>{snapshot.feedback.length}</b>
                </span>
              </div>
            </div>
            <CodexLog log={operation?.logTail || ''} activity={operation?.activity || []} />
          </section>
        </div>

        <div className="overview-side-column">
          <section className="card">
            <div className="card-head">
              <h2>寰幆闃舵娴佹按绾?/h2>
            </div>
            <div className="card-body">
              <div className="pipeline">
                {phases.map((phase, index) => {
                  const done = activeIndex > index;
                  const active = activeIndex === index;
                  return (
                    <div className={`pipe-step ${done ? 'done' : ''} ${active ? 'active' : ''}`} key={phase}>
                      <div className="pipe-node">{done ? '鉁? : active ? '鈻? : index + 1}</div>
                      <div className="pipe-label">{phaseLabel(phase)}</div>
                    </div>
                  );
                })}
              </div>
            </div>
          </section>

          <section className="card">
            <div className="card-head">
              <h2>杩戞湡浜嬩欢</h2>
              <span className="spacer">
                <button type="button" className="btn-link" onClick={onGoTasks}>
                  鏌ョ湅浠诲姟 鈫?                </button>
              </span>
            </div>
            <div className="card-body">
              <EventList events={snapshot.events.slice(0, 8)} />
            </div>
          </section>
        </div>
      </div>
    </>
  );
}

function StatCard({
  icon,
  value,
  label,
  sub,
  accent,
}: {
  icon: string;
  value: string;
  label: string;
  sub?: string;
  accent: 'brand' | 'info' | 'success' | 'warning';
}) {
  return (
    <div className={`stat stat-${accent}`}>
      <div className="stat-ico">{icon}</div>
      <div className="stat-value">{value}</div>
      <div className="stat-label">{label}</div>
      {sub ? <div className="stat-delta">{sub}</div> : null}
    </div>
  );
}

function tabTitle(tab: WorkspaceTab) {
  return { overview: '姒傝', requirement: '闇€姹傛ā鍧?, feedback: '鍙嶉妯″潡', tasks: '浠诲姟涓庤鍒?, events: '浜嬩欢娴? }[tab];
}

function tabSubtitle(tab: WorkspaceTab, project: Project | null) {
  const base = {
    overview: '寰幆鐘舵€併€侀樁娈垫祦姘寸嚎涓庡悇妯″潡涓€瑙?,
    requirement: '鏀堕泦闇€姹傦紝鍙戦€佸悗鑷姩鐢熸垚璁″垝鑽夌',
    feedback: '鏀堕泦鍙嶉锛屽叧鑱旈渶姹傚苟鐢熸垚璁″垝鑽夌',
    tasks: '寰幆鎺у埗銆佽鍒掕崏绋裤€丳lan 涓庝换鍔¤繘搴?,
    events: '寰幆杩愯鏃ュ織涓庝换鍔℃墽琛岃褰?,
  }[tab];
  return project ? `${base} 路 ${project.name}` : base;
}

function phaseLabel(phase: string) {
  return (
    {
      idle: '绌洪棽',
      scan: '鎵弿',
      'generate-plan': '鐢熸垚璁″垝',
      'execute-task': '鎵ц浠诲姟',
      validate: '楠屾敹',
      completed: '瀹屾垚',
      waiting: '绛夊緟',
      error: '寮傚父',
    }[phase] || phase
  );
}





import { useEffect, useRef } from 'react';
import type { ActivityLine } from '../types';
import { formatChinaTime } from '../utils/time';

const ROLE_CONFIG: Record<string, { label: string; cls: string }> = {
  codex: { label: 'Codex', cls: 'act-codex' },
  exec: { label: '执行', cls: 'act-exec' },
  thinking: { label: '思考', cls: 'act-thinking' },
  error: { label: '错误', cls: 'act-error' },
  system: { label: '系统', cls: 'act-system' },
  user: { label: '用户', cls: 'act-user' },
  info: { label: '信息', cls: 'act-info' },
};

/**
 * 以活动时间线显示 codex 执行过程（参考 run_advanced_plan_with_codex.dart 的 Activity 输出）。
 * 优先用过滤后的 activity 行；若为空则回退到 logTail 原始尾部。
 */
export function CodexLog({
  log,
  activity,
}: {
  log: string;
  activity?: ActivityLine[];
}) {
  const scrollRef = useRef<HTMLDivElement>(null);
  const lines = activity && activity.length > 0 ? activity : null;

  useEffect(() => {
    const el = scrollRef.current;
    if (el) el.scrollTop = el.scrollHeight;
  }, [log, activity]);

  if (!lines) {
    return (
      <div className="codex-log" ref={scrollRef}>
        <pre className="codex-raw">{log ? log.slice(-4000) : '等待 Codex 输出…'}</pre>
      </div>
    );
  }

  return (
    <div className="codex-log" ref={scrollRef}>
      {lines.map((line, index) => {
        const config = ROLE_CONFIG[line.role] || { label: line.role || '信息', cls: 'act-info' };
        return (
          <div className={`act-line ${config.cls}`} key={index}>
            <span className="act-time">{formatChinaTime(line.at)}</span>
            <span className="act-tag">{config.label}</span>
            <span className="act-text">{line.text}</span>
          </div>
        );
      })}
    </div>
  );
}



**Clarifying scroll implementation**

I need to focus on implementing P001, which involves establishing a log bottom determination mechanism. P002, regarding auto-scrolling, is something for the future. Currently, the existing useEffect always scrolls, but I'm not sure if that meets P001's requirements. 

P001 centers around recording the isAtBottom state and the scroll handler. It's crucial to tread lightly here because I can't implement P002 just yet. If we retain the always-scroll effect, it might interfere with P001's objectives, especially when users scroll up manually.
**Deciding on scroll behavior**

I'm considering whether we should avoid changing the auto-scroll feature for now, since P002 mentions implementing auto-scrolling only when sticky to the bottom. If I'm developing P001, I have to be careful not to alter the existing useEffect, but leaving it unchanged may lead to issues with the bottom state being overwritten. 

I might need to adjust it to maintain scrollTop. For P001, I'll likely add functions like `isNearBottom` and manage state through `isStickyToBottomRef`. I want to implement this without affecting the current behavior while ensuring that the state tracking user scroll position is addressed properly.

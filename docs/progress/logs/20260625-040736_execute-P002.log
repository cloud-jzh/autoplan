1360: function taskEventMeta(task, overrides = {}) {
1361:   const meta = {
1362:     ...compactEventMeta({
1363:       taskId: task?.id,
1364:       taskKey: task?.task_key,
1365:       taskTitle: task?.title,
1366:       planId: task?.plan_id,
1367:       status: task?.status,
1368:       startedAt: task?.started_at,
1369:       finishedAt: task?.finished_at,
1370:       durationMs: task?.duration_ms,
1371:       runDurationMs: task?.run_duration_ms,
1372:     }),
1373:     ...compactEventMeta(overrides),
1374:   };
1375:   meta.taskId = normalizeOptionalNumber(meta.taskId);
1376:   meta.planId = normalizeOptionalNumber(meta.planId);
1377:   meta.taskKey = normalizeOptionalString(meta.taskKey);
1378:   meta.taskTitle = normalizeOptionalString(meta.taskTitle);
1379:   meta.status = normalizeOptionalString(meta.status);
1380:   meta.startedAt = normalizeOptionalString(meta.startedAt);
1381:   meta.finishedAt = normalizeOptionalString(meta.finishedAt);
1382:   meta.durationMs = normalizeOptionalNumber(meta.durationMs);
1383:   meta.runDurationMs = normalizeOptionalNumber(meta.runDurationMs);
1384:   const compacted = compactEventMeta(meta);
1385:   return Object.keys(compacted).length ? compacted : null;
1386: }
1387: 
1388: function syncedTaskStatus(parsedStatus, existingStatus) {
1389:   const next = normalizeOptionalString(parsedStatus) || TASK_EVENT_STATUS.PENDING;
1390:   const current = normalizeOptionalString(existingStatus);
1391:   if (!current) return next;
1392:   if (next === TASK_EVENT_STATUS.COMPLETED || current === TASK_EVENT_STATUS.COMPLETED) return TASK_EVENT_STATUS.COMPLETED;
1393:   if (current === TASK_EVENT_STATUS.RUNNING || current === 'blocked') return current;
1394:   return next;
1395: }


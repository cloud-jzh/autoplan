 553:   scanDirectory(root, workspace, extensions) {
 554:     if (!fs.existsSync(root)) return { root, aggregateHash: hashText(''), files: [] };
 555:     const files = [];
 556:     const visit = (dir) => {
 557:       for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
 558:         const full = path.join(dir, entry.name);
 559:         if (entry.isDirectory()) {
 560:           visit(full);
 561:         } else if (entry.isFile() && extensions.includes(path.extname(entry.name).toLowerCase())) {
 562:           const stat = fs.statSync(full);
 563:           files.push({
 564:             path: normalizeRelative(workspace, full),
 565:             hash: hashFile(full),
 566:             size: stat.size,
 567:             modifiedAt: stat.mtime.toISOString(),
 568:           });
 569:         }
 570:       }
 571:     };
 572:     visit(root);
 573:     files.sort((a, b) => a.path.localeCompare(b.path));
 574:     return {
 575:       root,
 576:       aggregateHash: hashText(files.map((file) => `${file.path}|${file.hash}|${file.size}`).join('\n')),
 577:       files,
 578:     };
 579:   }

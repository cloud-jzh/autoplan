const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');
const assert = require('node:assert/strict');
const { AppDatabase, nowIso } = require('./src/database');
const { LoopService } = require('./src/loopService');

(async () => {
  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'autoplan-duration-'));
  const db = new AppDatabase(path.join(dir, 'test.sqlite'));
  await db.init();
  const projectId = db.get('SELECT id FROM projects ORDER BY id ASC LIMIT 1').id;
  const now = nowIso();
  const planId = db.insert(
    "'`INSERT INTO plans (project_id, issue_hash, file_path, hash, status, total_tasks, completed_tasks, validation_passed, created_at, updated_at)
     VALUES (?, ?, ?, ?, ?, 1, 0, 0, ?, ?)`,
    [projectId, '"'issue', 'docs/plan/test.md', '', 'pending', now, now],
  );
  const taskId = db.insert(
    "'`INSERT INTO plan_tasks (plan_id, task_key, title, raw_line, scope, status, sort_order, duration_ms, updated_at)
     VALUES (?, '"'P001', 'Test task', '- [ ] P001: Test task <"'!-- scope: src/loopService.js -->'"', 'src/loopService.js', 'pending', 1, 500, ?)"'`,
    [planId, now],
  );
  const service = new LoopService(db);
  service.startTaskRun(taskId, '"'2026-01-01T00:00:00.000Z');
  let task = db.get('SELECT * FROM plan_tasks WHERE id = ?', [taskId]);
  assert.equal(task.status, 'running');
  assert.equal(task.started_at, '2026-01-01T00:00:00.000Z');
  assert.equal(task.finished_at, null);
  assert.equal(task.duration_ms, 500);
  const finished = service.finishTaskRun(taskId, 'pending', '2026-01-01T00:00:01.250Z', { onlyIfRunning: true });
  task = db.get('SELECT * FROM plan_tasks WHERE id = ?', [taskId]);
  assert.equal(task.status, 'pending');
  assert.equal(task.finished_at, '2026-01-01T00:00:01.250Z');
  assert.equal(task.duration_ms, 1750);
  assert.equal(finished.run_duration_ms, 1250);
  service.startTaskRun(taskId, '2026-01-01T00:00:03.000Z');
  service.finishTaskRun(taskId, 'completed', '2026-01-01T00:00:04.000Z');
  task = db.get('SELECT * FROM plan_tasks WHERE id = ?', [taskId]);
  assert.equal(task.duration_ms, 2750);
  db.close?.();
  fs.rmSync(dir, { recursive: true, force: true });
})();

        { task_key: 'P010', title: '执行回归验证', raw_line: '- [ ] P010: 执行回归验证 <!-- scope: test/b.dart -->' },
      ]).map((task) => task.task_key),
      ['P009'],
      '测试/验证类任务应保持串行',
    );

    const plan = db.get('SELECT * FROM plans WHERE id = ?', [planId]);
    const planFile = path.join(workspace, plan.file_path);

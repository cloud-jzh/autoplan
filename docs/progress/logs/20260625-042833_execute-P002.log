  589:   scanDirectory(root, workspace, extensions) {
  590:     if (!fs.existsSync(root)) return { root, aggregateHash: hashText(''), files: [] };
  591:     const files = [];
  592:     const visit = (dir) => {
  593:       for (const entry of fs.readdirSync(dir, { withFileTypes: true })) {
  594:         const full = path.join(dir, entry.name);
  595:         if (entry.isDirectory()) {
  596:           visit(full);
  597:         } else if (entry.isFile() && extensions.includes(path.extname(entry.name).toLowerCase())) {
  598:           const stat = fs.statSync(full);
  599:           files.push({
  600:             path: normalizeRelative(workspace, full),
  601:             hash: hashFile(full),
  602:             size: stat.size,
  603:             modifiedAt: stat.mtime.toISOString(),
  604:           });
  605:         }
  606:       }
  607:     };
  608:     visit(root);
  609:     files.sort((a, b) => a.path.localeCompare(b.path));
  610:     return {
  611:       root,
  612:       aggregateHash: hashText(files.map((file) => `${file.path}|${file.hash}|${file.size}`).join('\n')),
  613:       files,
  614:     };
  615:   }

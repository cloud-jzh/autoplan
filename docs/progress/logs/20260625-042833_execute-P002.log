+    Object.defineProperty(error, TASK_LIFECYCLE_EVENT_RECORDED, { value: true });
+  } catch {
+    error[TASK_LIFECYCLE_EVENT_RECORDED] = true;
+  }
+}
+
+function taskLifecycleEventRecorded(error) {

项目入口在主进程，我直接插入最小数据以验证 `LoopService` 快照行为。
exec
powershell.exe -Command '$script = @'"'
const assert = require('node:assert/strict');
const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');
const { AppDatabase, nowIso } = require('./src/database');
const { LoopService, TASK_EVENT_TYPES } = require('./src/loopService');

(async () => {
  const dir = fs.mkdtempSync(path.join(os.tmpdir(), 'autoplan-p003-'));
  const db = new AppDatabase(path.join(dir, 'app.sqlite'));
  await db.init();
  const loop = new LoopService(db);
  const workspace = path.join(dir, 'workspace');
  fs.mkdirSync(workspace, { recursive: true });
  const projectId = db.insert(
    'INSERT INTO projects (name, workspace_path, description, created_at, updated_at) VALUES (?, ?, ?, ?, ?)',
    ['P003', workspace, '', nowIso(), nowIso()],
  );
  db.run('INSERT INTO project_states (project_id, updated_at) VALUES (?, ?)', [projectId, nowIso()]);
  const updates = [];
  loop.on('update', (snapshot) => updates.push(snapshot));

  loop.addEvent(projectId, TASK_EVENT_TYPES.STARTED, '开始了 P001 任务：测试', {
    taskId: 101,
    taskKey: 'P001',
    taskTitle: '测试',
  });
  loop.addEvent(projectId, TASK_EVENT_TYPES.SUCCEEDED, '结束了 P002 任务：测试', {
    taskId: 102,
    taskKey: 'P002',
    taskTitle: '测试',
  });

  const snapshot = loop.snapshot(projectId);
  assert.equal(snapshot.events.length, 2);
  assert.equal(snapshot.events[0].type, TASK_EVENT_TYPES.SUCCEEDED);
  assert.equal(snapshot.events[0].meta.taskId, 102);
  assert.equal(snapshot.events[0].meta.taskKey, 'P002');
  assert.equal(snapshot.events[1].type, TASK_EVENT_TYPES.STARTED);
  assert.equal(snapshot.events[1].meta.taskId, 101);
  assert.ok(updates.length >= 2, 'event writes should emit updates immediately');
  assert.equal(updates.at(-1).events[0].meta.taskKey, 'P002');

  for (let i = 0; i < 90; i += 1) loop.addEvent(projectId, 'test.event', "'`event ${i}`);
  assert.equal(loop.snapshot(projectId).events.length, 80);
  assert.equal(loop.snapshot(projectId).events[0].message, '"'event 89');

  db.close();
  fs.rmSync(dir, { recursive: true, force: true });
})();

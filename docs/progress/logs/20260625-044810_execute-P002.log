.loop-card { background: var(--brand-grad); color: #fff; border-radius: var(--r-lg); padding: 22px 24px; position: relative; overflow: hidden; box-shadow: 0 18px 40px rgba(77,110,255,0.28); }
.loop-card .lc-top { display: flex; align-items: center; gap: 12px; }
.loop-card .lc-status { font-size: 13px; opacity: 0.9; }
.loop-card .lc-phase { font-size: 22px; font-weight: 800; margin-top: 4px; }
.loop-card .lc-meta { display: flex; gap: 22px; margin-top: 16px; font-size: 12px; opacity: 0.92; }
.loop-card .lc-meta b { display: block; font-size: 15px; font-weight: 700; margin-top: 2px; }
.loop-card .lc-led { width: 12px; height: 12px; border-radius: 50%; background: #b6f5cf; box-shadow: 0 0 0 4px rgba(182,245,207,0.25); }
.loop-card .lc-led.running { animation: led-pulse 1.6s ease-in-out infinite; }
.loop-card .lc-led.stopped { background: #cfd6e6; box-shadow: 0 0 0 4px rgba(207,214,230,0.25); }

.pipeline { display: flex; align-items: flex-start; gap: 0; overflow-x: auto; }
.pipe-step { flex: 1 1 0; min-width: 0; text-align: center; position: relative; }
.pipe-node { width: 40px; height: 40px; margin: 0 auto; border-radius: 50%; display: grid; place-items: center; background: var(--bg-elevated); border: 2px solid var(--line); color: var(--text-3); font-weight: 700; font-size: 14px; position: relative; z-index: 1; }
.pipe-step.done .pipe-node { background: var(--success); border-color: var(--success); color: #fff; }
.pipe-step.active .pipe-node { background: var(--brand-600); border-color: var(--brand-600); color: #fff; box-shadow: 0 0 0 5px var(--brand-50); }
.pipe-step::before { content: ""; position: absolute; top: 20px; left: -50%; right: 50%; height: 2px; background: var(--line); z-index: 0; }
.pipe-step:first-child::before { display: none; }
.pipe-step.done::before, .pipe-step.active::before { background: var(--success); }
.pipe-label { font-size: 12px; font-weight: 600; margin-top: 10px; color: var(--text-2); }
.pipe-step.active .pipe-label { color: var(--brand-600); }

/* 实时执行日志（对话格式） */
.live-log-card { display: flex; flex-direction: column; min-height: 0; }
.live-log-card .card-head h2 { display: flex; align-items: center; gap: 8px; }
.overview-main-column > .live-log-card { height: 440px; }
.overview-main-column > .live-log-card .codex-log { flex: 1 1 auto; min-height: 0; max-height: none; }
.log-card-head { align-items: stretch; flex-direction: column; gap: 8px; padding: 12px 18px; }
.log-title-line { display: flex; align-items: center; gap: 12px; min-width: 0; }
.log-title-line h2 { flex: 0 0 auto; }
.log-title-line .hint { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.log-phase-chip { flex: 0 0 auto; border: 1px solid var(--line); border-radius: 999px; padding: 4px 9px; background: var(--bg-soft); color: var(--text-2); font-size: 12px; font-weight: 700; white-space: nowrap; }
.log-phase-chip.running { color: var(--success); background: var(--success-bg); border-color: transparent; }
.log-summary { display: flex; align-items: center; gap: 18px; color: var(--text-3); font-size: 12px; }
.log-summary b { color: var(--text-1); margin-left: 4px; }
.live-dot {
  width: 8px; height: 8px; border-radius: 50%; background: var(--success);
  box-shadow: 0 0 0 3px var(--success-bg);
  animation: led-pulse 1.4s ease-in-out infinite;
}
.live-dot.idle { background: var(--text-4); box-shadow: 0 0 0 3px var(--line); animation: none; }
.codex-log {
  margin: 0; padding: 10px;
  background: #1b2438; color: #d6e1f5;
  border-radius: 0 0 var(--r-lg) var(--r-lg);
  max-height: 380px; min-height: 120px; overflow: auto;
  font-family: var(--font-mono); font-size: 12px; line-height: 1.6;
}
.codex-raw { margin: 0; white-space: pre-wrap; word-break: break-word; color: #8a96b0; padding: 8px; }

/* 活动时间线行 */
.act-line {
  display: grid; grid-template-columns: 56px 52px 1fr; gap: 8px;
  align-items: baseline; padding: 4px 8px; border-radius: 4px;
}
.act-line:hover { background: rgba(255,255,255,0.04); }
.act-time { color: #5a6680; font-size: 11px; font-variant-numeric: tabular-nums; }
.act-tag {
  display: inline-block; font-size: 10px; font-weight: 700;
  padding: 1px 7px; border-radius: 999px; text-align: center;
  letter-spacing: 0.02em;
}
.act-text { color: #c8d3ec; word-break: break-word; white-space: pre-wrap; }

.act-codex .act-tag { background: rgba(109,93,252,0.3); color: #c4b8ff; }
.act-codex .act-text { color: #e0e6ff; }
.act-exec .act-tag { background: rgba(24,169,87,0.3); color: #7fe0a8; }
.act-exec .act-text { color: #9fd8b8; }
.act-thinking .act-tag { background: rgba(224,134,0,0.3); color: #ffc878; }
.act-thinking .act-text { color: #d8b878; font-style: italic; }
.act-error .act-tag { background: rgba(229,72,77,0.35); color: #ff9498; }
.act-error .act-text { color: #ff9498; }
.act-system .act-tag { background: rgba(124,135,155,0.3); color: #a0aac0; }
.act-system .act-text { color: #a0aac0; }
.act-user .act-tag { background: rgba(59,110,245,0.3); color: #8ab0ff; }
.act-user .act-text { color: #b8c8f0; }
.act-info .act-tag { background: rgba(124,135,155,0.25); color: #8a96b0; }
.act-info .act-text { color: #b0bbd6; }

.intake-layout { display: grid; grid-template-rows: minmax(0,1fr) auto; gap: 16px; flex: 1 1 0; min-height: 0; max-width: 880px; margin: 0 auto; width: 100%; }
.intake-layout > .composer { margin-bottom: 24px; }
.intake-stream { display: grid; grid-template-rows: auto minmax(0,1fr); min-height: 0; border: 1px solid var(--line); border-radius: var(--r-lg); background: var(--bg-elevated); padding: 18px; }
.section-heading { display: flex; align-items: baseline; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
.section-heading h2 { margin-bottom: 0; }
.section-heading span { color: var(--text-3); font-size: 12px; }
.intake-list { min-height: 0; overflow: auto; padding-right: 4px; display: flex; flex-direction: column; gap: 10px; }

.composer { background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-xl); padding: 14px 16px 12px; box-shadow: var(--shadow-lg); transition: border-color 0.16s, box-shadow 0.16s; }
.composer:focus-within { border-color: var(--brand-500); box-shadow: 0 18px 48px rgba(37,62,120,0.2); }
.composer.drag-over { border-color: var(--brand-500); background: var(--brand-50); }
.composer textarea { width: 100%; border: 0; outline: none; resize: none; background: transparent; font: inherit; font-size: 14.5px; line-height: 1.5; color: var(--text-1); min-height: 58px; max-height: 180px; overflow: auto; }
.composer textarea::placeholder { color: var(--text-4); }
.composer-bottom { display: flex; align-items: center; gap: 10px; margin-top: 8px; }
.composer-tools { display: flex; align-items: center; gap: 10px; min-width: 0; }
.attachment-trigger { display: grid; place-items: center; width: 40px; height: 40px; flex: 0 0 auto; padding: 0; border: 0; border-radius: 50%; background: transparent; color: var(--text-3); cursor: pointer; }
.attachment-trigger:hover, .attachment-trigger.drag-over { background: var(--bg-hover); }
.attachment-trigger input { display: none; }
.plus-icon { display: block; color: var(--text-3); font-size: 28px; font-weight: 300; line-height: 1; }
.composer-actions { display: flex; align-items: center; justify-content: end; gap: 10px; margin-left: auto; }
.composer-actions span { color: var(--text-3); font-size: 12px; }
.send-button { display: grid; place-items: center; width: 42px; height: 42px; flex: 0 0 auto; border: 0; border-radius: 50%; padding: 0; background: var(--brand-grad); color: #fff; font-size: 20px; line-height: 1; box-shadow: 0 6px 14px rgba(77,110,255,0.4); }
.send-button:hover { filter: brightness(1.05); }
.attachment-list.pending { display: flex; align-items: center; min-width: 0; max-width: min(520px,54vw); gap: 8px; overflow-x: auto; }
.pending-attachment { display: grid; grid-template-columns: 42px 1fr auto auto; align-items: center; gap: 8px; padding: 8px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-soft); }
.pending-thumb, .pending-file-icon { width: 42px; height: 42px; border-radius: var(--r-sm); background: var(--brand-50); }
.pending-thumb { object-fit: cover; }
.pending-file-icon { display: grid; place-items: center; color: var(--text-3); font-size: 12px; }
.pending-attachment span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.pending-attachment small { color: var(--text-3); }
.pending-attachment button { padding: 5px 8px; font-size: 12px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); }

.task-layout { display: grid; grid-template-columns: 320px minmax(0,1fr); gap: 18px; flex: 1 1 0; min-height: 0; }
.task-sidebar { display: grid; grid-template-rows: auto minmax(0,1fr); gap: 16px; min-height: 0; }
.task-sidebar > form.editor { min-height: 0; }
.task-main { display: grid; grid-template-rows: 1fr; gap: 16px; min-height: 0; }
.task-status-grid { display: grid; grid-template-columns: repeat(2, minmax(0,1fr)); gap: 16px; min-height: 0; }
.primary-section, .side-section, .task-status-grid .card { min-height: 0; overflow: hidden; display: flex; flex-direction: column; }
.side-section .list, .task-status-grid .list, .primary-section .list { overflow: auto; }
.field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; color: var(--text-3); font-size: 11.5px; font-weight: 600; }
.field:last-child { margin-bottom: 0; }
input, textarea, select { width: 100%; border: 1px solid var(--line); border-radius: var(--r-sm); padding: 9px 11px; font: inherit; font-size: 13px; color: var(--text-1); background: var(--bg-elevated); font-weight: 400; }
input:focus, textarea:focus, select:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
textarea { min-height: 80px; resize: vertical; }
.plan-draft textarea { min-height: 240px; font-family: var(--font-mono); font-size: 12.5px; line-height: 1.5; margin-top: 12px; }
.draft-note { color: var(--text-2); font-size: 13px; }

.modal-mask { position: fixed; inset: 0; z-index: 100; background: rgba(23,32,51,0.42); backdrop-filter: blur(2px); display: flex; align-items: center; justify-content: center; padding: 24px; }
.modal { width: 100%; max-width: 480px; background: var(--bg-elevated); border-radius: var(--r-lg); box-shadow: var(--shadow-lg); overflow: hidden; }
.modal-confirm { max-width: 400px; text-align: center; padding: 28px 24px 0; }
.modal-head { display: flex; align-items: center; gap: 12px; padding: 18px 22px; border-bottom: 1px solid var(--line-soft); }
.modal-head h3 { font-size: 16px; font-weight: 700; }
.modal-close { margin-left: auto; width: 30px; height: 30px; border-radius: 8px; border: 0; background: transparent; color: var(--text-3); font-size: 20px; }
.modal-close:hover { background: var(--bg-hover); color: var(--text-1); }
.modal-form { padding: 20px 22px; }
.modal-confirm p { font-size: 13px; color: var(--text-2); line-height: 1.6; margin: 8px 0 4px; }
.modal-danger-icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 50%; background: var(--danger-bg); color: var(--danger); font-size: 24px; margin: 0 auto 14px; }
.modal-foot { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 22px; border-top: 1px solid var(--line-soft); background: var(--bg-soft); }

@media (max-width: 1080px) {
  body { overflow: auto; }
  .workspace-shell { grid-template-columns: 1fr; height: auto; }
  .sidebar { height: auto; }


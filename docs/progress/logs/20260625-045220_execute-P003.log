 293: .pill .led { width: 7px; height: 7px; box-shadow: 0 0 0 3px var(--success-bg); }
 294: .led.running { animation: led-pulse 1.6s ease-in-out infinite; }
 295: .led.stopped { background: var(--text-4); box-shadow: 0 0 0 4px var(--line); }
 296: @keyframes led-pulse { 0%,100% { box-shadow: 0 0 0 4px var(--success-bg); } 50% { box-shadow: 0 0 0 7px rgba(24,169,87,0.15); } }
 297: .view { flex: 1 1 auto; min-height: 0; overflow: auto; padding: 24px 28px 32px; display: none; }
 298: .view.active { display: flex; flex-direction: column; }
 299: /* 概览等纯流式内容视图：恢复 block，内部自己滚动 */
 300: .view.active:has(.overview-grid),
 301: .view.active:has(.stat-grid),
 302: .view.active > section.card:only-child { display: block; }
 303: 
 304: .stat-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 20px; margin-bottom: 24px; }
 305: .stat { position: relative; padding: 18px 20px; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
 306: .stat::after { content: ""; position: absolute; right: -18px; top: -18px; width: 84px; height: 84px; border-radius: 50%; opacity: 0.5; }
 307: .stat-brand::after { background: var(--brand-50); }
 308: .stat-info::after { background: var(--info-bg); }
 309: .stat-success::after { background: var(--success-bg); }
 310: .stat-warning::after { background: var(--warning-bg); }
 311: .stat .stat-ico { width: 36px; height: 36px; border-radius: 10px; display: grid; place-items: center; margin-bottom: 12px; position: relative; z-index: 1; }
 312: .stat-brand .stat-ico { background: var(--brand-50); color: var(--brand-600); }
 313: .stat-info .stat-ico { background: var(--info-bg); color: var(--info); }
 314: .stat-success .stat-ico { background: var(--success-bg); color: var(--success); }
 315: .stat-warning .stat-ico { background: var(--warning-bg); color: var(--warning); }
 316: .stat .stat-value { font-size: 26px; font-weight: 800; line-height: 1; position: relative; z-index: 1; }
 317: .stat .stat-label { font-size: 12px; color: var(--text-3); margin-top: 6px; position: relative; z-index: 1; }
 318: .stat .stat-delta { font-size: 11px; margin-top: 8px; color: var(--success); font-weight: 600; position: relative; z-index: 1; }


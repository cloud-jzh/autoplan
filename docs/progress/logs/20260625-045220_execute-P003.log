 699:               <div className="log-title-line">
 700:                 <h2>
 701:                   <span className={`live-dot${operationActive ? '' : ' idle'}`} /> {operationTitle}
 702:                 </h2>
 703:                 <span className="hint">{operationHint}</span>
 704:                 <span className={`log-phase-chip ${state?.running ? 'running' : 'stopped'}`}>
 705:                   {state?.running ? '循环运行中' : '循环已停止'} · {currentPhase}
 706:                 </span>
 707:               </div>
 708:               <div className="log-summary">
 709:                 <span>
 710:                   计划草稿 <b>{snapshot.planDrafts.length}</b>
 711:                 </span>
 712:                 <span>
 713:                   待确认草稿 <b>{snapshot.planDrafts.filter((draft) => draft.status !== 'accepted').length}</b>
 714:                 </span>
 715:                 <span>
 716:                   反馈 <b>{snapshot.feedback.length}</b>
 717:                 </span>
 718:               </div>
 719:             </div>
 720:             <CodexLog log={operation?.logTail || ''} activity={operation?.activity || []} />
 721:           </section>
 722:         </div>
 723: 
 724:         <div className="overview-side-column">
 725:           <section className="card">
 726:             <div className="card-head">
 727:               <h2>循环阶段流水线</h2>
 728:             </div>
 729:             <div className="card-body">
 730:               <div className="pipeline">
 731:                 {phases.map((phase, index) => {
 732:                   const done = activeIndex > index;
 733:                   const active = activeIndex === index;
 734:                   return (
 735:                     <div className={`pipe-step ${done ? 'done' : ''} ${active ? 'active' : ''}`} key={phase}>
 736:                       <div className="pipe-node">{done ? '✓' : active ? '▶' : index + 1}</div>
 737:                       <div className="pipe-label">{phaseLabel(phase)}</div>
 738:                     </div>
 739:                   );
 740:                 })}
 741:               </div>
 742:             </div>
 743:           </section>
 744: 
 745:           <section className="card">
 746:             <div className="card-head">
 747:               <h2>近期事件</h2>
 748:               <span className="spacer">
 749:                 <button type="button" className="btn-link" onClick={onGoTasks}>
 750:                   查看任务 →
 751:                 </button>
 752:               </span>
 753:             </div>
 754:             <div className="card-body">
 755:               <EventList events={snapshot.events.slice(0, 8)} />
 756:             </div>
 757:           </section>
 758:         </div>
 759:       </div>
 760:     </>
 761:   );
 762: }
 763: 
 764: function StatCard({
 765:   icon,
 766:   value,
 767:   label,
 768:   sub,
 769:   accent,
 770: }: {
 771:   icon: string;
 772:   value: string;
 773:   label: string;
 774:   sub?: string;
 775:   accent: 'brand' | 'info' | 'success' | 'warning';
 776: }) {
 777:   return (
 778:     <div className={`stat stat-${accent}`}>
 779:       <div className="stat-ico">{icon}</div>
 780:       <div className="stat-value">{value}</div>
 781:       <div className="stat-label">{label}</div>
 782:       {sub ? <div className="stat-delta">{sub}</div> : null}
 783:     </div>
 784:   );
 785: }
 786: 
 787: function tabTitle(tab: WorkspaceTab) {
 788:   return { overview: '概览', requirement: '需求模块', feedback: '反馈模块', tasks: '任务与计划', events: '事件流' }[tab];
 789: }

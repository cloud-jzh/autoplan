 612: function normalizeSearchQuery(value: string) {
 613:   return value.trim().toLowerCase().replace(/\s+/g, ' ');
 614: }
 615: 
 616: function countSearchableItems(snapshot: AppSnapshot) {
 617:   return (
 618:     snapshot.requirements.length +
 619:     snapshot.feedback.length +
 620:     snapshot.planDrafts.length +
 621:     snapshot.plans.length +
 622:     snapshot.tasks.length +
 623:     snapshot.events.length
 624:   );
 625: }
 626: 
 627: function countWorkspaceSearchMatches(snapshot: AppSnapshot, normalizedQuery: string) {
 628:   const groups: unknown[][] = [
 629:     snapshot.requirements,
 630:     snapshot.feedback,
 631:     snapshot.planDrafts,
 632:     snapshot.plans,
 633:     snapshot.tasks,
 634:     snapshot.events,
 635:   ];
 636: 
 637:   return groups.reduce(
 638:     (count, group) => count + group.filter((item) => normalizeSearchQuery(toSearchText(item)).includes(normalizedQuery)).length,
 639:     0,
 640:   );
 641: }
 642: 
 643: function toSearchText(value: unknown, depth = 0): string {
 644:   if (value === null || value === undefined || depth > 6) return '';
 645:   if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') return String(value);
 646:   if (Array.isArray(value)) return value.map((item) => toSearchText(item, depth + 1)).join(' ');
 647:   if (typeof value === 'object') {
 648:     return Object.values(value as Record<string, unknown>)
 649:       .map((item) => toSearchText(item, depth + 1))
 650:       .join(' ');
 651:   }
 652:   return '';
 653: }
 654: 
 655: function OverviewView({
 656:   snapshot,
 657:   state,
 658:   onGoTasks,
 659: }: {
 660:   snapshot: AppSnapshot;
 661:   state: ProjectState | null;
 662:   onGoTasks: () => void;
 663: }) {
 664:   const reqCount = snapshot.requirements.length;
 665:   const planCount = snapshot.plans.length;
 666:   const runningPlan = snapshot.plans.find((plan) => !['completed'].includes(plan.status));
 667:   const doneTasks = snapshot.tasks.filter((task) => task.status === 'completed').length;
 668:   const totalTasks = snapshot.tasks.length;
 669: 
 670:   const phases = ['scan', 'generate-plan', 'execute-task', 'validate', 'completed'];
 671:   const currentPhase = state?.phase || 'idle';
 672:   const activeIndex = phases.indexOf(currentPhase);
 673:   const operation = snapshot.activeOperation || snapshot.lastOperation;
 674:   const operationActive = Boolean(snapshot.activeOperation);
 675:   const operationTime = operation?.startedAt ? `开始于 ${formatChinaTime(operation.startedAt)}` : '';
 676:   const operationExit =
 677:     operation && !operationActive && typeof operation.exitCode === 'number'
 678:       ? ` · 退出码 ${operation.exitCode}${operation.exitCode === 0 ? '（成功）' : '（失败）'}`
 679:       : '';
 680:   const operationHint = operation ? `${operationTime}${operationExit}` : '等待下一次执行';
 681:   const operationTitle = operation ? `${operationActive ? '执行日志' : '最近执行'} · ${operation.label}` : '执行日志';
 682: 
 683:   return (
 684:     <>
 685:       <div className="stat-grid">
 686:         <StatCard icon="requirement" value={String(reqCount)} label="需求" accent="brand" />
 687:         <StatCard
 688:           icon="plan"
 689:           value={String(planCount)}
 690:           label="计划"
 691:           sub={runningPlan ? `${runningPlan.completed_tasks}/${runningPlan.total_tasks} 任务` : '无进行中'}
 692:           accent="info"
 693:         />
 694:         <StatCard icon="tasks" value={`${doneTasks}/${totalTasks}`} label="任务进度" accent="success" />
 695:         <StatCard icon="refresh" value={`${state?.interval_seconds || 5}s`} label="循环间隔" accent="warning" />
 696:       </div>
 697: 
 698:       <div className="overview-grid">
 699:         <div className="overview-main-column">
 700:           <section className="card live-log-card">

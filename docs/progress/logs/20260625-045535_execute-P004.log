+            if (event.key === 'Escape' && query) {
+              event.preventDefault();
+              onQueryChange('');
+            }
+          }}
+          placeholder="搜索需求、反馈、任务、Plan 或事件"
+          value={query}
+        />
+        {query ? (
+          <button
+            type="button"

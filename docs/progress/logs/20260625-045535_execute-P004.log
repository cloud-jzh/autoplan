   1: import { DragEvent, FormEvent, KeyboardEvent, useEffect, useRef, useState } from 'react';
   2: import type { IntakeType, PendingAttachment } from '../types';
   3: import { autoGrowTextarea, formatBytes, getFilePath } from './shared';
   4: 
   5: interface ComposerProps {
   6:   pendingAttachments: PendingAttachment[];
   7:   placeholder: string;
   8:   submitLabel: string;
   9:   type: IntakeType;
  10:   onAddFiles: (type: IntakeType, files: FileList | File[] | null) => void;
  11:   onRemoveAttachment: (type: IntakeType, index: number) => void;
  12:   onSubmit: (body: string) => Promise<boolean>;
  13: }
  14: 
  15: export function Composer({
  16:   pendingAttachments,
  17:   placeholder,
  18:   submitLabel,
  19:   type,
  20:   onAddFiles,
  21:   onRemoveAttachment,
  22:   onSubmit,
  23: }: ComposerProps) {
  24:   const [body, setBody] = useState('');
  25:   const [dragOver, setDragOver] = useState(false);
  26:   const fileInputRef = useRef<HTMLInputElement>(null);
  27:   const textareaRef = useRef<HTMLTextAreaElement>(null);
  28: 
  29:   useEffect(() => {
  30:     if (textareaRef.current) autoGrowTextarea(textareaRef.current);
  31:   }, [body]);
  32: 
  33:   const submit = async (event: FormEvent<HTMLFormElement>) => {
  34:     event.preventDefault();
  35:     if (!body.trim() && !pendingAttachments.length) return;
  36:     const succeeded = await onSubmit(body);
  37:     if (succeeded) setBody('');
  38:   };
  39: 
  40:   const addFiles = (files: FileList | File[] | null) => onAddFiles(type, files);
  41: 
  42:   const handleTextareaKeyDown = (event: KeyboardEvent<HTMLTextAreaElement>) => {
  43:     if (event.key !== 'Enter' || event.shiftKey || event.nativeEvent.isComposing) return;
  44:     event.preventDefault();
  45:     event.currentTarget.form?.requestSubmit();
  46:   };
  47: 
  48:   const clearDragState = (event: DragEvent<HTMLElement>) => {
  49:     const relatedTarget = event.relatedTarget as Node | null;
  50:     if (relatedTarget && event.currentTarget.contains(relatedTarget)) return;
  51:     setDragOver(false);
  52:   };
  53: 
  54:   return (
  55:     <form
  56:       className={`composer docked-composer compact-composer${dragOver ? ' drag-over' : ''}`}
  57:       onDragLeave={clearDragState}
  58:       onDragOver={(event) => {
  59:         event.preventDefault();
  60:         setDragOver(true);
  61:       }}
  62:       onDrop={(event) => {
  63:         event.preventDefault();
  64:         setDragOver(false);
  65:         addFiles(event.dataTransfer.files);
  66:       }}
  67:       onSubmit={submit}
  68:     >
  69:       <textarea
  70:         name="body"
  71:         onChange={(event) => setBody(event.target.value)}
  72:         onInput={(event) => autoGrowTextarea(event.currentTarget)}
  73:         onKeyDown={handleTextareaKeyDown}
  74:         placeholder={placeholder}
  75:         ref={textareaRef}
  76:         value={body}
  77:       />
  78:       <div className="composer-bottom">
  79:         <div className="composer-tools">
  80:           <div
  81:             className={`attachment-dropzone attachment-trigger${dragOver ? ' drag-over' : ''}`}
  82:             onClick={() => fileInputRef.current?.click()}
  83:             onKeyDown={(event) => {
  84:               if (event.key === 'Enter' || event.key === ' ') {
  85:                 event.preventDefault();
  86:                 fileInputRef.current?.click();
  87:               }
  88:             }}
  89:             role="button"
  90:             tabIndex={0}
  91:             title="添加附件"
  92:           >
  93:             <input
  94:               multiple
  95:               onChange={(event) => {
  96:                 addFiles(event.target.files);
  97:                 event.target.value = '';
  98:               }}
  99:               ref={fileInputRef}
 100:               type="file"
 101:             />
 102:             <span className="plus-icon">+</span>
 103:           </div>
 104:           <PendingAttachmentList
 105:             attachments={pendingAttachments}
 106:             onRemove={(index) => onRemoveAttachment(type, index)}
 107:           />
 108:         </div>
 109:         <div className="composer-actions">
 110:           <span>Enter 发送</span>
 111:           <button className="send-button" type="submit" aria-label={submitLabel}>
 112:             →
 113:           </button>
 114:         </div>
 115:       </div>
 116:     </form>
 117:   );
 118: }
 119: 
 120: function PendingAttachmentList({
 121:   attachments,
 122:   onRemove,
 123: }: {
 124:   attachments: PendingAttachment[];
 125:   onRemove: (index: number) => void;
 126: }) {
 127:   return (
 128:     <div className="attachment-list pending">
 129:       {attachments.map((attachment, index) => (
 130:         <div className="pending-attachment" key={`${attachment.path}-${attachment.size}`}>
 131:           <PendingAttachmentPreview attachment={attachment} />
 132:           <span title={attachment.name || attachment.path}>{attachment.name || attachment.path}</span>
 133:           <small>{formatBytes(attachment.size)}</small>
 134:           <button type="button" onClick={() => onRemove(index)}>
 135:             移除
 136:           </button>
 137:         </div>
 138:       ))}
 139:     </div>
 140:   );
 141: }
 142: 
 143: function PendingAttachmentPreview({ attachment }: { attachment: PendingAttachment }) {
 144:   if (!attachment.type.startsWith('image/')) {
 145:     return <span className="pending-file-icon">文件</span>;
 146:   }
 147:   return (
 148:     <img
 149:       className="pending-thumb"
 150:       src={window.autoplan.toFileUrl(attachment.path)}
 151:       alt={attachment.name || '附件'}
 152:     />
 153:   );
 154: }

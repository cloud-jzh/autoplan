from pathlib import Path
import re
roots = [Path('src/renderer'), Path('src/styles.css'), Path('ui')]
exts = {'.tsx', '.ts', '.css', '.html', '.md'}
pattern = re.compile(r'[\\U0001F000-\\U0001FAFF\\u2190-\\u21FF\\u2300-\\u23FF\\u25A0-\\u27BF]')
files = []
for root in roots:
    if root.is_file():
        files.append(root)
    elif root.is_dir():
        files.extend(p for p in root.rglob('*') if p.is_file() and p.suffix.lower() in exts)
seen = set()
findings = []
for path in sorted(files):
    if path in seen:
        continue
    seen.add(path)
    text = path.read_text(encoding='utf-8')
    for line_no, line in enumerate(text.splitlines(), 1):
        matches = pattern.findall(line)
        if matches:
            uniq = ''.join(dict.fromkeys(matches))
            context = line.strip()
            if len(context) > 180:
                context = context[:177] + '...'
            findings.append((str(path).replace('\\\\','/'), line_no, uniq, context))
if findings:

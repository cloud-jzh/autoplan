from pathlib import Path
import re
roots = [Path('src/renderer'), Path('src/styles.css'), Path('ui')]
exts = {'.tsx', '.ts', '.css', '.html', '.md'}
pattern = re.compile(r'[\\U0001F000-\\U0001FAFF\\u2190-\\u21FF\\u2300-\\u23FF\\u25A0-\\u27BF]')
files = []
for root in roots:
    if root.is_file():
        files.append(root)
    elif root.is_dir():
        files.extend(p for p in root.rglob('*') if p.is_file() and p.suffix.lower() in exts)
findings = []
for path in sorted(set(files)):
    text = path.read_text(encoding='utf-8')
    for line_no, line in enumerate(text.splitlines(), 1):
        matches = pattern.findall(line)
        if matches:
            context = line.strip()
            if len(context) > 140:
                context = context[:137] + '...'
            findings.append((str(path).replace('\\\\','/'), line_no, ''.join(dict.fromkeys(matches)), context))
if findings:
    print('Full scan non-scope/non-icon textual findings:')
    for item in findings:
        print(f'{item[0]}:{item[1]}: {item[2]} :: {item[3]}')
else:
    print('No emoji/symbol-range findings in src/renderer, src/styles.css, or ui.')

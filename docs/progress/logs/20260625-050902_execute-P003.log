+function shortCodexSessionId(sessionId) {
+  const normalized = normalizeCodexSessionId(sessionId);
+  if (normalized.length <= 13) return normalized || 'unknown';
+  return `${normalized.slice(0, 8)}…${normalized.slice(-4)}`;
+}

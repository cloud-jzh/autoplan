const assert = require('node:assert/strict');
const fs = require('node:fs');
const os = require('node:os');
const path = require('node:path');
const { AppDatabase, nowIso } = require('./src/database');
const { LoopService } = require('./src/loopService');

(async () => {
  const root = fs.mkdtempSync(path.join(os.tmpdir(), 'autoplan-p004-'));
  const workspace = path.join(root, 'workspace');
  fs.mkdirSync(path.join(workspace, 'docs', 'plan'), { recursive: true });
  fs.mkdirSync(path.join(workspace, 'docs', 'progress', 'logs'), { recursive: true });
  const planRel = path.join('docs', 'plan', 'p004.md');
  const planFile = path.join(workspace, planRel);
  fs.writeFileSync(planFile, '- [ ] P001: one\\n- [ ] P002: two\\n', 'utf8');

  const db = new AppDatabase(path.join(root, 'data', 'db.sqlite'));
  await db.init();
  const loop = new LoopService(db);
  const projectId = loop.defaultProjectId();
  db.run('UPDATE projects SET workspace_path = ?, updated_at = ? WHERE id = ?', [workspace, nowIso(), projectId]);
  const planId = db.insert('INSERT INTO plans (project_id, issue_hash, file_path, hash, status, total_tasks, completed_tasks, created_at, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)', [projectId, 'issue', planRel, 'hash', 'running', 2, 0, nowIso(), nowIso()]);
  const oldSession = '11111111-1111-4111-8111-111111111111';
  const firstTaskId = db.insert('INSERT INTO plan_tasks (plan_id, task_key, title, raw_line, scope, status, sort_order, codex_session_id, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?)', [planId, 'P001', 'one', '- [ ] P001: one <"'!-- scope: src/loopService.js -->'"', 'src/loopService.js', 'pending', 1, oldSession, nowIso()]);
  const secondTaskId = db.insert('INSERT INTO plan_tasks (plan_id, task_key, title, raw_line, scope, status, sort_order, updated_at) VALUES (?, ?, ?, ?, ?, ?, ?, ?)', [planId, 'P002', 'two', '- [ ] P002: two <"'!-- scope: src/loopService.js -->'"', 'src/loopService.js', 'pending', 2, nowIso()]);
  const plan = db.get('SELECT * FROM plans WHERE id = ?', [planId]);
  const firstTask = db.get('SELECT * FROM plan_tasks WHERE id = ?', [firstTaskId]);
  const secondTask = db.get('SELECT * FROM plan_tasks WHERE id = ?', [secondTaskId]);
  const seen = [];
  const returnedSession = '22222222-2222-4222-8222-222222222222';
  loop.runCodex = async (_workspace, _prompt, _label, operation) => {
    seen.push({ taskId: operation.taskId, session: operation.codexSessionId || null });
    return { exitCode: seen.length === 1 ? 1 : 0, logFile: path.join(workspace, 'docs', 'progress', 'logs', "'`run-${seen.length}.log`), sessionId: returnedSession };
  };

  await loop.executeTask(workspace, plan, firstTask);
  let storedFirst = db.get('"'SELECT * FROM plan_tasks WHERE id = ?', [firstTask.id]);
  assert.equal(seen[0].session, oldSession, '首次执行应传入已保存 session');
  assert.equal(storedFirst.codex_session_id, returnedSession, '失败后也应写回捕获 session');
  assert.equal(storedFirst.status, 'pending', '失败任务应回到 pending');

  await loop.executeTask(workspace, plan, storedFirst);
  storedFirst = db.get('SELECT * FROM plan_tasks WHERE id = ?', [firstTask.id]);
  assert.equal(seen[1].session, returnedSession, '重试应复用上次写回 session');
  assert.equal(storedFirst.codex_session_id, returnedSession, '重试后保留任务 session');

  await loop.executeTask(workspace, plan, secondTask);
  const storedSecond = db.get('SELECT * FROM plan_tasks WHERE id = ?', [secondTask.id]);
  assert.equal(seen[2].session, null, '不同任务不应继承其它任务 session');
  assert.equal(storedSecond.codex_session_id, returnedSession, '不同任务只写回自己的捕获 session');
  console.log('p004 lifecycle ok');
})().catch((error) => {
  console.error(error);
  process.exit(1);
});

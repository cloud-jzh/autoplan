+  }
+  if (mode === 'resume') return sessionShortId ? `恢复会话 ${sessionShortId}` : '恢复会话';
+  if (mode === 'new') return sessionShortId ? `新建会话 ${sessionShortId}` : '新建会话';
+  return sessionShortId ? `会话 ${sessionShortId}` : '';

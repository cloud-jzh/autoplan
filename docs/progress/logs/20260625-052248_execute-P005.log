+  const fallback = Boolean(source.codexSessionFallback);
+  const state = normalizeOptionalString(source.codexSessionState) || (fallback ? 'fallback-new' : mode);
+  const label = codexSessionReadableLabel({
+    codexSessionId: sessionId,

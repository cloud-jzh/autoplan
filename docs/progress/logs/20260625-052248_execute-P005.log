 1515:   meta.status = normalizeOptionalString(meta.status);
 1516:   meta.startedAt = normalizeOptionalString(meta.startedAt);
 1517:   meta.finishedAt = normalizeOptionalString(meta.finishedAt);
 1518:   meta.durationMs = normalizeOptionalNumber(meta.durationMs);
 1519:   meta.runDurationMs = normalizeOptionalNumber(meta.runDurationMs);
 1520:   const compacted = compactEventMeta(meta);
 1521:   return Object.keys(compacted).length ? compacted : null;
 1522: }
 1523: 
 1524: function taskEventMessage(type, task, meta = null) {
 1525:   const taskLabel = task?.task_key ? `${task.task_key} 任务` : task?.id ? `任务 #${task.id}` : '任务';
 1526:   const separator = taskLabel === '任务' ? '' : ' ';
 1527:   const taskTitle = normalizeOptionalString(task?.title) || '未命名任务';
 1528:   const action =
 1529:     {
 1530:       [TASK_EVENT_TYPES.STARTED]: '开始了',
 1531:       [TASK_EVENT_TYPES.SUCCEEDED]: '结束了',
 1532:       [TASK_EVENT_TYPES.FAILED]: '执行失败',
 1533:       [TASK_EVENT_TYPES.STOP_REQUESTED]: '请求停止',
 1534:       [TASK_EVENT_TYPES.STOPPED]: '停止了',
 1535:       [TASK_EVENT_TYPES.INTERRUPTED]: '中断了',
 1536:     }[type] || '更新了';
 1537:   const codexContext = codexSessionReadableLabel(meta);
 1538:   return `${action}${separator}${taskLabel}：${taskTitle}${codexContext ? `（${codexContext}）` : ''}`;
 1539: }
 1540: 
 1541: function markTaskLifecycleEventRecorded(error) {
 1542:   if (!error || (typeof error !== 'object' && typeof error !== 'function')) return;
 1543:   try {
 1544:     Object.defineProperty(error, TASK_LIFECYCLE_EVENT_RECORDED, { value: true });
 1545:   } catch {
 1546:     error[TASK_LIFECYCLE_EVENT_RECORDED] = true;
 1547:   }
 1548: }
 1549: 
 1550: function taskLifecycleEventRecorded(error) {
 1551:   return Boolean(error && (typeof error === 'object' || typeof error === 'function') && error[TASK_LIFECYCLE_EVENT_RECORDED]);
 1552: }
 1553: 
 1554: function syncedTaskStatus(parsedStatus, existingStatus) {
 1555:   const next = normalizeOptionalString(parsedStatus) || TASK_EVENT_STATUS.PENDING;
 1556:   const current = normalizeOptionalString(existingStatus);
 1557:   if (!current) return next;
 1558:   if (next === TASK_EVENT_STATUS.COMPLETED || current === TASK_EVENT_STATUS.COMPLETED) return TASK_EVENT_STATUS.COMPLETED;
 1559:   if (current === TASK_EVENT_STATUS.RUNNING || current === 'blocked') return current;
 1560:   return next;
 1561: }
 1562: 
 1563: function compactEventMeta(meta) {
 1564:   const result = {};
 1565:   for (const [key, value] of Object.entries(meta || {})) {
 1566:     if (value !== undefined && value !== null && value !== '') result[key] = value;
 1567:   }
 1568:   return result;
 1569: }
 1570: 
 1571: function normalizeOptionalNumber(value) {
 1572:   if (value === undefined || value === null || value === '') return undefined;
 1573:   const number = Number(value);
 1574:   return Number.isFinite(number) ? number : undefined;
 1575: }
 1576: 
 1577: function normalizeOptionalString(value) {
 1578:   if (value === undefined || value === null) return undefined;
 1579:   const text = String(value).trim();
 1580:   return text || undefined;
 1581: }
 1582: 
 1583: function withTaskDurationMeta(task, runDurationMs) {
 1584:   if (!task) return null;
 1585:   return {
 1586:     ...task,
 1587:     duration_ms: normalizeDurationMs(task.duration_ms),
 1588:     ...(runDurationMs !== undefined ? { run_duration_ms: normalizeDurationMs(runDurationMs) } : {}),
 1589:   };
 1590: }
 1591: 
 1592: function operationSnapshotRow(operation) {
 1593:   if (!operation) return null;
 1594:   const activity = Array.isArray(operation.activity)
 1595:     ? operation.activity
 1596:     : operation.activity && typeof operation.activity.getLines === 'function'
 1597:       ? operation.activity.getLines()
 1598:       : [];
 1599:   return {
 1600:     label: operation.label || '',
 1601:     projectId: operation.projectId || null,
 1602:     planId: operation.planId || null,
 1603:     taskId: operation.taskId || null,
 1604:     startedAt: operation.startedAt || null,
 1605:     ...(operation.finishedAt ? { finishedAt: operation.finishedAt } : {}),
 1606:     ...(typeof operation.exitCode === 'number' ? { exitCode: operation.exitCode } : {}),
 1607:     logTail: (operation.logBuffer || operation.logTail || '').slice(-8000),
 1608:     activity,
 1609:     ...codexSessionContextFields(operation),
 1610:   };
 1611: }
 1612: 
 1613: function runtimeCodexContextByTask(runtime, projectId) {
 1614:   const contexts = new Map();
 1615:   if (runtime?.lastOperation && Number(runtime.lastOperation.projectId) === Number(projectId) && runtime.lastOperation.taskId) {
 1616:     contexts.set(Number(runtime.lastOperation.taskId), codexSessionContextFields(runtime.lastOperation));
 1617:   }
 1618:   for (const operation of runtime?.activeOperations?.values?.() || []) {
 1619:     if (Number(operation.projectId) !== Number(projectId) || !operation.taskId) continue;
 1620:     contexts.set(Number(operation.taskId), codexSessionContextFields(operation));
 1621:   }
 1622:   return contexts;
 1623: }
 1624: 
 1625: function codexSessionContextFields(source = {}) {
 1626:   const sessionId = operationCodexSessionId(source);
 1627:   const requestedSessionId = normalizeCodexSessionId(source.codexSessionRequestedId ?? source.requestedSessionId);
 1628:   const mode = normalizeCodexSessionMode(source.codexSessionMode);
 1629:   const fallback = Boolean(source.codexSessionFallback);
 1630:   const state = normalizeOptionalString(source.codexSessionState) || (fallback ? 'fallback-new' : mode);
 1631:   const label = codexSessionReadableLabel({
 1632:     codexSessionId: sessionId,
 1633:     codexSessionRequestedId: requestedSessionId,
 1634:     codexSessionMode: mode,
 1635:     codexSessionState: state,
 1636:     codexSessionFallback: fallback,
 1637:   });
 1638:   return compactEventMeta({
 1639:     codexSessionId: sessionId || undefined,
 1640:     codexSessionShortId: sessionId ? shortCodexSessionId(sessionId) : undefined,
 1641:     codexSessionMode: mode || undefined,
 1642:     codexSessionState: state || undefined,
 1643:     codexSessionLabel: label || undefined,
 1644:     codexSessionRequestedId: requestedSessionId || undefined,
 1645:     codexSessionRequestedShortId: requestedSessionId ? shortCodexSessionId(requestedSessionId) : undefined,
 1646:     codexSessionFallback: fallback || undefined,
 1647:   });
 1648: }
 1649: 
 1650: function normalizeCodexSessionMode(mode) {
 1651:   const normalized = normalizeOptionalString(mode);
 1652:   if (normalized === 'new' || normalized === 'resume') return normalized;
 1653:   return undefined;
 1654: }
 1655: 
 1656: function codexSessionReadableLabel(source = {}) {
 1657:   const explicit = normalizeOptionalString(source.codexSessionLabel);
 1658:   if (explicit) return explicit;
 1659:   const sessionId = operationCodexSessionId(source);
 1660:   const requestedSessionId = normalizeCodexSessionId(source.codexSessionRequestedId ?? source.requestedSessionId);
 1661:   const sessionShortId = sessionId ? shortCodexSessionId(sessionId) : '';
 1662:   const requestedShortId = requestedSessionId ? shortCodexSessionId(requestedSessionId) : '';
 1663:   const mode = normalizeCodexSessionMode(source.codexSessionMode);
 1664:   const state = normalizeOptionalString(source.codexSessionState);
 1665:   if (state === 'fallback-new' || source.codexSessionFallback) {
 1666:     return requestedShortId ? `回退新建会话（原 ${requestedShortId}）` : '回退新建会话';
 1667:   }
 1668:   if (mode === 'resume') return sessionShortId ? `恢复会话 ${sessionShortId}` : '恢复会话';
 1669:   if (mode === 'new') return sessionShortId ? `新建会话 ${sessionShortId}` : '新建会话';
 1670:   return sessionShortId ? `会话 ${sessionShortId}` : '';
 1671: }
 1672: 
 1673: function taskSnapshotRow(task, codexContext = null) {
 1674:   if (!task) return task;
 1675:   const startedAt = normalizeOptionalString(task.started_at) || null;
 1676:   const finishedAt = normalizeOptionalString(task.finished_at) || null;
 1677:   const isRunning = task.status === TASK_EVENT_STATUS.RUNNING;
 1678:   const runDurationMs = isRunning ? taskRunDurationMs(startedAt, nowIso()) : undefined;
 1679:   const sessionContext = codexSessionContextFields({
 1680:     codexSessionId: codexContext?.codexSessionId ?? task.codex_session_id,
 1681:     codexSessionRequestedId: codexContext?.codexSessionRequestedId,
 1682:     codexSessionMode: codexContext?.codexSessionMode,
 1683:     codexSessionState: codexContext?.codexSessionState,
 1684:     codexSessionFallback: codexContext?.codexSessionFallback,
 1685:   });
 1686:   return {
 1687:     ...task,
 1688:     started_at: startedAt,
 1689:     finished_at: finishedAt,
 1690:     duration_ms: normalizeDurationMs(task.duration_ms),
 1691:     ...(runDurationMs !== undefined ? { run_duration_ms: normalizeDurationMs(runDurationMs) } : {}),
 1692:     ...sessionContext,
 1693:   };
 1694: }

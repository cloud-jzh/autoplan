   17: function isNearLogBottom(el: HTMLDivElement) {
   18:   const maxScrollTop = Math.max(0, el.scrollHeight - el.clientHeight);
   19:   return maxScrollTop - el.scrollTop <= LOG_BOTTOM_THRESHOLD_PX;
   20: }
   21: 
   22: /**
   23:  * 以活动时间线显示 codex 执行过程（参考 run_advanced_plan_with_codex.dart 的 Activity 输出）。
   24:  * 优先用过滤后的 activity 行；若为空则回退到 logTail 原始尾部。
   25:  */
   26: export function CodexLog({
   27:   log,
   28:   activity,
   29: }: {
   30:   log: string;
   31:   activity?: ActivityLine[];
   32: }) {
   33:   const scrollRef = useRef<HTMLDivElement>(null);
   34:   const isAtBottomRef = useRef(true);
   35:   const lines = activity && activity.length > 0 ? activity : null;
   36: 
   37:   const updateBottomState = () => {
   38:     const el = scrollRef.current;
   39:     isAtBottomRef.current = el ? isNearLogBottom(el) : true;
   40:   };
   41: 
   42:   useEffect(() => {
   43:     const el = scrollRef.current;
   44:     if (el) {
   45:       el.scrollTop = el.scrollHeight;
   46:       updateBottomState();
   47:     }
   48:   }, [log, activity]);
   49: 
   50:   if (!lines) {
   51:     return (
   52:       <div className="codex-log" ref={scrollRef} onScroll={updateBottomState}>
   53:         <pre className="codex-raw">{log ? log.slice(-4000) : '等待 Codex 输出…'}</pre>
   54:       </div>
   55:     );
   56:   }
   57: 
   58:   return (
   59:     <div className="codex-log" ref={scrollRef} onScroll={updateBottomState}>
   60:       {lines.map((line, index) => {
   61:         const config = ROLE_CONFIG[line.role] || { label: line.role || '信息', cls: 'act-info' };
   62:         return (
   63:           <div className={`act-line ${config.cls}`} key={index}>
   64:             <span className="act-time">{formatChinaTime(line.at)}</span>
   65:             <span className="act-tag">{config.label}</span>
   66:             <span className="act-text">{line.text}</span>
   67:           </div>
   68:         );
   69:       })}

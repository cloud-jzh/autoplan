   22: /**
   23:  * 以活动时间线显示 codex 执行过程（参考 run_advanced_plan_with_codex.dart 的 Activity 输出）。
   24:  * 优先用过滤后的 activity 行；若为空则回退到 logTail 原始尾部。
   25:  */
   26: export function CodexLog({
   27:   log,
   28:   activity,
   29:   context,
   30: }: {
   31:   log: string;
   32:   activity?: ActivityLine[];
   33:   context?: CodexSessionInfo | null;
   34: }) {
   35:   const scrollRef = useRef<HTMLDivElement>(null);
   36:   const isAtBottomRef = useRef(true);
   37:   const lines = activity && activity.length > 0 ? activity : null;
   38:   const contextLabel = codexContextLabel(context);
   39: 
   40:   const updateBottomState = () => {
   41:     const el = scrollRef.current;
   42:     isAtBottomRef.current = el ? isNearLogBottom(el) : true;
   43:   };
   44: 
   45:   useEffect(() => {
   46:     const el = scrollRef.current;
   47:     if (el) {
   48:       el.scrollTop = el.scrollHeight;
   49:       updateBottomState();
   50:     }
   51:   }, [log, activity, contextLabel]);
   52: 
   53:   const contextLine = contextLabel ? (
   54:     <div className="act-line act-info">
   55:       <span className="act-time">上下文</span>
   56:       <span className="act-tag">会话</span>
   57:       <span className="act-text">{contextLabel}</span>
   58:     </div>
   59:   ) : null;
   60: 
   61:   if (!lines) {
   62:     return (
   63:       <div className="codex-log" ref={scrollRef} onScroll={updateBottomState}>
   64:         {contextLine}
   65:         <pre className="codex-raw">{log ? log.slice(-4000) : '等待 Codex 输出…'}</pre>
   66:       </div>
   67:     );
   68:   }
   69: 
   70:   return (
   71:     <div className="codex-log" ref={scrollRef} onScroll={updateBottomState}>
   72:       {contextLine}
   73:       {lines.map((line, index) => {
   74:         const config = ROLE_CONFIG[line.role] || { label: line.role || '信息', cls: 'act-info' };
   75:         return (
   76:           <div className={`act-line ${config.cls}`} key={index}>
   77:             <span className="act-time">{formatChinaTime(line.at)}</span>
   78:             <span className="act-tag">{config.label}</span>
   79:             <span className="act-text">{line.text}</span>
   80:           </div>
   81:         );
   82:       })}
   83:     </div>
   84:   );
   85: }
   86: 
   87: function codexContextLabel(context?: CodexSessionInfo | null) {
   88:   if (!context) return '';
   89:   const explicit = context.codexSessionLabel?.trim();
   90:   if (explicit) return explicit;
   91:   const requested = context.codexSessionRequestedShortId || shortCodexSessionId(context.codexSessionRequestedId);
   92:   const current = context.codexSessionShortId || shortCodexSessionId(context.codexSessionId);
   93:   if (context.codexSessionFallback || context.codexSessionState === 'fallback-new') {
   94:     return requested ? `回退新建会话（原 ${requested}）` : '回退新建会话';
   95:   }
   96:   if (context.codexSessionMode === 'resume') return current ? `恢复会话 ${current}` : '恢复会话';
   97:   if (context.codexSessionMode === 'new') return current ? `新建会话 ${current}` : '新建会话';
   98:   return current ? `会话 ${current}` : '';
   99: }
  100: 
  101: function shortCodexSessionId(sessionId?: string | null) {
  102:   const text = sessionId?.trim();
  103:   if (!text) return '';
  104:   if (text.length <= 13) return text;
  105:   return `${text.slice(0, 8)}…${text.slice(-4)}`;
  106: }


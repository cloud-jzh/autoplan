 315:   const id = db.insert(
 316:     `INSERT INTO projects (name, workspace_path, description, created_at, updated_at)
 317:      VALUES (?, ?, ?, ?, ?)`,
 318:     [name, workspacePath, '', now, now],
 319:   );
 320:   loop.ensureProjectState(id);
 321:   return id;
 322: }

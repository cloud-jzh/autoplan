+      assert.equal(operation.parallel, true, '并发执行 operation 应标记 parallel');
+      assert.equal(operation.codexSessionId, undefined, '同一 plan 的不同任务首次执行不应复用其它 session id');
+      seenParallelTaskIds.add(operation.taskId);

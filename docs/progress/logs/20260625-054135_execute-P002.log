+  const leftUpdatedAt = getTimestampMs(left.updatedAt);
+  const rightUpdatedAt = getTimestampMs(right.updatedAt);
+  if (leftUpdatedAt !== rightUpdatedAt) return rightUpdatedAt - leftUpdatedAt;

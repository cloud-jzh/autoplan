+function pushSearchField(
+  fields: WorkspaceSearchField[],
+  field: WorkspaceSearchHitField,
+  label: string,
+  value: unknown,
+) {
+  const text = toSearchText(value);
+  if (!text) return;
+
+  fields.push({
+    field,
+    label,
+    value: text,
+    priority: getSearchFieldPriority(field),
+  });
+}

+  }
+
+  return meta as Record<string, unknown>;
+}
+
+function stringifySearchMeta(meta: unknown) {
+  if (meta === null || typeof meta === 'undefined') return '';
+  if (typeof meta === 'string') return meta;
+
+  try {
+    return JSON.stringify(meta);
+  } catch {
+    return String(meta);
+  }
+}

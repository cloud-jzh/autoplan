 167: function formatEvent(event: AppEvent): TaskEventDisplay {
 168:   const meta = readEventMeta(event);
 169:   const taskDisplay = meta && (isTaskEventType(event.type) || readMetaText(meta, ['taskKey', 'task_key', 'taskId', 'task_id']))
 170:     ? formatTaskEvent(event, meta)
 171:     : null;
 172:   if (taskDisplay) return taskDisplay;
 173: 
 174:   return {
 175:     title: event.type || '事件',
 176:     body: event.message || '',
 177:     meta: formatChinaDateTime(event.created_at),
 178:   };
 179: }
 180: 
 181: function toSearchText(value: unknown, depth = 0): string {
 182:   if (value === null || value === undefined || depth > 6) return '';
 183:   if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') return String(value);
 184:   if (Array.isArray(value)) return value.map((item) => toSearchText(item, depth + 1)).join(' ');
 185:   if (typeof value === 'object') {
 186:     return Object.values(value as Record<string, unknown>)
 187:       .map((item) => toSearchText(item, depth + 1))
 188:       .join(' ');
 189:   }
 190:   return '';
 191: }
 192: 
 193: export function getEventSearchText(event: AppEvent) {
 194:   const display = formatEvent(event);
 195:   const meta = readEventMeta(event);
 196:   return [
 197:     event.type,
 198:     event.message,
 199:     display.title,
 200:     display.body,
 201:     display.badge,
 202:     display.meta,
 203:     toSearchText(meta),
 204:   ]
 205:     .filter(Boolean)
 206:     .join(' ');
 207: }

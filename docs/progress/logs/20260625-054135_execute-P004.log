   5: type TimedPlanTask = PlanTask & {
   6:   plan_id?: number | null;
   7:   started_at?: string | null;
   8:   finished_at?: string | null;
   9:   duration_ms?: number | null;
  10: };
  11: 
  12: type EventMetaRecord = Record<string, unknown>;
  13: 
  14: type TaskEventTone = 'start' | 'success' | 'failed' | 'stopped' | 'stopping' | 'updated';
  15: 
  16: type TaskEventDisplay = {
  17:   title: string;
  18:   body: string;
  19:   meta: string;
  20:   badge?: string;
  21:   tone?: TaskEventTone;
  22: };
  23: 
  24: const TASK_EVENT_PRESENTATION: Record<TaskEventTone, { action: string; badge: string }> = {
  25:   start: { action: '开始了', badge: '开始' },
  26:   success: { action: '结束了', badge: '成功' },
  27:   failed: { action: '执行失败', badge: '失败' },
  28:   stopped: { action: '停止了', badge: '停止' },
  29:   stopping: { action: '请求停止', badge: '停止中' },
  30:   updated: { action: '更新了', badge: '任务' },
  31: };
  32: 
  33: function readDurationMs(task: TimedPlanTask) {
  34:   if (task.duration_ms === null || typeof task.duration_ms === 'undefined') return null;
  35:   const duration = Number(task.duration_ms);
  36:   return Number.isFinite(duration) && duration >= 0 ? duration : null;
  37: }
  38: 
  39: function getTaskDurationMs(task: TimedPlanTask) {
  40:   if (task.status === 'running') return getRunningDurationMs(readDurationMs(task), task.started_at);
  41:   return readDurationMs(task);
  42: }
  43: 
  44: function readPlanId(task: TimedPlanTask) {
  45:   if (task.plan_id === null || typeof task.plan_id === 'undefined') return null;
  46:   const planId = Number(task.plan_id);
  47:   return Number.isFinite(planId) ? planId : null;
  48: }
  49: 
  50: function formatTaskDuration(task: TimedPlanTask) {
  51:   const duration = getTaskDurationMs(task);
  52:   if (task.status === 'running') return `已运行 ${formatDuration(duration, '0秒')}`;
  53:   if (duration === null || (duration === 0 && !task.started_at && !task.finished_at)) return '未开始';
  54:   return `耗时 ${formatDuration(duration, '0秒')}`;
  55: }
  56: 
  57: function tasksForPlan(tasks: PlanTask[], plan: Plan, planCount: number) {
  58:   const timedTasks = tasks as TimedPlanTask[];
  59:   const hasPlanIds = timedTasks.some((task) => readPlanId(task) !== null);
  60:   if (!hasPlanIds) return planCount === 1 ? timedTasks : [];
  61:   return timedTasks.filter((task) => readPlanId(task) === plan.id);
  62: }
  63: 
  64: function formatPlanDurationSummary(tasks: TimedPlanTask[]) {
  65:   const totalMs = tasks.reduce((sum, task) => sum + (getTaskDurationMs(task) ?? 0), 0);
  66:   const completedMs = tasks.reduce(
  67:     (sum, task) => sum + (task.status === 'completed' ? getTaskDurationMs(task) ?? 0 : 0),
  68:     0,
  69:   );
  70: 
  71:   return `总耗时 ${formatDuration(totalMs, '0秒')} · 已完成 ${formatDuration(completedMs, '0秒')}`;
  72: }
  73: 
  74: function toEventMetaRecord(value: unknown): EventMetaRecord | null {
  75:   if (!value) return null;
  76:   if (typeof value === 'string') {
  77:     try {
  78:       return toEventMetaRecord(JSON.parse(value));
  79:     } catch {
  80:       return null;
  81:     }
  82:   }
  83:   if (typeof value === 'object' && !Array.isArray(value)) return value as EventMetaRecord;
  84:   return null;
  85: }
  86: 
  87: function readEventMeta(event: AppEvent) {
  88:   return toEventMetaRecord((event as AppEvent & { meta?: unknown }).meta);
  89: }
  90: 
  91: function readMetaText(meta: EventMetaRecord | null, keys: string[]) {
  92:   if (!meta) return '';
  93:   for (const key of keys) {
  94:     const value = meta[key];
  95:     if (typeof value === 'string') {
  96:       const text = value.trim();
  97:       if (text) return text;
  98:     }
  99:     if (typeof value === 'number' && Number.isFinite(value)) return String(value);
 100:   }
 101:   return '';
 102: }
 103: 
 104: function readMetaNumber(meta: EventMetaRecord | null, keys: string[]) {
 105:   const text = readMetaText(meta, keys);
 106:   if (!text) return null;
 107:   const value = Number(text);
 108:   return Number.isFinite(value) ? value : null;
 109: }
 110: 
 111: function includesAny(text: string, keywords: string[]) {
 112:   return keywords.some((keyword) => text.includes(keyword));
 113: }
 114: 
 115: function classifyTaskEvent(event: AppEvent, meta: EventMetaRecord | null): TaskEventTone {
 116:   const eventText = `${event.type || ''} ${readMetaText(meta, ['status', 'taskStatus', 'task_status'])}`.toLowerCase();
 117:   if (includesAny(eventText, ['stop_requested', 'stop-requested', 'stop.requested', 'request_stop', 'stopping'])) {
 118:     return 'stopping';
 119:   }
 120:   if (includesAny(eventText, ['fail', 'error', 'errored'])) return 'failed';
 121:   if (includesAny(eventText, ['stop', 'interrupt', 'cancel'])) return 'stopped';
 122:   if (includesAny(eventText, ['start', 'begin', 'running'])) return 'start';
 123:   if (includesAny(eventText, ['complete', 'finish', 'success', 'succeed', 'executed', 'done'])) return 'success';
 124:   return 'updated';
 125: }
 126: 
 127: function isTaskEventType(type: string) {
 128:   return /^task[.:_-]/i.test(type);
 129: }
 130: 
 131: function sameEventText(left: string, right: string) {
 132:   return left.replace(/\s+/g, ' ').trim() === right.replace(/\s+/g, ' ').trim();
 133: }
 134: 
 135: function formatTaskEvent(event: AppEvent, meta: EventMetaRecord): TaskEventDisplay | null {
 136:   const taskKey = readMetaText(meta, ['taskKey', 'task_key']);
 137:   const taskId = readMetaText(meta, ['taskId', 'task_id']);
 138:   const taskTitle = readMetaText(meta, ['taskTitle', 'task_title', 'title']) || '未命名任务';
 139:   const hasTaskIdentity = Boolean(taskKey || taskId || readMetaText(meta, ['taskTitle', 'task_title', 'title']));
 140:   if (!hasTaskIdentity) return null;
 141: 
 142:   const tone = classifyTaskEvent(event, meta);
 143:   const presentation = TASK_EVENT_PRESENTATION[tone];
 144:   const taskLabel = taskKey ? `${taskKey} 任务` : taskId ? `任务 #${taskId}` : '任务';
 145:   const separator = taskLabel === '任务' ? '' : ' ';
 146:   const title = `${presentation.action}${separator}${taskLabel}：${taskTitle}`;
 147:   const originalMessage = event.message?.trim() || '';
 148:   const planId = readMetaText(meta, ['planId', 'plan_id']);
 149:   const status = readMetaText(meta, ['status', 'taskStatus', 'task_status']);
 150:   const durationMs = readMetaNumber(meta, ['durationMs', 'duration_ms']);
 151:   const metaParts = [
 152:     formatChinaDateTime(event.created_at),
 153:     planId ? `Plan #${planId}` : '',
 154:     status ? `状态 ${status}` : '',
 155:     durationMs !== null ? `耗时 ${formatDuration(durationMs, '0秒')}` : '',
 156:   ].filter(Boolean);
 157: 
 158:   return {
 159:     title,
 160:     body: originalMessage && !sameEventText(originalMessage, title) ? originalMessage : '',
 161:     meta: metaParts.join(' · '),
 162:     badge: presentation.badge,
 163:     tone,
 164:   };
 165: }
 166: 
 167: function formatEvent(event: AppEvent): TaskEventDisplay {
 168:   const meta = readEventMeta(event);
 169:   const taskDisplay = meta && (isTaskEventType(event.type) || readMetaText(meta, ['taskKey', 'task_key', 'taskId', 'task_id']))
 170:     ? formatTaskEvent(event, meta)
 171:     : null;
 172:   if (taskDisplay) return taskDisplay;
 173: 
 174:   return {
 175:     title: event.type || '事件',
 176:     body: event.message || '',
 177:     meta: formatChinaDateTime(event.created_at),
 178:   };
 179: }

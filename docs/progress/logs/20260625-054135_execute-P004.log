 237:               </span>
 238:               <span className={`chip ${accepted ? 'chip-accepted' : 'chip-waiting'}`}>{draft.status}</span>
 239:             </div>
 240:             <textarea
 241:               readOnly={accepted}
 242:               value={draftTextById[draft.id] ?? draft.markdown ?? ''}
 243:               onChange={(event) => onChange(draft.id, event.target.value)}
 244:             />
 245:             <div className="button-row">
 246:               {accepted ? (
 247:                 <span className="draft-note">已加入任务系统：Plan #{draft.linked_plan_id || ''}</span>
 248:               ) : (
 249:                 <>
 250:                   <button type="button" onClick={() => onSave(draft)}>
 251:                     保存调整
 252:                   </button>
 253:                   {onAccept ? (
 254:                     <button className="btn-primary" type="button" onClick={() => onAccept(draft)}>
 255:                       确认加入任务系统
 256:                     </button>
 257:                   ) : null}
 258:                 </>
 259:               )}
 260:             </div>
 261:           </article>
 262:         );
 263:       })}
 264:     </div>
 265:   );
 266: }

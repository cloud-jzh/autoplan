 284:                   停止
 285:                 </button>
 286:               </div>
 287:             }
 288:             key={task.id}
 289:             title={task.title}
 290:             status={task.status}
 291:             body={task.file_path}
 292:             meta={`${task.task_key} · ${durationLabel} · ${formatChinaDateTime(task.updated_at)}`}
 293:           />
 294:         );
 295:       })}
 296:     </div>
 297:   );
 298: }

+
+function filterWorkspaceItems<T>(items: T[], normalizedQuery: string, getSearchText: (item: T) => string = toSearchText) {
+  if (!normalizedQuery) return items;
+  return items.filter((item) => normalizeSearchQuery(getSearchText(item)).includes(normalizedQuery));
+}

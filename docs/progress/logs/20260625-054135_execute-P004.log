 268: export function PlanList({
 269:   emptyText = '暂无 plan。',
 270:   plans,
 271:   tasks = [],
 272:   totalPlanCount = plans.length,
 273: }: {
 274:   emptyText?: string;
 275:   plans: Plan[];
 276:   tasks?: PlanTask[];
 277:   totalPlanCount?: number;
 278: }) {
 279:   if (!plans.length) return <div className="empty">{emptyText}</div>;
 280: 
 281:   return (
 282:     <div className="list compact">
 283:       {plans.map((plan) => {
 284:         const durationSummary = formatPlanDurationSummary(tasksForPlan(tasks, plan, totalPlanCount));
 285:         return (
 286:           <RecordCard
 287:             key={plan.id}
 288:             title={plan.file_path}
 289:             status={plan.status}
 290:             body={`${plan.completed_tasks}/${plan.total_tasks} tasks · ${durationSummary} · validation ${
 291:               plan.validation_passed ? 'passed' : 'pending'
 292:             }`}
 293:             meta={`${plan.hash?.slice(0, 12) || ''} · ${formatChinaDateTime(plan.updated_at)}`}
 294:           />
 295:         );
 296:       })}
 297:     </div>
 298:   );
 299: }

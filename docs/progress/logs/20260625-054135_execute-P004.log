 310:   if (['running', 'processing'].includes(s)) return 'chip-running';
 311:   return 'chip-waiting';
 312: }
 313: 
 314: function planChipClass(planStatus: string) {
 315:   const s = String(planStatus || '').toLowerCase();
 316:   if (s === 'completed') return 'chip-completed';
 317:   if (s === 'interrupted') return 'chip-failed';
 318:   if (s === 'validation_failed') return 'chip-failed';
 319:   if (['pending', 'running', 'generate-plan', 'execute-task', 'validate', 'scan'].includes(s)) return 'chip-running';
 320:   return 'chip-waiting';


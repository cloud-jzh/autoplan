+function countWorkspaceSearchMatches(snapshot: AppSnapshot, normalizedQuery: string) {
+  return (
+    filterWorkspaceItems(snapshot.requirements, normalizedQuery).length +
+    filterWorkspaceItems(snapshot.feedback, normalizedQuery).length +
+    filterWorkspaceItems(snapshot.planDrafts, normalizedQuery).length +

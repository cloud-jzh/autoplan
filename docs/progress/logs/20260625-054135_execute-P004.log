 613: 
 614: function normalizeSearchQuery(value: string) {
 615:   return value.trim().toLowerCase().replace(/\s+/g, ' ');
 616: }
 617: 
 618: function countSearchableItems(snapshot: AppSnapshot) {
 619:   return (
 620:     snapshot.requirements.length +
 621:     snapshot.feedback.length +
 622:     snapshot.planDrafts.length +
 623:     snapshot.plans.length +
 624:     snapshot.tasks.length +
 625:     snapshot.events.length
 626:   );
 627: }
 628: 
 629: function countWorkspaceSearchMatches(snapshot: AppSnapshot, normalizedQuery: string) {
 630:   const groups: unknown[][] = [
 631:     snapshot.requirements,
 632:     snapshot.feedback,
 633:     snapshot.planDrafts,
 634:     snapshot.plans,
 635:     snapshot.tasks,
 636:     snapshot.events,
 637:   ];
 638: 
 639:   return groups.reduce(
 640:     (count, group) => count + group.filter((item) => normalizeSearchQuery(toSearchText(item)).includes(normalizedQuery)).length,
 641:     0,
 642:   );
 643: }
 644: 
 645: function toSearchText(value: unknown, depth = 0): string {
 646:   if (value === null || value === undefined || depth > 6) return '';
 647:   if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') return String(value);
 648:   if (Array.isArray(value)) return value.map((item) => toSearchText(item, depth + 1)).join(' ');
 649:   if (typeof value === 'object') {
 650:     return Object.values(value as Record<string, unknown>)
 651:       .map((item) => toSearchText(item, depth + 1))
 652:       .join(' ');
 653:   }
 654:   return '';
 655: }

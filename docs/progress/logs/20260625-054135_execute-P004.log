 236: export function PlanList({ plans, tasks = [] }: { plans: Plan[]; tasks?: PlanTask[] }) {
 237:   if (!plans.length) return <div className="empty">暂无 plan。</div>;
 238: 
 239:   return (
 240:     <div className="list compact">
 241:       {plans.map((plan) => {
 242:         const durationSummary = formatPlanDurationSummary(tasksForPlan(tasks, plan, plans.length));
 243:         return (
 244:           <RecordCard
 245:             key={plan.id}
 246:             title={plan.file_path}
 247:             status={plan.status}
 248:             body={`${plan.completed_tasks}/${plan.total_tasks} tasks · ${durationSummary} · validation ${
 249:               plan.validation_passed ? 'passed' : 'pending'
 250:             }`}
 251:             meta={`${plan.hash?.slice(0, 12) || ''} · ${formatChinaDateTime(plan.updated_at)}`}
 252:           />
 253:         );
 254:       })}
 255:     </div>
 256:   );
 257: }

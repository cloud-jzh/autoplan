 301: export function TaskList({
 302:   emptyText = '暂无任务。',
 303:   tasks,
 304:   onRun,
 305:   onStop,
 306: }: {
 307:   emptyText?: string;
 308:   tasks: PlanTask[];
 309:   onRun?: (task: PlanTask) => void;
 310:   onStop?: (task: PlanTask) => void;
 311: }) {
 312:   if (!tasks.length) return <div className="empty">{emptyText}</div>;
 313: 
 314:   return (
 315:     <div className="list compact">
 316:       {tasks.map((task) => {
 317:         const running = task.status === 'running';
 318:         const completed = task.status === 'completed';
 319:         const durationLabel = formatTaskDuration(task as TimedPlanTask);
 320:         return (
 321:           <RecordCard
 322:             actions={
 323:               <div className="item-actions">
 324:                 <button type="button" className="btn-link" disabled={completed || running} onClick={() => onRun?.(task)}>
 325:                   执行
 326:                 </button>
 327:                 <button type="button" className="btn-link danger-link" disabled={!running} onClick={() => onStop?.(task)}>
 328:                   停止
 329:                 </button>
 330:               </div>


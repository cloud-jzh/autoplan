+.search-source-chip:hover:not(:disabled) { background: var(--brand-50); border-color: #cdd8ea; color: var(--brand-700); }
+.search-source-chip:disabled { cursor: default; color: var(--text-4); }
+.search-source-chip:disabled b { color: var(--text-4); }
+.search-results-body { max-height: min(420px, 42vh); overflow: auto; padding: 14px 16px 16px; }
+.search-result-groups { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 12px; }
+.search-result-group { min-width: 0; display: flex; flex-direction: column; gap: 10px; padding: 12px; border: 1px solid var(--line-soft); border-radius: var(--r-md); background: var(--bg-soft); }
+.search-result-group.is-empty { color: var(--text-4); }
+.search-result-group-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
+.search-result-group-title { display: inline-flex; align-items: center; gap: 8px; min-width: 0; color: var(--text-1); font-size: 13px; font-weight: 750; }
+.search-result-group-title span { min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+.search-result-group-count { flex: 0 0 auto; color: var(--text-3); font-size: 12px; font-weight: 700; }
+.search-result-items { display: grid; gap: 8px; }
+.search-result-item { width: 100%; min-width: 0; display: grid; gap: 7px; padding: 10px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--text-1); text-align: left; transition: background 0.14s, border-color 0.14s, transform 0.06s; }
+.search-result-item:hover { background: #fff; border-color: #cdd8ea; }
+.search-result-item:active { transform: translateY(1px); }
+.search-result-item:focus-visible { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
+.search-result-item-top { display: flex; align-items: center; gap: 8px; min-width: 0; }
+.search-result-title { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 13px; font-weight: 700; }
+.search-result-status { flex: 0 0 auto; max-width: 42%; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; padding: 2px 7px; border-radius: 999px; background: var(--brand-50); color: var(--brand-700); font-size: 11px; font-weight: 750; }

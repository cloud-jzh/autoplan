 191: export function searchWorkspaceSnapshot(
 192:   snapshot: AppSnapshot | null | undefined,
 193:   queryInput: string | WorkspaceSearchQuery | null | undefined,
 194: ): WorkspaceSearchState {
 195:   const query = resolveWorkspaceSearchQuery(queryInput);
 196:   if (!snapshot || query.isEmpty) {
 197:     return createWorkspaceSearchStateFromResults(query, []);
 198:   }
 199: 
 200:   const attachmentLookup = createAttachmentLookup(snapshot.attachments ?? []);
 201:   const candidates: WorkspaceSearchCandidate[] = [
 202:     ...(snapshot.requirements ?? []).map((requirement) =>
 203:       createRequirementCandidate(
 204:         requirement,
 205:         getOwnerAttachments(attachmentLookup, 'requirement', requirement.id),
 206:       ),
 207:     ),
 208:     ...(snapshot.feedback ?? []).map((feedback) =>
 209:       createFeedbackCandidate(feedback, getOwnerAttachments(attachmentLookup, 'feedback', feedback.id)),
 210:     ),
 211:     ...(snapshot.planDrafts ?? []).map(createPlanDraftCandidate),
 212:     ...(snapshot.plans ?? []).map(createPlanCandidate),
 213:     ...(snapshot.tasks ?? []).map(createTaskCandidate),
 214:     ...(snapshot.events ?? []).map(createEventCandidate),
 215:   ];
 216: 
 217:   const rankedResults = candidates
 218:     .map((candidate) => createRankedWorkspaceSearchResult(candidate, query))
 219:     .filter((result): result is RankedWorkspaceSearchResult => result !== null)
 220:     .sort(compareRankedWorkspaceSearchResults);
 221:   const results = rankedResults.map(({ result }) => result);
 222: 
 223:   return createWorkspaceSearchStateFromResults(query, results);
 224: }

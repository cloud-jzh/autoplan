 206: .app-header { display: flex; align-items: center; justify-content: space-between; padding: 18px 32px; background: var(--bg-elevated); border-bottom: 1px solid var(--line); }
 207: .app-header .brand { display: flex; align-items: center; gap: 12px; }
 208: .brand-mark { display: grid; place-items: center; width: 40px; height: 40px; border-radius: 12px; background: var(--brand-grad); color: #fff; font-weight: 800; font-size: 18px; box-shadow: 0 8px 18px rgba(77, 110, 255, 0.35); }
 209: .app-header h1 { font-size: 17px; font-weight: 700; }
 210: .app-header p { font-size: 11px; color: var(--text-3); margin-top: 2px; }
 211: .header-actions { display: flex; align-items: center; gap: 10px; }
 212: .projects-main { height: calc(100vh - 77px); overflow: auto; padding: 28px 32px 48px; }
 213: .projects-hero { display: flex; align-items: flex-end; gap: 20px; flex-wrap: wrap; margin-bottom: 22px; }
 214: .projects-hero h2 { font-size: 24px; font-weight: 800; }
 215: .projects-hero p { font-size: 13px; color: var(--text-3); margin-top: 6px; }
 216: .hero-stats { margin-left: auto; display: flex; gap: 24px; }
 217: .hero-stat { text-align: right; }
 218: .hero-stat b { display: block; font-size: 22px; font-weight: 800; color: var(--text-1); }
 219: .hero-stat span { font-size: 11px; color: var(--text-3); }
 220: .projects-toolbar { margin-bottom: 20px; }
 221: .search-input { width: 100%; max-width: 400px; padding: 10px 14px; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-elevated); font: inherit; font-size: 13px; }
 222: .search-input:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
 223: .project-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }
 224: .project-card { position: relative; background: var(--bg-elevated); border: 1px solid var(--line); border-radius: var(--r-lg); padding: 18px; box-shadow: var(--shadow-sm); cursor: pointer; transition: transform 0.14s, box-shadow 0.14s, border-color 0.14s; }
 225: .project-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); border-color: #cdd8ea; }
 226: .project-card-top { display: flex; align-items: flex-start; gap: 12px; }
 227: .project-avatar { width: 44px; height: 44px; flex: 0 0 auto; border-radius: 12px; background: var(--brand-grad); color: #fff; font-weight: 700; font-size: 18px; display: grid; place-items: center; }
 228: .project-info { min-width: 0; flex: 1 1 auto; }
 229: .project-name { font-size: 15px; font-weight: 700; color: var(--text-1); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
 230: .project-path { font-size: 11.5px; color: var(--text-3); margin-top: 3px; font-family: var(--font-mono); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
 231: .project-card-menu { flex: 0 0 auto; }
 232: .ctx-details { position: relative; }
 233: .ctx-details > summary { list-style: none; width: 30px; height: 30px; border-radius: 8px; display: grid; place-items: center; color: var(--text-3); line-height: 1; cursor: pointer; }
 234: .ctx-details > summary::-webkit-details-marker { display: none; }
 235: .ctx-details > summary:hover { background: var(--bg-hover); color: var(--text-1); }

 429: function pushAttachmentFields(fields: WorkspaceSearchField[], attachments: readonly AttachmentRecord[]) {
 430:   attachments.forEach((attachment) => {
 431:     pushSearchField(fields, WORKSPACE_SEARCH_HIT_FIELDS.FILE_PATH, '附件名称', attachment.original_name);
 432:     pushSearchField(fields, WORKSPACE_SEARCH_HIT_FIELDS.FILE_PATH, '附件路径', attachment.stored_path);
 433:   });
 434: }

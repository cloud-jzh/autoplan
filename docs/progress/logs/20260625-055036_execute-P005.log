 368: function createRankedWorkspaceSearchResult(
 369:   candidate: WorkspaceSearchCandidate,
 370:   query: WorkspaceSearchQuery,
 371: ): RankedWorkspaceSearchResult | null {
 372:   const searchableText = candidate.fields.map((field) => field.value.toLowerCase()).join(' ');
 373:   if (!doesTextMatchQuery(searchableText, query)) {
 374:     return null;
 375:   }
 376: 
 377:   const matches = candidate.fields
 378:     .filter((field) => doesFieldMatchQuery(field, query))
 379:     .map((field): WorkspaceSearchMatch => ({
 380:       field: field.field,
 381:       label: field.label,
 382:       value: field.value,
 383:       snippet: createSearchSnippet(field.value, query),
 384:     }));
 385:   if (matches.length === 0) {
 386:     return null;
 387:   }
 388: 
 389:   const priority = matches.reduce(
 390:     (best, match) => Math.min(best, getSearchFieldPriority(match.field)),
 391:     FALLBACK_SEARCH_PRIORITY,
 392:   );
 393:   const updatedAtMs = getTimestampMs(candidate.updatedAt);
 394: 
 395:   return {
 396:     priority,
 397:     updatedAtMs,
 398:     result: {
 399:       id: `${candidate.source}:${candidate.recordId}`,
 400:       source: candidate.source,
 401:       targetTab: getWorkspaceSearchTargetTab(candidate.source),
 402:       recordId: candidate.recordId,
 403:       title: candidate.title,
 404:       summary: candidate.summary,
 405:       status: candidate.status,
 406:       updatedAt: candidate.updatedAt,
 407:       matches,
 408:     },
 409:   };
 410: }

 151: export function resolveWorkspaceSearchQuery(
 152:   query: string | WorkspaceSearchQuery | null | undefined,
 153: ): WorkspaceSearchQuery {
 154:   if (typeof query === 'string' || query === null || typeof query === 'undefined') {
 155:     return normalizeWorkspaceSearchQuery(query);
 156:   }
 157: 
 158:   return normalizeWorkspaceSearchQuery(query.raw || query.normalized);

 412: function pushSearchField(
 413:   fields: WorkspaceSearchField[],
 414:   field: WorkspaceSearchHitField,
 415:   label: string,
 416:   value: unknown,
 417: ) {
 418:   const text = toSearchText(value);
 419:   if (!text) return;
 420: 
 421:   fields.push({
 422:     field,
 423:     label,
 424:     value: text,
 425:     priority: getSearchFieldPriority(field),
 426:   });
 427: }

 101: export function normalizeWorkspaceSearchQuery(query: string | null | undefined): WorkspaceSearchQuery {
 102:   const raw = typeof query === 'string' ? query : '';
 103:   const normalized = raw.trim().replace(/\s+/g, ' ').toLowerCase();
 104: 
 105:   return {
 106:     raw,
 107:     normalized,
 108:     terms: normalized === '' ? [] : normalized.split(' '),
 109:     isEmpty: normalized === '',
 110:   };
 111: }

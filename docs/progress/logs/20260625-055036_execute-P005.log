 120: .icon-surface-danger { --icon-surface-color: var(--danger); --icon-surface-bg: var(--danger-bg); }
 121: 
 122: .list { display: grid; gap: 10px; padding: 16px 18px; }
 123: .list.compact { max-height: none; overflow: auto; }
 124: .item { min-width: 0; border: 1px solid var(--line-soft); border-radius: var(--r-md); padding: 12px; background: var(--bg-soft); }
 125: .item-title { display: flex; justify-content: space-between; gap: 12px; min-width: 0; font-weight: 650; align-items: center; }
 126: .item-title > span:first-child { flex: 1 1 auto; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
 127: .item-title-right { display: inline-flex; align-items: center; justify-content: flex-end; gap: 8px; min-width: 0; flex: 0 0 auto; }
 128: .item-actions { display: inline-flex; flex-wrap: wrap; align-items: center; justify-content: flex-end; gap: 4px; }
 129: .item-actions .btn-link { padding: 3px 6px; font-size: 12px; white-space: nowrap; }
 130: .item-actions .danger-link { color: var(--danger); }
 131: .item-actions .btn-link:disabled { color: var(--text-4); cursor: not-allowed; text-decoration: none; }
 132: .item-body { margin-top: 10px; color: var(--text-2); overflow-wrap: anywhere; }
 133: .plain-text { line-height: 1.55; white-space: pre-wrap; word-break: break-word; }
 134: .markdown-reader { min-width: 0; color: var(--text-1); font-size: 13.5px; line-height: 1.72; overflow-wrap: anywhere; }
 135: .markdown-reader > :first-child { margin-top: 0; }
 136: .markdown-reader > :last-child { margin-bottom: 0; }
 137: .markdown-reader-empty { padding: 28px 18px; border: 1px dashed var(--line); border-radius: var(--r-md); background: var(--bg-soft); color: var(--text-3); text-align: center; font-size: 13px; }
 138: .markdown-reader h1 { margin: 0 0 14px; padding-bottom: 10px; border-bottom: 1px solid var(--line-soft); font-size: 22px; line-height: 1.3; font-weight: 800; }
 139: .markdown-reader h2 { margin: 24px 0 10px; padding-bottom: 6px; border-bottom: 1px solid var(--line-soft); font-size: 18px; line-height: 1.35; font-weight: 750; }
 140: .markdown-reader h3 { margin: 20px 0 8px; font-size: 15.5px; line-height: 1.4; font-weight: 700; }
 141: .markdown-reader h4, .markdown-reader h5, .markdown-reader h6 { margin: 16px 0 8px; font-size: 14px; line-height: 1.4; font-weight: 700; }
 142: .markdown-reader p { margin: 0 0 12px; color: var(--text-2); }
 143: .markdown-reader a { color: var(--brand-600); overflow-wrap: anywhere; word-break: break-word; }
 144: .markdown-reader a:hover { text-decoration: underline; }
 145: .markdown-reader ul, .markdown-reader ol { margin: 0 0 14px; padding-left: 1.45em; color: var(--text-2); }
 146: .markdown-reader li { margin: 4px 0; }
 147: .markdown-reader li > p { margin: 6px 0; }
 148: .markdown-reader .contains-task-list { list-style: none; padding-left: 1.2em; }
 149: .markdown-reader .task-list-item { margin-left: -1.2em; }
 150: .markdown-reader input[type="checkbox"] { width: auto; margin: 0 7px 0 0; accent-color: var(--brand-600); vertical-align: -2px; }
 151: .markdown-reader blockquote { margin: 14px 0; padding: 10px 14px; border-left: 3px solid var(--brand-500); border-radius: 0 var(--r-sm) var(--r-sm) 0; background: var(--brand-50); color: var(--text-2); }
 152: .markdown-reader blockquote p { color: inherit; }
 153: .markdown-reader code { padding: 2px 5px; border: 1px solid var(--line-soft); border-radius: var(--r-sm); background: var(--bg-soft); color: var(--text-1); font-family: var(--font-mono); font-size: 0.92em; word-break: break-word; }
 154: .markdown-reader pre { max-width: 100%; margin: 14px 0; padding: 12px 14px; overflow: auto; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-soft); box-shadow: inset 0 1px 0 rgba(255,255,255,0.65); }
 155: .markdown-reader pre code { display: block; padding: 0; border: 0; border-radius: 0; background: transparent; color: var(--text-1); white-space: pre; word-break: normal; overflow-wrap: normal; }
 156: .markdown-reader table { display: block; width: 100%; max-width: 100%; margin: 14px 0; overflow-x: auto; border-collapse: collapse; font-size: 13px; }
 157: .markdown-reader th, .markdown-reader td { padding: 8px 10px; border: 1px solid var(--line); text-align: left; vertical-align: top; }
 158: .markdown-reader th { background: var(--bg-soft); color: var(--text-1); font-weight: 700; }
 159: .markdown-reader tr:nth-child(even) td { background: rgba(248,250,253,0.65); }
 160: .markdown-reader hr { margin: 20px 0; border: 0; border-top: 1px solid var(--line); }
 161: .markdown-reader img { max-width: 100%; height: auto; border-radius: var(--r-md); box-shadow: var(--shadow-sm); }
 162: .meta { margin-top: 6px; color: var(--text-3); font-size: 12px; word-break: break-all; overflow-wrap: anywhere; }
 163: .event-list { min-width: 0; }
 164: .event-item { display: grid; gap: 8px; border-left: 3px solid transparent; }
 165: .event-title { align-items: flex-start; }
 166: .event-title > span:first-child { white-space: normal; overflow: visible; text-overflow: clip; overflow-wrap: anywhere; line-height: 1.45; }
 167: .event-badge { flex: 0 0 auto; display: inline-flex; align-items: center; padding: 3px 9px; border-radius: 999px; font-size: 11px; font-weight: 700; white-space: nowrap; }
 168: .event-badge-start, .event-badge-updated { color: var(--info); background: var(--info-bg); }
 169: .event-badge-success { color: var(--success); background: var(--success-bg); }
 170: .event-badge-failed { color: var(--danger); background: var(--danger-bg); }
 171: .event-badge-stopped, .event-badge-stopping { color: var(--warning); background: var(--warning-bg); }
 172: .event-item-start { border-left-color: var(--info); }
 173: .event-item-success { border-left-color: var(--success); }
 174: .event-item-failed { border-left-color: var(--danger); }
 175: .event-item-stopped, .event-item-stopping { border-left-color: var(--warning); }
 176: .event-item-updated { border-left-color: var(--info); }
 177: .event-item .item-body, .event-meta { margin-top: 0; }
 178: .button-row { display: flex; flex-wrap: wrap; align-items: center; gap: 8px; margin-top: 12px; }

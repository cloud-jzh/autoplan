 436: function createAttachmentLookup(attachments: readonly AttachmentRecord[]) {
 437:   const lookup = new Map<string, AttachmentRecord[]>();
 438: 
 439:   attachments.forEach((attachment) => {
 440:     const key = createAttachmentLookupKey(attachment.owner_type, attachment.owner_id);
 441:     const ownerAttachments = lookup.get(key) ?? [];
 442:     lookup.set(key, [...ownerAttachments, attachment]);
 443:   });
 444: 
 445:   return lookup;
 446: }
 447: 
 448: function getOwnerAttachments(
 449:   lookup: Map<string, AttachmentRecord[]>,
 450:   ownerType: AttachmentRecord['owner_type'],
 451:   ownerId: number,
 452: ) {
 453:   return lookup.get(createAttachmentLookupKey(ownerType, ownerId)) ?? [];
 454: }
 455: 
 456: function createAttachmentLookupKey(ownerType: AttachmentRecord['owner_type'], ownerId: number) {
 457:   return `${ownerType}:${ownerId}`;
 458: }
 459: 
 460: function doesFieldMatchQuery(field: WorkspaceSearchField, query: WorkspaceSearchQuery) {
 461:   return doesTextMatchQuery(field.value.toLowerCase(), query);
 462: }
 463: 
 464: function doesTextMatchQuery(text: string, query: WorkspaceSearchQuery) {
 465:   if (!text || query.isEmpty) return false;
 466:   if (text.includes(query.normalized)) return true;
 467:   return query.terms.every((term) => text.includes(term));
 468: }
 469: 
 470: function createSearchSnippet(value: string, query: WorkspaceSearchQuery) {
 471:   const text = toSearchText(value);
 472:   if (text.length <= SEARCH_SNIPPET_MAX_LENGTH) return text;
 473: 
 474:   const lowerText = text.toLowerCase();
 475:   const matchIndex = getFirstSearchMatchIndex(lowerText, query);
 476:   const safeMatchIndex = matchIndex >= 0 ? matchIndex : 0;
 477:   const start = Math.max(0, safeMatchIndex - 32);
 478:   const end = Math.min(text.length, start + SEARCH_SNIPPET_MAX_LENGTH);
 479:   const prefix = start > 0 ? '…' : '';
 480:   const suffix = end < text.length ? '…' : '';
 481: 
 482:   return `${prefix}${text.slice(start, end)}${suffix}`;
 483: }
 484: 
 485: function getFirstSearchMatchIndex(text: string, query: WorkspaceSearchQuery) {
 486:   const phraseIndex = text.indexOf(query.normalized);
 487:   if (phraseIndex >= 0) return phraseIndex;
 488: 
 489:   return query.terms.reduce((bestIndex, term) => {
 490:     const termIndex = text.indexOf(term);
 491:     if (termIndex < 0) return bestIndex;
 492:     return bestIndex < 0 ? termIndex : Math.min(bestIndex, termIndex);
 493:   }, -1);
 494: }
 495: 
 496: function compareRankedWorkspaceSearchResults(
 497:   left: RankedWorkspaceSearchResult,
 498:   right: RankedWorkspaceSearchResult,
 499: ) {
 500:   if (left.priority !== right.priority) return left.priority - right.priority;
 501:   if (left.updatedAtMs !== right.updatedAtMs) return right.updatedAtMs - left.updatedAtMs;
 502:   return compareWorkspaceSearchResults(left.result, right.result);
 503: }
 504: 
 505: function compareWorkspaceSearchResults(left: WorkspaceSearchResult, right: WorkspaceSearchResult) {
 506:   const leftPriority = getWorkspaceSearchResultPriority(left);
 507:   const rightPriority = getWorkspaceSearchResultPriority(right);
 508:   if (leftPriority !== rightPriority) return leftPriority - rightPriority;
 509: 
 510:   const leftUpdatedAt = getTimestampMs(left.updatedAt);
 511:   const rightUpdatedAt = getTimestampMs(right.updatedAt);
 512:   if (leftUpdatedAt !== rightUpdatedAt) return rightUpdatedAt - leftUpdatedAt;
 513: 
 514:   if (left.source !== right.source) return left.source.localeCompare(right.source);
 515:   return right.recordId - left.recordId;
 516: }
 517: 
 518: function getWorkspaceSearchResultPriority(result: WorkspaceSearchResult) {
 519:   return result.matches.reduce(
 520:     (priority, match) => Math.min(priority, getSearchFieldPriority(match.field)),
 521:     FALLBACK_SEARCH_PRIORITY,
 522:   );
 523: }
 524: 
 525: function getSearchFieldPriority(field: WorkspaceSearchHitField) {
 526:   return WORKSPACE_SEARCH_FIELD_PRIORITIES[field] ?? FALLBACK_SEARCH_PRIORITY;
 527: }
 528: 
 529: function summarizeSearchText(value: unknown, fallback: string) {
 530:   const text = toSearchText(value);
 531:   if (!text) return fallback;
 532:   if (text.length <= SEARCH_SUMMARY_MAX_LENGTH) return text;
 533:   return `${text.slice(0, SEARCH_SUMMARY_MAX_LENGTH)}…`;
 534: }
 535: 
 536: function nullableSearchText(value: unknown) {
 537:   return toSearchText(value) || null;
 538: }
 539: 
 540: function toSearchText(value: unknown) {
 541:   if (value === null || typeof value === 'undefined') return '';
 542:   return String(value).trim().replace(/\s+/g, ' ');
 543: }
 544: 
 545: function getFileName(filePath: unknown) {
 546:   const path = toSearchText(filePath);
 547:   if (!path) return '';
 548:   return path.split(/[\\/]/).filter(Boolean).pop() ?? path;
 549: }
 550: 
 551: function getObjectMeta(meta: unknown): Record<string, unknown> | null {
 552:   if (!meta || typeof meta !== 'object' || Array.isArray(meta)) {
 553:     return null;
 554:   }
 555: 
 556:   return meta as Record<string, unknown>;
 557: }
 558: 
 559: function stringifySearchMeta(meta: unknown) {
 560:   if (meta === null || typeof meta === 'undefined') return '';
 561:   if (typeof meta === 'string') return meta;
 562: 
 563:   try {
 564:     return JSON.stringify(meta);
 565:   } catch {
 566:     return String(meta);
 567:   }
 568: }


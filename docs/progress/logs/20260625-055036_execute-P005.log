 180: /* 需求/反馈卡片：进度 + 操作脚 + 追加任务 */
 181: .intake-progress { margin-top: 12px; }
 182: .intake-item .item-foot {
 183:   display: flex; align-items: center; gap: 12px; margin-top: 12px;
 184:   padding-top: 10px; border-top: 1px solid var(--line-soft);
 185: }
 186: .intake-item .item-foot .meta { margin-top: 0; margin-left: auto; }
 187: .intake-item .item-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 4px; }
 188: .intake-item .danger-link { color: var(--danger); }
 189: .intake-item .danger-link:hover { text-decoration: underline; }
 190: .append-row {
 191:   display: flex; gap: 8px; margin-top: 12px;
 192:   padding: 10px; border-radius: var(--r-sm);
 193:   background: var(--bg-soft); border: 1px dashed var(--line);
 194: }
 195: .append-input { flex: 1 1 auto; padding: 7px 10px; border: 1px solid var(--line); border-radius: var(--r-sm); font: inherit; font-size: 12.5px; }
 196: .append-input:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
 197: .inline-editor { display: grid; gap: 10px; margin-top: 12px; }
 198: .inline-editor .field { margin-bottom: 0; }
 199: .inline-editor textarea { min-height: 140px; }
 200: .attachment-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 10px; }
 201: .attachment-thumb, .attachment-file { display: grid; gap: 6px; width: 120px; padding: 8px; border: 1px solid var(--line); border-radius: var(--r-sm); background: var(--bg-elevated); color: var(--text-1); }
 202: .attachment-thumb img { width: 100%; aspect-ratio: 1; border-radius: 4px; object-fit: cover; background: var(--brand-50); }
 203: .attachment-thumb span, .attachment-file span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 12px; }
 204: .attachment-file small { color: var(--text-3); font-size: 12px; }

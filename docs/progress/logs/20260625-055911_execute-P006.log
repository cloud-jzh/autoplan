 314: 
 315: function insertProject(db, loop, name, workspacePath) {
 316:   const now = nowIso();
 317:   const id = db.insert(
 318:     `INSERT INTO projects (name, workspace_path, description, created_at, updated_at)
 319:      VALUES (?, ?, ?, ?, ?)`,
 320:     [name, workspacePath, '', now, now],
 321:   );
 322:   loop.ensureProjectState(id);
 323:   return id;
 324: }
 325: 
 326: function insertRequirement(db, projectId) {
 327:   const now = nowIso();
 328:   return db.insert(
 329:     `INSERT INTO requirements (project_id, title, body, status, created_at, updated_at)
 330:      VALUES (?, ?, ?, ?, ?, ?)`,
 331:     [projectId, '普通文本需求', '目标：\n普通文本验收\n允许拖拽图片附件', 'open', now, now],
 332:   );
 333: }
 334: 
 335: function insertFeedback(db, projectId) {
 336:   const now = nowIso();
 337:   db.insert(
 338:     `INSERT INTO feedback (project_id, requirement_id, title, body, status, created_at, updated_at)
 339:      VALUES (?, ?, ?, ?, ?, ?, ?)`,
 340:     [projectId, null, '普通文本反馈', '列表展示\n重点内容\n可附加图片', 'open', now, now],
 341:   );
 342: }

 277: export function PlanList({
 278:   emptyText = '暂无 plan。',
 279:   plans,
 280:   tasks = [],
 281:   totalPlanCount = plans.length,
 282: }: {
 283:   emptyText?: string;
 284:   plans: Plan[];
 285:   tasks?: PlanTask[];
 286:   totalPlanCount?: number;
 287: }) {
 288:   const [readingPlan, setReadingPlan] = useState<Plan | null>(null);
 289:   const [planReadResult, setPlanReadResult] = useState<ReadPlanResult | null>(null);
 290:   const [planReadError, setPlanReadError] = useState('');
 291:   const [planReading, setPlanReading] = useState(false);
 292: 
 293:   useEffect(() => {
 294:     if (!readingPlan) return;
 295: 
 296:     let cancelled = false;
 297:     setPlanReading(true);
 298:     setPlanReadResult(null);
 299:     setPlanReadError('');
 300: 
 301:     window.autoplan
 302:       .readPlan({ projectId: readingPlan.project_id, planId: readingPlan.id })
 303:       .then((result) => {
 304:         if (cancelled) return;
 305:         setPlanReadResult(result);
 306:         setPlanReadError(result.ok ? '' : result.error || '读取 Plan 全文失败');
 307:       })
 308:       .catch((error) => {
 309:         if (cancelled) return;
 310:         setPlanReadError(getErrorMessage(error, '读取 Plan 全文失败'));
 311:       })
 312:       .finally(() => {
 313:         if (!cancelled) setPlanReading(false);
 314:       });
 315: 
 316:     return () => {
 317:       cancelled = true;
 318:     };
 319:   }, [readingPlan]);
 320: 
 321:   const closeReader = () => {
 322:     setReadingPlan(null);
 323:     setPlanReadResult(null);
 324:     setPlanReadError('');
 325:     setPlanReading(false);
 326:   };
 327: 
 328:   if (!plans.length) return <div className="empty">{emptyText}</div>;
 329: 
 330:   const readerFilePath = planReadResult?.file_path || readingPlan?.file_path || '';
 331:   const readerHash = planReadResult?.hash || readingPlan?.hash || '';
 332:   const readerUpdatedAt = planReadResult?.updated_at || readingPlan?.updated_at || '';
 333: 
 334:   return (
 335:     <>
 336:       <div className="list compact">
 337:         {plans.map((plan) => {
 338:           const durationSummary = formatPlanDurationSummary(tasksForPlan(tasks, plan, totalPlanCount));
 339:           return (
 340:             <RecordCard
 341:               actions={
 342:                 <div className="item-actions">
 343:                   <button
 344:                     type="button"
 345:                     className="btn-link plan-read-link"
 346:                     aria-haspopup="dialog"
 347:                     aria-expanded={readingPlan?.id === plan.id}
 348:                     onClick={() => setReadingPlan(plan)}
 349:                   >
 350:                     阅读全文
 351:                   </button>
 352:                 </div>
 353:               }
 354:               key={plan.id}
 355:               title={plan.file_path}
 356:               status={plan.status}
 357:               body={`${plan.completed_tasks}/${plan.total_tasks} tasks · ${durationSummary} · validation ${
 358:                 plan.validation_passed ? 'passed' : 'pending'
 359:               }`}
 360:               meta={`${plan.hash?.slice(0, 12) || ''} · ${formatChinaDateTime(plan.updated_at)}`}
 361:             />
 362:           );
 363:         })}
 364:       </div>
 365: 
 366:       {readingPlan ? (
 367:         <div className="modal-mask" onClick={closeReader}>
 368:           <div
 369:             className="modal plan-reader-modal"
 370:             role="dialog"
 371:             aria-modal="true"
 372:             aria-labelledby="plan-reader-title"
 373:             onClick={(event) => event.stopPropagation()}
 374:           >
 375:             <div className="modal-head plan-reader-head">
 376:               <div className="plan-reader-title">
 377:                 <h3 id="plan-reader-title">Plan 全文</h3>
 378:                 <span className="plan-reader-path mono" title={readerFilePath}>
 379:                   {readerFilePath}
 380:                 </span>
 381:               </div>
 382:               <button type="button" className="modal-close" onClick={closeReader} aria-label="关闭 Plan 全文阅读">
 383:                 ×
 384:               </button>
 385:             </div>
 386:             <div className="plan-reader-body">
 387:               <div className="plan-reader-summary" aria-label="Plan 摘要">
 388:                 <div className="plan-reader-summary-item">
 389:                   <span>状态</span>
 390:                   <strong>{readingPlan.status}</strong>
 391:                 </div>
 392:                 <div className="plan-reader-summary-item">
 393:                   <span>更新时间</span>
 394:                   <strong>{readerUpdatedAt ? formatChinaDateTime(readerUpdatedAt) : '-'}</strong>
 395:                 </div>
 396:                 <div className="plan-reader-summary-item">
 397:                   <span>哈希</span>
 398:                   <strong className="mono" title={readerHash}>
 399:                     {readerHash?.slice(0, 12) || '-'}
 400:                   </strong>
 401:                 </div>
 402:               </div>
 403: 
 404:               {planReadError ? (
 405:                 <div className="plan-reader-error" role="alert">
 406:                   {planReadError}
 407:                 </div>
 408:               ) : null}
 409:               {planReading ? (
 410:                 <div className="plan-reader-loading" role="status">
 411:                   正在读取 Plan 全文…
 412:                 </div>
 413:               ) : null}
 414:               {!planReading && !planReadError ? (
 415:                 <section className="plan-reader-content" aria-label="Plan Markdown 正文">
 416:                   <MarkdownReader markdown={planReadResult?.markdown ?? ''} emptyMessage="暂无计划正文" />
 417:                 </section>
 418:               ) : null}
 419:             </div>
 420:           </div>
 421:         </div>
 422:       ) : null}
 423:     </>
 424:   );
 425: }
 426: 
 427: export function TaskList({
 428:   emptyText = '暂无任务。',
 429:   tasks,
 430:   onRun,
 431:   onStop,
 432: }: {
 433:   emptyText?: string;
 434:   tasks: PlanTask[];
 435:   onRun?: (task: PlanTask) => void;
 436:   onStop?: (task: PlanTask) => void;
 437: }) {
 438:   if (!tasks.length) return <div className="empty">{emptyText}</div>;
 439: 
 440:   return (
 441:     <div className="list compact">
 442:       {tasks.map((task) => {
 443:         const running = task.status === 'running';
 444:         const completed = task.status === 'completed';
 445:         const durationLabel = formatTaskDuration(task as TimedPlanTask);
 446:         return (
 447:           <RecordCard
 448:             actions={
 449:               <div className="item-actions">
 450:                 <button type="button" className="btn-link" disabled={completed || running} onClick={() => onRun?.(task)}>
 451:                   执行
 452:                 </button>
 453:                 <button type="button" className="btn-link danger-link" disabled={!running} onClick={() => onStop?.(task)}>
 454:                   停止
 455:                 </button>
 456:               </div>
 457:             }
 458:             key={task.id}
 459:             title={task.title}
 460:             status={task.status}
 461:             body={task.file_path}
 462:             meta={`${task.task_key} · ${durationLabel} · ${formatChinaDateTime(task.updated_at)}`}
 463:           />
 464:         );
 465:       })}
 466:     </div>
 467:   );
 468: }
 469: 
 470: export function EventList({ emptyText = '暂无事件。', events }: { emptyText?: string; events: AppEvent[] }) {
 471:   if (!events.length) return <div className="empty">{emptyText}</div>;
 472: 
 473:   return (
 474:     <div className="list compact event-list">
 475:       {events.map((event) => {
 476:         const display = formatEvent(event);
 477:         return (
 478:           <article className={`item event-item ${display.tone ? `event-item-${display.tone}` : ''}`} key={event.id}>
 479:             <div className="item-title event-title">
 480:               <span>{display.title}</span>
 481:               {display.badge ? <span className={`event-badge event-badge-${display.tone}`}>{display.badge}</span> : null}
 482:             </div>
 483:             {display.body ? <div className="item-body plain-text">{display.body}</div> : null}
 484:             <div className="meta event-meta">{display.meta}</div>
 485:           </article>
 486:         );
 487:       })}
 488:     </div>
 489:   );
 490: }

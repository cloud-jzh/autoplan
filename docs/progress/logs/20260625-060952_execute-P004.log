 258:                 <>
 259:                   <button type="button" onClick={() => onSave(draft)}>
 260:                     保存调整
 261:                   </button>
 262:                   {onAccept ? (
 263:                     <button className="btn-primary" type="button" onClick={() => onAccept(draft)}>
 264:                       确认加入任务系统
 265:                     </button>
 266:                   ) : null}
 267:                 </>
 268:               )}
 269:             </div>
 270:           </article>
 271:         );
 272:       })}
 273:     </div>
 274:   );
 275: }

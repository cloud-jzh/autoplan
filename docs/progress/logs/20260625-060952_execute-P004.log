  52: function formatTaskDuration(task: TimedPlanTask) {
  53:   const duration = getTaskDurationMs(task);
  54:   if (task.status === 'running') return `已运行 ${formatDuration(duration, '0秒')}`;
  55:   if (duration === null || (duration === 0 && !task.started_at && !task.finished_at)) return '未开始';
  56:   return `耗时 ${formatDuration(duration, '0秒')}`;
  57: }
  58: 
  59: function tasksForPlan(tasks: PlanTask[], plan: Plan, planCount: number) {
  60:   const timedTasks = tasks as TimedPlanTask[];
  61:   const hasPlanIds = timedTasks.some((task) => readPlanId(task) !== null);
  62:   if (!hasPlanIds) return planCount === 1 ? timedTasks : [];
  63:   return timedTasks.filter((task) => readPlanId(task) === plan.id);
  64: }
  65: 
  66: function formatPlanDurationSummary(tasks: TimedPlanTask[]) {
  67:   const totalMs = tasks.reduce((sum, task) => sum + (getTaskDurationMs(task) ?? 0), 0);
  68:   const completedMs = tasks.reduce(
  69:     (sum, task) => sum + (task.status === 'completed' ? getTaskDurationMs(task) ?? 0 : 0),
  70:     0,
  71:   );
  72: 
  73:   return `总耗时 ${formatDuration(totalMs, '0秒')} · 已完成 ${formatDuration(completedMs, '0秒')}`;
  74: }
  75: 
  76: function getErrorMessage(error: unknown, fallback: string) {
  77:   if (error instanceof Error && error.message) return error.message;
  78:   if (typeof error === 'string' && error.trim()) return error.trim();
  79:   return fallback;
  80: }
  81: 
  82: function toEventMetaRecord(value: unknown): EventMetaRecord | null {
  83:   if (!value) return null;
  84:   if (typeof value === 'string') {
  85:     try {
  86:       return toEventMetaRecord(JSON.parse(value));
  87:     } catch {
  88:       return null;
  89:     }
  90:   }
  91:   if (typeof value === 'object' && !Array.isArray(value)) return value as EventMetaRecord;
  92:   return null;
  93: }
  94: 
  95: function readEventMeta(event: AppEvent) {
  96:   return toEventMetaRecord((event as AppEvent & { meta?: unknown }).meta);
  97: }
  98: 
  99: function readMetaText(meta: EventMetaRecord | null, keys: string[]) {
 100:   if (!meta) return '';
 101:   for (const key of keys) {
 102:     const value = meta[key];
 103:     if (typeof value === 'string') {
 104:       const text = value.trim();
 105:       if (text) return text;
 106:     }
 107:     if (typeof value === 'number' && Number.isFinite(value)) return String(value);
 108:   }
 109:   return '';
 110: }
 111: 
 112: function readMetaNumber(meta: EventMetaRecord | null, keys: string[]) {
 113:   const text = readMetaText(meta, keys);
 114:   if (!text) return null;
 115:   const value = Number(text);
 116:   return Number.isFinite(value) ? value : null;
 117: }
 118: 
 119: function includesAny(text: string, keywords: string[]) {
 120:   return keywords.some((keyword) => text.includes(keyword));
 121: }
 122: 
 123: function classifyTaskEvent(event: AppEvent, meta: EventMetaRecord | null): TaskEventTone {
 124:   const eventText = `${event.type || ''} ${readMetaText(meta, ['status', 'taskStatus', 'task_status'])}`.toLowerCase();
 125:   if (includesAny(eventText, ['stop_requested', 'stop-requested', 'stop.requested', 'request_stop', 'stopping'])) {
 126:     return 'stopping';
 127:   }
 128:   if (includesAny(eventText, ['fail', 'error', 'errored'])) return 'failed';
 129:   if (includesAny(eventText, ['stop', 'interrupt', 'cancel'])) return 'stopped';
 130:   if (includesAny(eventText, ['start', 'begin', 'running'])) return 'start';
 131:   if (includesAny(eventText, ['complete', 'finish', 'success', 'succeed', 'executed', 'done'])) return 'success';
 132:   return 'updated';
 133: }
 134: 
 135: function isTaskEventType(type: string) {
 136:   return /^task[.:_-]/i.test(type);
 137: }
 138: 
 139: function sameEventText(left: string, right: string) {
 140:   return left.replace(/\s+/g, ' ').trim() === right.replace(/\s+/g, ' ').trim();
 141: }
 142: 
 143: function formatTaskEvent(event: AppEvent, meta: EventMetaRecord): TaskEventDisplay | null {
 144:   const taskKey = readMetaText(meta, ['taskKey', 'task_key']);
 145:   const taskId = readMetaText(meta, ['taskId', 'task_id']);
 146:   const taskTitle = readMetaText(meta, ['taskTitle', 'task_title', 'title']) || '未命名任务';
 147:   const hasTaskIdentity = Boolean(taskKey || taskId || readMetaText(meta, ['taskTitle', 'task_title', 'title']));
 148:   if (!hasTaskIdentity) return null;
 149: 
 150:   const tone = classifyTaskEvent(event, meta);
 151:   const presentation = TASK_EVENT_PRESENTATION[tone];
 152:   const taskLabel = taskKey ? `${taskKey} 任务` : taskId ? `任务 #${taskId}` : '任务';
 153:   const separator = taskLabel === '任务' ? '' : ' ';
 154:   const title = `${presentation.action}${separator}${taskLabel}：${taskTitle}`;
 155:   const originalMessage = event.message?.trim() || '';
 156:   const planId = readMetaText(meta, ['planId', 'plan_id']);
 157:   const status = readMetaText(meta, ['status', 'taskStatus', 'task_status']);
 158:   const durationMs = readMetaNumber(meta, ['durationMs', 'duration_ms']);
 159:   const metaParts = [
 160:     formatChinaDateTime(event.created_at),
 161:     planId ? `Plan #${planId}` : '',
 162:     status ? `状态 ${status}` : '',
 163:     durationMs !== null ? `耗时 ${formatDuration(durationMs, '0秒')}` : '',
 164:   ].filter(Boolean);
 165: 
 166:   return {
 167:     title,
 168:     body: originalMessage && !sameEventText(originalMessage, title) ? originalMessage : '',
 169:     meta: metaParts.join(' · '),
 170:     badge: presentation.badge,
 171:     tone,
 172:   };
 173: }
 174: 
 175: function formatEvent(event: AppEvent): TaskEventDisplay {
 176:   const meta = readEventMeta(event);
 177:   const taskDisplay = meta && (isTaskEventType(event.type) || readMetaText(meta, ['taskKey', 'task_key', 'taskId', 'task_id']))
 178:     ? formatTaskEvent(event, meta)
 179:     : null;
 180:   if (taskDisplay) return taskDisplay;
 181: 
 182:   return {
 183:     title: event.type || '事件',
 184:     body: event.message || '',
 185:     meta: formatChinaDateTime(event.created_at),
 186:   };
 187: }
 188: 
 189: function toSearchText(value: unknown, depth = 0): string {
 190:   if (value === null || value === undefined || depth > 6) return '';
 191:   if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') return String(value);
 192:   if (Array.isArray(value)) return value.map((item) => toSearchText(item, depth + 1)).join(' ');
 193:   if (typeof value === 'object') {
 194:     return Object.values(value as Record<string, unknown>)
 195:       .map((item) => toSearchText(item, depth + 1))
 196:       .join(' ');
 197:   }
 198:   return '';
 199: }
 200: 
 201: export function getEventSearchText(event: AppEvent) {
 202:   const display = formatEvent(event);
 203:   const meta = readEventMeta(event);
 204:   return [
 205:     event.type,
 206:     event.message,
 207:     display.title,
 208:     display.body,
 209:     display.badge,
 210:     display.meta,
 211:     toSearchText(meta),
 212:     toSearchText(event),
 213:   ]
 214:     .filter(Boolean)
 215:     .join(' ');
 216: }

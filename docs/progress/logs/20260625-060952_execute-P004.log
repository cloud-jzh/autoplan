 630: function WorkspaceSearchBox({
 631:   hitCount,
 632:   onQueryChange,
 633:   query,
 634:   totalCount,
 635: }: {
 636:   hitCount: number;
 637:   onQueryChange: (query: string) => void;
 638:   query: string;
 639:   totalCount: number;
 640: }) {
 641:   const hasQuery = Boolean(normalizeSearchQuery(query));
 642:   const resultLabel = hasQuery ? `命中 ${hitCount} 条` : `可搜索 ${totalCount} 条`;
 643: 
 644:   return (
 645:     <div className="workspace-search" role="search" aria-label="工作区搜索">
 646:       <div className="workspace-search-field">
 647:         <Icon name="search" size={16} className="workspace-search-icon" aria-hidden="true" />
 648:         <input
 649:           aria-label="搜索当前工作区"
 650:           className="workspace-search-input search-input"
 651:           onChange={(event) => onQueryChange(event.target.value)}
 652:           onKeyDown={(event) => {
 653:             if (event.key === 'Escape' && query) {
 654:               event.preventDefault();
 655:               onQueryChange('');
 656:             }
 657:           }}
 658:           placeholder="搜索需求、反馈、任务、Plan 或事件"
 659:           value={query}
 660:         />
 661:         {query ? (
 662:           <button
 663:             type="button"
 664:             className="workspace-search-clear"
 665:             onClick={() => onQueryChange('')}
 666:             aria-label="清空工作区搜索关键字"
 667:           >
 668:             <Icon name="close" size={15} aria-hidden="true" />
 669:           </button>
 670:         ) : null}
 671:       </div>
 672:       <span className={`workspace-search-count${hasQuery && hitCount === 0 ? ' is-empty' : ''}`} aria-live="polite">
 673:         {resultLabel}
 674:       </span>
 675:     </div>
 676:   );
 677: }
 678: 
 679: function normalizeSearchQuery(value: string) {
 680:   return value.trim().toLowerCase().replace(/\s+/g, ' ');
 681: }
 682: 
 683: function countSearchableItems(snapshot: AppSnapshot) {
 684:   return (
 685:     snapshot.requirements.length +
 686:     snapshot.feedback.length +
 687:     snapshot.planDrafts.length +
 688:     snapshot.plans.length +
 689:     snapshot.tasks.length +
 690:     snapshot.events.length
 691:   );
 692: }
 693: 
 694: function createFilteredWorkspaceItems(
 695:   snapshot: AppSnapshot | null | undefined,
 696:   searchState: WorkspaceSearchState,
 697: ): WorkspaceFilterableItems {
 698:   if (!snapshot) {
 699:     return { requirements: [], feedback: [], planDrafts: [], plans: [], tasks: [], events: [] };
 700:   }
 701:   if (searchState.query.isEmpty) {
 702:     return {
 703:       requirements: snapshot.requirements,
 704:       feedback: snapshot.feedback,
 705:       planDrafts: snapshot.planDrafts,
 706:       plans: snapshot.plans,
 707:       tasks: snapshot.tasks,
 708:       events: snapshot.events,
 709:     };
 710:   }
 711: 
 712:   return {
 713:     requirements: filterItemsBySearchGroup(
 714:       snapshot.requirements,
 715:       searchState.groups,
 716:       WORKSPACE_SEARCH_SOURCE_TYPES.REQUIREMENT,
 717:     ),
 718:     feedback: filterItemsBySearchGroup(snapshot.feedback, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.FEEDBACK),
 719:     planDrafts: filterItemsBySearchGroup(
 720:       snapshot.planDrafts,
 721:       searchState.groups,
 722:       WORKSPACE_SEARCH_SOURCE_TYPES.PLAN_DRAFT,
 723:     ),
 724:     plans: filterItemsBySearchGroup(snapshot.plans, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.PLAN),
 725:     tasks: filterItemsBySearchGroup(snapshot.tasks, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.TASK),
 726:     events: filterItemsBySearchGroup(snapshot.events, searchState.groups, WORKSPACE_SEARCH_SOURCE_TYPES.EVENT),
 727:   };
 728: }
 729: 
 730: function filterItemsBySearchGroup<T extends { id: number }>(
 731:   items: T[],
 732:   groups: WorkspaceSearchGroup[],
 733:   source: WorkspaceSearchSourceType,
 734: ) {
 735:   const group = groups.find((item) => item.source === source);
 736:   if (!group?.results.length) return [];
 737: 
 738:   const recordIds = new Set(group.results.map((result) => result.recordId));
 739:   return items.filter((item) => recordIds.has(item.id));
 740: }
 741: 
 742: function OverviewView({
 743:   snapshot,
 744:   state,
 745:   onGoTasks,
 746: }: {
 747:   snapshot: AppSnapshot;
 748:   state: ProjectState | null;
 749:   onGoTasks: () => void;
 750: }) {
 751:   const reqCount = snapshot.requirements.length;
 752:   const planCount = snapshot.plans.length;
 753:   const runningPlan = snapshot.plans.find((plan) => !['completed'].includes(plan.status));
 754:   const doneTasks = snapshot.tasks.filter((task) => task.status === 'completed').length;
 755:   const totalTasks = snapshot.tasks.length;
 756: 
 757:   const phases = ['scan', 'generate-plan', 'execute-task', 'validate', 'completed'];
 758:   const currentPhase = state?.phase || 'idle';
 759:   const activeIndex = phases.indexOf(currentPhase);
 760:   const operation = snapshot.activeOperation || snapshot.lastOperation;
 761:   const operationActive = Boolean(snapshot.activeOperation);
 762:   const operationTime = operation?.startedAt ? `开始于 ${formatChinaTime(operation.startedAt)}` : '';
 763:   const operationExit =
 764:     operation && !operationActive && typeof operation.exitCode === 'number'
 765:       ? `退出码 ${operation.exitCode}${operation.exitCode === 0 ? '（成功）' : '（失败）'}`
 766:       : '';
 767:   const operationHint = operation
 768:     ? [operationTime, operation.codexSessionLabel, operationExit].filter(Boolean).join(' · ')
 769:     : '等待下一次执行';
 770:   const operationTitle = operation ? `${operationActive ? '执行日志' : '最近执行'} · ${operation.label}` : '执行日志';
 771: 
 772:   return (
 773:     <>
 774:       <div className="stat-grid">
 775:         <StatCard icon="requirement" value={String(reqCount)} label="需求" accent="brand" />
 776:         <StatCard

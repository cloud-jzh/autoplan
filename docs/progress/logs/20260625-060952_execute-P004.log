 621:         <div className="loop-config mono">
 622:           间隔 {state?.interval_seconds || 5}s
 623:           {state?.validation_command ? ` · ${state.validation_command}` : ' · 无验收命令'}
 624:         </div>
 625:       </div>
 626:     </aside>
 627:   );
 628: }

   1: import type { ComponentProps } from 'react';
   2: import ReactMarkdown from 'react-markdown';
   3: import remarkGfm from 'remark-gfm';
   4: 
   5: type ReactMarkdownProps = ComponentProps<typeof ReactMarkdown>;
   6: type MarkdownComponents = NonNullable<ReactMarkdownProps['components']>;
   7: type UrlTransform = NonNullable<ReactMarkdownProps['urlTransform']>;
   8: 
   9: export type MarkdownReaderProps = {
  10:   markdown?: string | null;
  11:   className?: string;
  12:   emptyMessage?: string;
  13:   ariaLabel?: string;
  14: };
  15: 
  16: const allowedUrlProtocols = new Set(['http:', 'https:', 'mailto:', 'tel:']);
  17: 
  18: function normalizeSafeUrl(url: string): string | undefined {
  19:   const trimmedUrl = url.trim();
  20: 
  21:   if (!trimmedUrl || trimmedUrl.startsWith('//')) {
  22:     return undefined;
  23:   }
  24: 
  25:   if (/^[a-zA-Z][a-zA-Z\d+.-]*:/.test(trimmedUrl)) {
  26:     try {
  27:       const parsedUrl = new URL(trimmedUrl);
  28:       return allowedUrlProtocols.has(parsedUrl.protocol) ? trimmedUrl : undefined;
  29:     } catch {
  30:       return undefined;
  31:     }
  32:   }
  33: 
  34:   return trimmedUrl;
  35: }
  36: 
  37: const safeUrlTransform: UrlTransform = (url) => normalizeSafeUrl(url) ?? '';
  38: 
  39: const markdownComponents: MarkdownComponents = {
  40:   a({ node: _node, href, children, ...props }) {
  41:     const safeHref = href ? normalizeSafeUrl(href) : undefined;
  42:     const isExternalLink = Boolean(safeHref && /^https?:\/\//i.test(safeHref));
  43: 
  44:     return (
  45:       <a
  46:         {...props}
  47:         href={safeHref}
  48:         target={isExternalLink ? '_blank' : undefined}
  49:         rel={isExternalLink ? 'noreferrer noopener' : undefined}
  50:       >
  51:         {children}
  52:       </a>
  53:     );
  54:   },
  55: };
  56: 
  57: export function MarkdownReader({
  58:   markdown,
  59:   className,
  60:   emptyMessage = '暂无计划正文',
  61:   ariaLabel = 'Markdown 正文',
  62: }: MarkdownReaderProps) {
  63:   const content = markdown ?? '';
  64:   const classes = ['markdown-reader', className].filter(Boolean).join(' ');
  65: 
  66:   if (!content.trim()) {
  67:     return (
  68:       <div className={`${classes} markdown-reader-empty`} role="status">
  69:         {emptyMessage}
  70:       </div>
  71:     );
  72:   }
  73: 
  74:   return (
  75:     <div className={classes} aria-label={ariaLabel}>
  76:       <ReactMarkdown
  77:         components={markdownComponents}
  78:         remarkPlugins={[remarkGfm]}
  79:         urlTransform={safeUrlTransform}
  80:       >
  81:         {content}
  82:       </ReactMarkdown>
  83:     </div>
  84:   );
  85: }
  86: 
  87: export default MarkdownReader;


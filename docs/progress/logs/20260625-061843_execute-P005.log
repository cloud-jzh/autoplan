   1: import type { AppEvent, Plan, PlanDraft, PlanTask, WorkspacePlanReadState } from '../types';
   2: import { RecordCard } from './IntakePanel';
   3: import { MarkdownReader } from './MarkdownReader';
   4: import { formatChinaDateTime, formatDuration, getRunningDurationMs } from '../utils/time';
   5: 
   6: type TimedPlanTask = PlanTask & {
   7:   plan_id?: number | null;
   8:   started_at?: string | null;
   9:   finished_at?: string | null;
  10:   duration_ms?: number | null;
  11: };
  12: 
  13: type EventMetaRecord = Record<string, unknown>;
  14: 
  15: type TaskEventTone = 'start' | 'success' | 'failed' | 'stopped' | 'stopping' | 'updated';
  16: 
  17: type TaskEventDisplay = {
  18:   title: string;
  19:   body: string;
  20:   meta: string;
  21:   badge?: string;
  22:   tone?: TaskEventTone;
  23: };
  24: 
  25: const TASK_EVENT_PRESENTATION: Record<TaskEventTone, { action: string; badge: string }> = {
  26:   start: { action: '开始了', badge: '开始' },
  27:   success: { action: '结束了', badge: '成功' },
  28:   failed: { action: '执行失败', badge: '失败' },
  29:   stopped: { action: '停止了', badge: '停止' },
  30:   stopping: { action: '请求停止', badge: '停止中' },
  31:   updated: { action: '更新了', badge: '任务' },
  32: };
  33: 
  34: function readDurationMs(task: TimedPlanTask) {
  35:   if (task.duration_ms === null || typeof task.duration_ms === 'undefined') return null;
  36:   const duration = Number(task.duration_ms);
  37:   return Number.isFinite(duration) && duration >= 0 ? duration : null;
  38: }
  39: 
  40: function getTaskDurationMs(task: TimedPlanTask) {
  41:   if (task.status === 'running') return getRunningDurationMs(readDurationMs(task), task.started_at);
  42:   return readDurationMs(task);
  43: }
  44: 
  45: function readPlanId(task: TimedPlanTask) {
  46:   if (task.plan_id === null || typeof task.plan_id === 'undefined') return null;
  47:   const planId = Number(task.plan_id);
  48:   return Number.isFinite(planId) ? planId : null;
  49: }
  50: 
  51: function formatTaskDuration(task: TimedPlanTask) {
  52:   const duration = getTaskDurationMs(task);
  53:   if (task.status === 'running') return `已运行 ${formatDuration(duration, '0秒')}`;
  54:   if (duration === null || (duration === 0 && !task.started_at && !task.finished_at)) return '未开始';
  55:   return `耗时 ${formatDuration(duration, '0秒')}`;
  56: }
  57: 
  58: function tasksForPlan(tasks: PlanTask[], plan: Plan, planCount: number) {
  59:   const timedTasks = tasks as TimedPlanTask[];
  60:   const hasPlanIds = timedTasks.some((task) => readPlanId(task) !== null);
  61:   if (!hasPlanIds) return planCount === 1 ? timedTasks : [];
  62:   return timedTasks.filter((task) => readPlanId(task) === plan.id);
  63: }
  64: 
  65: function formatPlanDurationSummary(tasks: TimedPlanTask[]) {
  66:   const totalMs = tasks.reduce((sum, task) => sum + (getTaskDurationMs(task) ?? 0), 0);
  67:   const completedMs = tasks.reduce(
  68:     (sum, task) => sum + (task.status === 'completed' ? getTaskDurationMs(task) ?? 0 : 0),
  69:     0,
  70:   );
  71: 
  72:   return `总耗时 ${formatDuration(totalMs, '0秒')} · 已完成 ${formatDuration(completedMs, '0秒')}`;
  73: }
  74: 
  75: function toEventMetaRecord(value: unknown): EventMetaRecord | null {
  76:   if (!value) return null;
  77:   if (typeof value === 'string') {
  78:     try {
  79:       return toEventMetaRecord(JSON.parse(value));
  80:     } catch {
  81:       return null;
  82:     }
  83:   }
  84:   if (typeof value === 'object' && !Array.isArray(value)) return value as EventMetaRecord;
  85:   return null;
  86: }
  87: 
  88: function readEventMeta(event: AppEvent) {
  89:   return toEventMetaRecord((event as AppEvent & { meta?: unknown }).meta);
  90: }
  91: 
  92: function readMetaText(meta: EventMetaRecord | null, keys: string[]) {
  93:   if (!meta) return '';
  94:   for (const key of keys) {
  95:     const value = meta[key];
  96:     if (typeof value === 'string') {
  97:       const text = value.trim();
  98:       if (text) return text;
  99:     }
 100:     if (typeof value === 'number' && Number.isFinite(value)) return String(value);
 101:   }
 102:   return '';
 103: }
 104: 
 105: function readMetaNumber(meta: EventMetaRecord | null, keys: string[]) {
 106:   const text = readMetaText(meta, keys);
 107:   if (!text) return null;
 108:   const value = Number(text);
 109:   return Number.isFinite(value) ? value : null;
 110: }
 111: 
 112: function includesAny(text: string, keywords: string[]) {
 113:   return keywords.some((keyword) => text.includes(keyword));
 114: }
 115: 
 116: function classifyTaskEvent(event: AppEvent, meta: EventMetaRecord | null): TaskEventTone {
 117:   const eventText = `${event.type || ''} ${readMetaText(meta, ['status', 'taskStatus', 'task_status'])}`.toLowerCase();
 118:   if (includesAny(eventText, ['stop_requested', 'stop-requested', 'stop.requested', 'request_stop', 'stopping'])) {
 119:     return 'stopping';
 120:   }
 121:   if (includesAny(eventText, ['fail', 'error', 'errored'])) return 'failed';
 122:   if (includesAny(eventText, ['stop', 'interrupt', 'cancel'])) return 'stopped';
 123:   if (includesAny(eventText, ['start', 'begin', 'running'])) return 'start';
 124:   if (includesAny(eventText, ['complete', 'finish', 'success', 'succeed', 'executed', 'done'])) return 'success';
 125:   return 'updated';
 126: }
 127: 
 128: function isTaskEventType(type: string) {
 129:   return /^task[.:_-]/i.test(type);
 130: }
 131: 
 132: function sameEventText(left: string, right: string) {
 133:   return left.replace(/\s+/g, ' ').trim() === right.replace(/\s+/g, ' ').trim();
 134: }
 135: 
 136: function formatTaskEvent(event: AppEvent, meta: EventMetaRecord): TaskEventDisplay | null {
 137:   const taskKey = readMetaText(meta, ['taskKey', 'task_key']);
 138:   const taskId = readMetaText(meta, ['taskId', 'task_id']);
 139:   const taskTitle = readMetaText(meta, ['taskTitle', 'task_title', 'title']) || '未命名任务';
 140:   const hasTaskIdentity = Boolean(taskKey || taskId || readMetaText(meta, ['taskTitle', 'task_title', 'title']));
 141:   if (!hasTaskIdentity) return null;
 142: 
 143:   const tone = classifyTaskEvent(event, meta);
 144:   const presentation = TASK_EVENT_PRESENTATION[tone];
 145:   const taskLabel = taskKey ? `${taskKey} 任务` : taskId ? `任务 #${taskId}` : '任务';
 146:   const separator = taskLabel === '任务' ? '' : ' ';
 147:   const title = `${presentation.action}${separator}${taskLabel}：${taskTitle}`;
 148:   const originalMessage = event.message?.trim() || '';
 149:   const planId = readMetaText(meta, ['planId', 'plan_id']);
 150:   const status = readMetaText(meta, ['status', 'taskStatus', 'task_status']);
 151:   const durationMs = readMetaNumber(meta, ['durationMs', 'duration_ms']);
 152:   const metaParts = [
 153:     formatChinaDateTime(event.created_at),
 154:     planId ? `Plan #${planId}` : '',
 155:     status ? `状态 ${status}` : '',
 156:     durationMs !== null ? `耗时 ${formatDuration(durationMs, '0秒')}` : '',
 157:   ].filter(Boolean);
 158: 
 159:   return {
 160:     title,
 161:     body: originalMessage && !sameEventText(originalMessage, title) ? originalMessage : '',
 162:     meta: metaParts.join(' · '),
 163:     badge: presentation.badge,
 164:     tone,
 165:   };
 166: }
 167: 
 168: function formatEvent(event: AppEvent): TaskEventDisplay {
 169:   const meta = readEventMeta(event);
 170:   const taskDisplay = meta && (isTaskEventType(event.type) || readMetaText(meta, ['taskKey', 'task_key', 'taskId', 'task_id']))
 171:     ? formatTaskEvent(event, meta)
 172:     : null;
 173:   if (taskDisplay) return taskDisplay;
 174: 
 175:   return {
 176:     title: event.type || '事件',
 177:     body: event.message || '',
 178:     meta: formatChinaDateTime(event.created_at),
 179:   };
 180: }
 181: 
 182: function toSearchText(value: unknown, depth = 0): string {
 183:   if (value === null || value === undefined || depth > 6) return '';
 184:   if (typeof value === 'string' || typeof value === 'number' || typeof value === 'boolean') return String(value);
 185:   if (Array.isArray(value)) return value.map((item) => toSearchText(item, depth + 1)).join(' ');
 186:   if (typeof value === 'object') {
 187:     return Object.values(value as Record<string, unknown>)
 188:       .map((item) => toSearchText(item, depth + 1))
 189:       .join(' ');
 190:   }
 191:   return '';
 192: }
 193: 
 194: export function getEventSearchText(event: AppEvent) {
 195:   const display = formatEvent(event);
 196:   const meta = readEventMeta(event);
 197:   return [
 198:     event.type,
 199:     event.message,
 200:     display.title,
 201:     display.body,
 202:     display.badge,
 203:     display.meta,
 204:     toSearchText(meta),
 205:     toSearchText(event),
 206:   ]
 207:     .filter(Boolean)
 208:     .join(' ');
 209: }

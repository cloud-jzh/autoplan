 289: export function PlanList({
 290:   emptyText = '暂无 plan。',
 291:   latestReadingPlan,
 292:   onCloseReader,
 293:   onOpenReader,
 294:   onRefreshReader,
 295:   plans,
 296:   readerState,
 297:   tasks = [],
 298:   totalPlanCount = plans.length,
 299: }: {
 300:   emptyText?: string;
 301:   latestReadingPlan?: Plan | null;
 302:   onCloseReader: () => void;
 303:   onOpenReader: (plan: Plan) => void;
 304:   onRefreshReader: () => void;
 305:   plans: Plan[];
 306:   readerState: WorkspacePlanReadState;
 307:   tasks?: PlanTask[];
 308:   totalPlanCount?: number;
 309: }) {
 310:   const readingPlan = readerState.plan;
 311:   const planReadResult = readerState.result;
 312:   const planReadError = readerState.error;
 313:   const planReading = readerState.loading;
 314:   const readerFilePath = planReadResult?.file_path || readingPlan?.file_path || '';
 315:   const readerHash = planReadResult?.hash || readingPlan?.hash || '';
 316:   const readerUpdatedAt = planReadResult?.updated_at || readingPlan?.updated_at || '';
 317:   const latestPlanUpdated = hasPlanReaderUpdate(readingPlan, latestReadingPlan, planReadResult);
 318: 
 319:   return (
 320:     <>
 321:       {plans.length ? (
 322:         <div className="list compact">
 323:           {plans.map((plan) => {
 324:             const durationSummary = formatPlanDurationSummary(tasksForPlan(tasks, plan, totalPlanCount));
 325:             const readingThisPlan = Boolean(
 326:               readingPlan && readingPlan.id === plan.id && readingPlan.project_id === plan.project_id,
 327:             );
 328:             const disableRead = planReading && readingThisPlan;
 329:             return (
 330:               <RecordCard
 331:                 actions={
 332:                   <div className="item-actions">
 333:                     <button
 334:                       type="button"
 335:                       className="btn-link plan-read-link"
 336:                       aria-haspopup="dialog"
 337:                       aria-expanded={readingThisPlan}
 338:                       disabled={disableRead}
 339:                       onClick={() => onOpenReader(plan)}
 340:                     >
 341:                       {disableRead ? '读取中…' : '阅读全文'}
 342:                     </button>
 343:                   </div>
 344:                 }
 345:                 key={plan.id}
 346:                 title={plan.file_path}
 347:                 status={plan.status}
 348:                 body={`${plan.completed_tasks}/${plan.total_tasks} tasks · ${durationSummary} · validation ${
 349:                   plan.validation_passed ? 'passed' : 'pending'
 350:                 }`}
 351:                 meta={`${plan.hash?.slice(0, 12) || ''} · ${formatChinaDateTime(plan.updated_at)}`}
 352:               />
 353:             );
 354:           })}
 355:         </div>
 356:       ) : (
 357:         <div className="empty">{emptyText}</div>
 358:       )}
 359: 
 360:       {readingPlan ? (
 361:         <div className="modal-mask" onClick={onCloseReader}>
 362:           <div
 363:             className="modal plan-reader-modal"
 364:             role="dialog"
 365:             aria-modal="true"
 366:             aria-labelledby="plan-reader-title"
 367:             onClick={(event) => event.stopPropagation()}
 368:           >
 369:             <div className="modal-head plan-reader-head">
 370:               <div className="plan-reader-title">
 371:                 <h3 id="plan-reader-title">Plan 全文</h3>
 372:                 <span className="plan-reader-path mono" title={readerFilePath}>
 373:                   {readerFilePath}
 374:                 </span>
 375:               </div>
 376:               <div className="item-actions">
 377:                 <button type="button" className="btn-link" disabled={planReading} onClick={onRefreshReader}>
 378:                   {planReading ? '读取中…' : '刷新'}
 379:                 </button>
 380:                 <button type="button" className="modal-close" onClick={onCloseReader} aria-label="关闭 Plan 全文阅读">
 381:                   ×
 382:                 </button>
 383:               </div>
 384:             </div>
 385:             <div className="plan-reader-body">
 386:               <div className="plan-reader-summary" aria-label="Plan 摘要">
 387:                 <div className="plan-reader-summary-item">
 388:                   <span>状态</span>
 389:                   <strong>{readingPlan.status}</strong>
 390:                 </div>
 391:                 <div className="plan-reader-summary-item">
 392:                   <span>更新时间</span>
 393:                   <strong>{readerUpdatedAt ? formatChinaDateTime(readerUpdatedAt) : '-'}</strong>
 394:                 </div>
 395:                 <div className="plan-reader-summary-item">
 396:                   <span>哈希</span>
 397:                   <strong className="mono" title={readerHash}>
 398:                     {readerHash?.slice(0, 12) || '-'}
 399:                   </strong>
 400:                 </div>
 401:               </div>
 402: 
 403:               {latestPlanUpdated ? (
 404:                 <div className="hint" role="status">
 405:                   Plan 列表信息已更新，可刷新读取最新正文。
 406:                   <button type="button" className="btn-link" disabled={planReading} onClick={onRefreshReader}>
 407:                     刷新读取
 408:                   </button>
 409:                 </div>
 410:               ) : null}
 411:               {planReadError ? (
 412:                 <div className="plan-reader-error" role="alert">
 413:                   <span>{planReadError}</span>
 414:                   <button type="button" className="btn-link" disabled={planReading} onClick={onRefreshReader}>
 415:                     重试
 416:                   </button>
 417:                 </div>
 418:               ) : null}
 419:               {planReading ? (
 420:                 <div className="plan-reader-loading" role="status">
 421:                   正在读取 Plan 全文…
 422:                 </div>
 423:               ) : null}
 424:               {!planReading && !planReadError ? (
 425:                 <section className="plan-reader-content" aria-label="Plan Markdown 正文">
 426:                   <MarkdownReader markdown={planReadResult?.markdown ?? ''} emptyMessage="暂无计划正文" />
 427:                 </section>
 428:               ) : null}
 429:             </div>
 430:           </div>
 431:         </div>
 432:       ) : null}
 433:     </>
 434:   );
 435: }

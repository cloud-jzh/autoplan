 140: .markdown-reader-empty { padding: 28px 18px; border: 1px dashed var(--line); border-radius: var(--r-md); background: var(--bg-soft); color: var(--text-3); text-align: center; font-size: 13px; }
 141: .markdown-reader h1 { margin: 0 0 14px; padding-bottom: 10px; border-bottom: 1px solid var(--line-soft); font-size: 22px; line-height: 1.3; font-weight: 800; }
 142: .markdown-reader h2 { margin: 24px 0 10px; padding-bottom: 6px; border-bottom: 1px solid var(--line-soft); font-size: 18px; line-height: 1.35; font-weight: 750; }
 143: .markdown-reader h3 { margin: 20px 0 8px; font-size: 15.5px; line-height: 1.4; font-weight: 700; }
 144: .markdown-reader h4, .markdown-reader h5, .markdown-reader h6 { margin: 16px 0 8px; font-size: 14px; line-height: 1.4; font-weight: 700; }
 145: .markdown-reader p { margin: 0 0 12px; color: var(--text-2); }
 146: .markdown-reader a { color: var(--brand-600); overflow-wrap: anywhere; word-break: break-word; }
 147: .markdown-reader a:hover { text-decoration: underline; }
 148: .markdown-reader ul, .markdown-reader ol { margin: 0 0 14px; padding-left: 1.45em; color: var(--text-2); }
 149: .markdown-reader li { margin: 4px 0; }
 150: .markdown-reader li > p { margin: 6px 0; }
 151: .markdown-reader .contains-task-list { list-style: none; padding-left: 1.2em; }
 152: .markdown-reader .task-list-item { margin-left: -1.2em; }
 153: .markdown-reader input[type="checkbox"] { width: auto; margin: 0 7px 0 0; accent-color: var(--brand-600); vertical-align: -2px; }
 154: .markdown-reader .task-list-item > input[type="checkbox"] { margin-top: 0.42em; }
 155: .markdown-reader blockquote { margin: 14px 0; padding: 10px 14px; border-left: 3px solid var(--brand-500); border-radius: 0 var(--r-sm) var(--r-sm) 0; background: var(--brand-50); color: var(--text-2); }
 156: .markdown-reader blockquote p { color: inherit; }
 157: .markdown-reader code { padding: 2px 5px; border: 1px solid var(--line-soft); border-radius: var(--r-sm); background: var(--bg-soft); color: var(--text-1); font-family: var(--font-mono); font-size: 0.92em; word-break: break-word; }
 158: .markdown-reader pre { max-width: 100%; margin: 14px 0; padding: 12px 14px; overflow: auto; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-soft); box-shadow: inset 0 1px 0 rgba(255,255,255,0.65); }
 159: .markdown-reader pre code { display: block; padding: 0; border: 0; border-radius: 0; background: transparent; color: var(--text-1); white-space: pre; word-break: normal; overflow-wrap: normal; }
 160: .markdown-reader pre:focus-visible, .markdown-reader-table:focus-visible { outline: 2px solid var(--brand-500); outline-offset: 2px; }
 161: .markdown-reader-table { max-width: 100%; margin: 14px 0; overflow-x: auto; border: 1px solid var(--line); border-radius: var(--r-md); }
 162: .markdown-reader-table table { width: max-content; min-width: 100%; border-collapse: collapse; font-size: 13px; }
 163: .markdown-reader th, .markdown-reader td { padding: 8px 10px; border: 1px solid var(--line); text-align: left; vertical-align: top; }
 164: .markdown-reader th { background: var(--bg-soft); color: var(--text-1); font-weight: 700; }
 165: .markdown-reader tr:nth-child(even) td { background: rgba(248,250,253,0.65); }
---
 484: input, textarea, select { width: 100%; border: 1px solid var(--line); border-radius: var(--r-sm); padding: 9px 11px; font: inherit; font-size: 13px; color: var(--text-1); background: var(--bg-elevated); font-weight: 400; }
 485: input:focus, textarea:focus, select:focus { outline: none; border-color: var(--brand-500); box-shadow: 0 0 0 3px var(--brand-50); }
 486: textarea { min-height: 80px; resize: vertical; }
 487: .plan-draft textarea { min-height: 240px; font-family: var(--font-mono); font-size: 12.5px; line-height: 1.5; margin-top: 12px; }
 488: .draft-note { color: var(--text-2); font-size: 13px; }
 489: 
 490: .modal-mask { position: fixed; inset: 0; z-index: 100; overflow: auto; background: rgba(23,32,51,0.42); backdrop-filter: blur(2px); display: flex; align-items: center; justify-content: center; padding: 24px; }
 491: .modal { width: 100%; max-width: 480px; background: var(--bg-elevated); border-radius: var(--r-lg); box-shadow: var(--shadow-lg); overflow: hidden; }
 492: .modal-confirm { max-width: 400px; text-align: center; padding: 28px 24px 0; }
 493: .modal-head { display: flex; align-items: center; gap: 12px; padding: 18px 22px; border-bottom: 1px solid var(--line-soft); }
 494: .modal-head h3 { font-size: 16px; font-weight: 700; }
 495: .modal-close { margin-left: auto; width: 30px; height: 30px; border-radius: 8px; border: 0; background: transparent; color: var(--text-3); display: grid; place-items: center; }
 496: .modal-close:hover { background: var(--bg-hover); color: var(--text-1); }
 497: .modal-form { padding: 20px 22px; }
 498: .modal-confirm p { font-size: 13px; color: var(--text-2); line-height: 1.6; margin: 8px 0 4px; }
 499: .modal-danger-icon { display: grid; place-items: center; width: 48px; height: 48px; border-radius: 50%; background: var(--danger-bg); color: var(--danger); margin: 0 auto 14px; }
 500: .modal-foot { display: flex; justify-content: flex-end; gap: 10px; padding: 16px 22px; border-top: 1px solid var(--line-soft); background: var(--bg-soft); }
 501: 
 502: .plan-reader-modal { width: 100%; max-width: min(920px, calc(100vw - 48px)); max-height: min(86dvh, 860px); display: flex; flex-direction: column; }
 503: .plan-reader-head { flex: 0 0 auto; align-items: flex-start; }
 504: .plan-reader-title { min-width: 0; display: flex; flex: 1 1 auto; flex-direction: column; gap: 5px; }
 505: .plan-reader-path { max-width: 100%; overflow: hidden; color: var(--text-3); font-size: 12px; font-weight: 500; text-overflow: ellipsis; white-space: nowrap; }
 506: .plan-reader-actions { flex: 0 0 auto; }
 507: .plan-reader-body { flex: 1 1 auto; min-height: 0; overflow: auto; overscroll-behavior: contain; padding: 16px 22px 22px; display: flex; flex-direction: column; gap: 14px; }
 508: .plan-reader-body:focus-visible { outline: 2px solid var(--brand-500); outline-offset: -4px; }
 509: .plan-reader-summary { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 10px; margin: 0; }
 510: .plan-reader-summary-item { min-width: 0; padding: 10px 12px; border: 1px solid var(--line-soft); border-radius: var(--r-md); background: var(--bg-soft); }
 511: .plan-reader-summary-item dt { display: block; margin-bottom: 4px; color: var(--text-3); font-size: 11px; font-weight: 700; }
 512: .plan-reader-summary-item dd { display: block; min-width: 0; margin: 0; overflow: hidden; color: var(--text-1); font-size: 12.5px; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
 513: .plan-reader-content { min-width: 0; padding: 16px; overflow: visible; border: 1px solid var(--line); border-radius: var(--r-md); background: var(--bg-elevated); box-shadow: var(--shadow-sm); }
 514: .plan-reader-loading, .plan-reader-error { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; padding: 14px 16px; border-radius: var(--r-md); font-size: 13px; line-height: 1.5; }
 515: .plan-reader-loading { border: 1px dashed var(--line); background: var(--bg-soft); color: var(--text-3); }
 516: .plan-reader-error { border: 1px solid rgba(229,72,77,0.28); background: var(--danger-bg); color: var(--danger); }
 517: 
 518: @media (max-width: 1080px) {
 519:   body { overflow: auto; }
 520:   .workspace-shell { grid-template-columns: 1fr; height: auto; }
 521:   .sidebar { height: auto; }
 522:   .workspace-main { height: auto; min-height: 100vh; }
 523:   .topbar { flex-wrap: wrap; align-items: flex-start; }
 524:   .workspace-search { order: 3; flex-basis: 100%; max-width: none; min-width: 0; margin-left: 0; }
 525:   .workspace-search + .topbar-actions { margin-left: auto; }
 526:   .search-results { margin: 14px 20px 0; }
 527:   .task-layout { grid-template-columns: 1fr; }
 528:   .task-main { grid-template-rows: auto auto; }
 529:   .task-status-grid { grid-template-columns: 1fr; }
 530:   .overview-grid { grid-template-columns: 1fr; }
 531:   .overview-main-column > .live-log-card { height: 360px; }
 532: }
 533: 
 534: @media (max-width: 640px) {
 535:   .view { padding: 18px 14px 24px; }
 536:   .topbar { padding: 14px; }
 537:   .topbar-actions { width: 100%; justify-content: space-between; flex-wrap: wrap; }
 538:   .workspace-search { flex-direction: column; align-items: stretch; gap: 6px; }
 539:   .workspace-search-count { padding-left: 2px; }
 540:   .search-results { margin: 12px 14px 0; }
 541:   .search-results-head, .search-results-empty { align-items: stretch; flex-direction: column; }
 542:   .search-results-clear, .search-results-empty .btn { width: 100%; }
 543:   .search-result-groups { grid-template-columns: 1fr; }
 544:   .search-result-meta { flex-direction: column; gap: 3px; }
 545:   .stat-grid { grid-template-columns: 1fr; }
 546:   .card-head { flex-wrap: wrap; align-items: flex-start; }
 547:   .item-title { align-items: flex-start; flex-wrap: wrap; }
 548:   .item-title-right { width: 100%; justify-content: space-between; flex-wrap: wrap; }

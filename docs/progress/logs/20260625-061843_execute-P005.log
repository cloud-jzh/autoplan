 480: export function EventList({ emptyText = '暂无事件。', events }: { emptyText?: string; events: AppEvent[] }) {
 481:   if (!events.length) return <div className="empty">{emptyText}</div>;
 482: 
 483:   return (
 484:     <div className="list compact event-list">
 485:       {events.map((event) => {
 486:         const display = formatEvent(event);
 487:         return (
 488:           <article className={`item event-item ${display.tone ? `event-item-${display.tone}` : ''}`} key={event.id}>
 489:             <div className="item-title event-title">
 490:               <span>{display.title}</span>
 491:               {display.badge ? <span className={`event-badge event-badge-${display.tone}`}>{display.badge}</span> : null}
 492:             </div>
 493:             {display.body ? <div className="item-body plain-text">{display.body}</div> : null}
 494:             <div className="meta event-meta">{display.meta}</div>
 495:           </article>
 496:         );
 497:       })}
 498:     </div>
 499:   );
 500: }

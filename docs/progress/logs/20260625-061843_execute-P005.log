 270: function hasPlanReaderUpdate(
 271:   readingPlan: Plan | null,
 272:   latestPlan: Plan | null | undefined,
 273:   result: WorkspacePlanReadState['result'],
 274: ) {
 275:   if (!readingPlan || !latestPlan) return false;
 276:   if (readingPlan.id !== latestPlan.id || readingPlan.project_id !== latestPlan.project_id) return false;
 277: 
 278:   const readFilePath = result?.file_path || readingPlan.file_path || '';
 279:   const readHash = result?.hash || readingPlan.hash || '';
 280:   const readUpdatedAt = result?.updated_at || readingPlan.updated_at || '';
 281:   return (
 282:     (latestPlan.file_path || '') !== readFilePath ||
 283:     (latestPlan.hash || '') !== readHash ||
 284:     (latestPlan.updated_at || '') !== readUpdatedAt ||
 285:     (latestPlan.status || '') !== (readingPlan.status || '')
 286:   );
 287: }

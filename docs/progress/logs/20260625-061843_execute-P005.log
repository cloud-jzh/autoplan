+
+function exposeHtmlComments(markdown: string) {
+  let fence: { char: string; length: number } | null = null;
+
+  return markdown
+    .split('\n')
+    .map((line) => {
+      const fenceMatch = line.match(/^ {0,3}(`{3,}|~{3,})/);

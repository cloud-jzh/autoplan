+          fence = null;
+        }
+        return line;
+      }
+
+      const visibleLine = line.replace(/<!--.*?-->/g, toVisibleHtmlComment);
+
+      if (fenceMatch) {
+        fence = { char: fenceMatch[1][0], length: fenceMatch[1].length };
+      }
+
+      return visibleLine;
+    })
+    .join('\n');
+}

 437: export function TaskList({
 438:   emptyText = '暂无任务。',
 439:   tasks,
 440:   onRun,
 441:   onStop,
 442: }: {
 443:   emptyText?: string;
 444:   tasks: PlanTask[];
 445:   onRun?: (task: PlanTask) => void;
 446:   onStop?: (task: PlanTask) => void;
 447: }) {
 448:   if (!tasks.length) return <div className="empty">{emptyText}</div>;
 449: 
 450:   return (
 451:     <div className="list compact">
 452:       {tasks.map((task) => {
 453:         const running = task.status === 'running';
 454:         const completed = task.status === 'completed';
 455:         const durationLabel = formatTaskDuration(task as TimedPlanTask);
 456:         return (
 457:           <RecordCard
 458:             actions={
 459:               <div className="item-actions">
 460:                 <button type="button" className="btn-link" disabled={completed || running} onClick={() => onRun?.(task)}>
 461:                   执行
 462:                 </button>
 463:                 <button type="button" className="btn-link danger-link" disabled={!running} onClick={() => onStop?.(task)}>
 464:                   停止
 465:                 </button>
 466:               </div>
 467:             }
 468:             key={task.id}
 469:             title={task.title}
 470:             status={task.status}
 471:             body={task.file_path}
 472:             meta={`${task.task_key} · ${durationLabel} · ${formatChinaDateTime(task.updated_at)}`}
 473:           />
 474:         );
 475:       })}
 476:     </div>
 477:   );
 478: }

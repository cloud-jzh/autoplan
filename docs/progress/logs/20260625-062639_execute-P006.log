 241: 
 242:     const stoppableTask = db.get('SELECT * FROM plan_tasks WHERE plan_id = ? AND task_key = ?', [planId, 'P003']);
 243:     loop.startTaskRun(stoppableTask.id, nowIso());
 244:     await sleep(20);
 245:     loop.stopTask(projectId, stoppableTask.id);
 246:     const stoppedTask = db.get('SELECT * FROM plan_tasks WHERE id = ?', [stoppableTask.id]);
 247:     assert.equal(stoppedTask.status, 'pending', '手动停止后任务应回到 pending 以便重试');
 248:     assertIsoString(stoppedTask.finished_at, '手动停止后应写入 finished_at');
 249:     assert.ok(stoppedTask.duration_ms > 0, '手动停止后应累计耗时');
 250:     const stoppedTaskEvents = taskEventsByKey(loop.snapshot(projectId), 'P003');

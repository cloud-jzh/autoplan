 279:     assertWorkspaceSearchRegression(snapshot);
 280: 
 281:     await assertCodexSessionReuseSmoke(db, loop, projectId, workspace);
 282: 
 283:     const multiWorkspaceA = path.join(tempRoot, 'multi-a');

 371: function loadRendererTsModule(modulePath, cache = new Map()) {
 372:   const absolutePath = path.resolve(modulePath);
 373:   const cachedModule = cache.get(absolutePath);
 374:   if (cachedModule) return cachedModule.exports;
 375: 
 376:   const ts = require('typescript');
 377:   const module = { exports: {} };
 378:   cache.set(absolutePath, module);
 379: 
 380:   const source = fs.readFileSync(absolutePath, 'utf8');
 381:   const transpiled = ts.transpileModule(source, {
 382:     fileName: absolutePath,
 383:     compilerOptions: {
 384:       module: ts.ModuleKind.CommonJS,
 385:       target: ts.ScriptTarget.ES2022,
 386:       jsx: ts.JsxEmit.ReactJSX,
 387:       esModuleInterop: true,
 388:     },
 389:     reportDiagnostics: true,
 390:   });
 391:   const diagnostics = (transpiled.diagnostics || []).filter(
 392:     (diagnostic) => diagnostic.category === ts.DiagnosticCategory.Error,
 393:   );
 394:   assert.deepEqual(
 395:     diagnostics.map((diagnostic) => ts.flattenDiagnosticMessageText(diagnostic.messageText, '\n')),
 396:     [],
 397:     `${absolutePath} 应能被 TypeScript 转译`,
 398:   );
 399: 
 400:   const rendererRoot = path.join(__dirname, '..', 'src', 'renderer');
 401:   const localRequire = (request) => {
 402:     if (request.startsWith('.') || path.isAbsolute(request)) {
 403:       return loadRendererTsModule(resolveRendererModule(path.dirname(absolutePath), request, rendererRoot), cache);
 404:     }
 405:     return require(request);
 406:   };
 407: 
 408:   const script = new vm.Script(transpiled.outputText, { filename: absolutePath });
 409:   script.runInNewContext({
 410:     require: localRequire,
 411:     module,
 412:     exports: module.exports,
 413:     __dirname: path.dirname(absolutePath),
 414:     __filename: absolutePath,
 415:     console,
 416:   });
 417:   return module.exports;
 418: }
 419: 
 420: function resolveRendererModule(fromDir, request, rendererRoot) {
 421:   const basePath = path.resolve(fromDir, request);
 422:   const candidates = [
 423:     basePath,
 424:     `${basePath}.ts`,
 425:     `${basePath}.tsx`,
 426:     `${basePath}.js`,
 427:     `${basePath}.jsx`,
 428:     path.join(basePath, 'index.ts'),
 429:     path.join(basePath, 'index.tsx'),
 430:     path.join(basePath, 'index.js'),
 431:   ];
 432:   const resolvedPath = candidates.find((candidate) => fs.existsSync(candidate) && fs.statSync(candidate).isFile());
 433:   assert.ok(resolvedPath, `应能解析前端模块 ${request}`);
 434: 
 435:   const relativePath = path.relative(rendererRoot, resolvedPath);
 436:   assert.ok(
 437:     relativePath && !relativePath.startsWith('..') && !path.isAbsolute(relativePath),
 438:     `前端 smoke 模块应限制在 renderer 目录内：${request}`,
 439:   );
 440:   return resolvedPath;
 441: }

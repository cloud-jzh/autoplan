 252:     assertTaskEventMeta(stoppedTaskEvents[0], stoppableTask, 'stopping', '手动停止任务事件');
 253: 
 254:     const stoppedDurationMs = stoppedTask.duration_ms;
 255:     const retryStoppedTask = db.get('SELECT * FROM plan_tasks WHERE id = ?', [stoppableTask.id]);
 256:     loop.runCodex = async (_workspace, prompt) => {
 257:       assert.match(prompt, /只执行指定任务 P003/, '停止后重试任务 prompt 应锁定指定任务');
 258:       await sleep(20);
 259:       const runningStoppedRetryTask = db.get('SELECT * FROM plan_tasks WHERE id = ?', [stoppableTask.id]);
 260:       assert.equal(runningStoppedRetryTask.status, 'running', '停止后重试应重新进入 running 状态');

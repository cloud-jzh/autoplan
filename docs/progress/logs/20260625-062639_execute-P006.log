+    require: localRequire,
+    module,
+    exports: module.exports,
+    __dirname: path.dirname(absolutePath),
+    __filename: absolutePath,
+    console,
+  });
+  return module.exports;
+}
+function resolveRendererModule(fromDir, request, rendererRoot) {

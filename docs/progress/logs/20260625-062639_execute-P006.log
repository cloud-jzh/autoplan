 443: function insertProject(db, loop, name, workspacePath) {
 444:   const now = nowIso();
 445:   const id = db.insert(
 446:     `INSERT INTO projects (name, workspace_path, description, created_at, updated_at)
 447:      VALUES (?, ?, ?, ?, ?)`,
 448:     [name, workspacePath, '', now, now],
 449:   );
 450:   loop.ensureProjectState(id);
 451:   return id;
 452: }

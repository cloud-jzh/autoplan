 262:       return { exitCode: 0, logFile: fakeLogFile, lastFile: path.join(workspace, 'fake-stopped-retry.txt') };
 263:     };
 264:     const stoppedRetryResult = await loop.executeTask(workspace, plan, retryStoppedTask);
 265:     loop.runCodex = originalRunCodex;
 266:     assert.equal(stoppedRetryResult.exitCode, 0, '手动停止后的重试应成功');
 267:     loop.completeTask(workspace, plan, retryStoppedTask, stoppedRetryResult);
 268:     const stoppedRetriedTask = db.get('SELECT * FROM plan_tasks WHERE id = ?', [stoppableTask.id]);
 269:     assert.equal(stoppedRetriedTask.status, 'completed', '手动停止后任务应可重试完成');
 270:     assert.ok(stoppedRetriedTask.duration_ms > stoppedDurationMs, '手动停止后重试应继续累加耗时');
 271:     assertTaskDurationShape(taskByKey(loop.snapshot(projectId), 'P003'), '停止后重试完成任务快照');
 272: 
 273:     fs.writeFileSync(planFile, fs.readFileSync(planFile, 'utf8').replaceAll('- [ ]', '- [x]'), 'utf8');

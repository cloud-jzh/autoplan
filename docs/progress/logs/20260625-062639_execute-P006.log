 230:       return { exitCode: 0, logFile: fakeLogFile, lastFile: path.join(workspace, 'fake-retry.txt') };
 231:     };
 232:     const retryResult = await loop.executeTask(workspace, plan, retryAttemptTask);
 233:     loop.runCodex = originalRunCodex;
 234:     assert.equal(retryResult.exitCode, 0, '模拟重试应成功');
 235:     loop.completeTask(workspace, plan, retryAttemptTask, retryResult);
 236:     const retriedTask = db.get('SELECT * FROM plan_tasks WHERE id = ?', [retryTask.id]);
 237:     assert.equal(retriedTask.status, 'completed', '重试成功后任务应完成');
 238:     assertIsoString(retriedTask.finished_at, '重试成功后应写入 finished_at');

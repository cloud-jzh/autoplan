 288:     loop.configure(multiProjectA, { workspacePath: multiWorkspaceA, intervalSeconds: 60, validationCommand: '' });
 289:     loop.configure(multiProjectB, { workspacePath: multiWorkspaceB, intervalSeconds: 60, validationCommand: '' });
 290:     loop.configure(sameWorkspaceProject, { workspacePath: multiWorkspaceB, intervalSeconds: 60, validationCommand: '' });
 291: 
 292:     loop.start(multiProjectA);
 293:     loop.start(multiProjectB);
 294:     assert.equal(loop.snapshot(multiProjectA).state.running, 1, '项目 A 循环应保持运行中');
 295:     assert.equal(loop.snapshot(multiProjectB).state.running, 1, '项目 B 循环应保持运行中');
 296:     assert.ok(
 297:       loop.snapshot().projects.filter((project) => project.running).length >= 2,
 298:       '项目列表应能显示多个运行中项目',
 299:     );
 300:     assert.throws(
 301:       () => loop.start(sameWorkspaceProject),
 302:       /工作区正在被项目/,
 303:       '同一工作区不应被两个项目循环同时占用',
 304:     );
 305:     loop.stop(multiProjectA);
 306:     assert.equal(loop.snapshot(multiProjectA).state.running, 0, '停止项目 A 后 A 应停止');
 307:     assert.equal(loop.snapshot(multiProjectB).state.running, 1, '停止项目 A 不应影响项目 B');
 308:     loop.stop(multiProjectB);
 309:     assert.equal(loop.snapshot(multiProjectB).state.running, 0, '项目 B 应可独立停止');
 310: 
 311:     console.log('smoke ok: projects, scoped snapshots, attachments, draft plan, search, task acceptance, task events, scan, validation, duration stats, codex session reuse, multi-loop');
 312:   } finally {
 313:     fs.rmSync(tempRoot, { recursive: true, force: true });
 314:   }

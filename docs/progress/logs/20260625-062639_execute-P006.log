 472: async function assertCodexSessionReuseSmoke(db, loop, projectId, workspace) {
 473:   const contextPlanRel = path.join('docs', 'plan', 'context-reuse-smoke.md');
 474:   const contextPlanFile = path.join(workspace, contextPlanRel);
 475:   fs.mkdirSync(path.dirname(contextPlanFile), { recursive: true });
 476:   fs.writeFileSync(
 477:     contextPlanFile,
 478:     [
 479:       '# Context reuse smoke',
 480:       '',
 481:       '- [ ] C001: 失败后复用上下文 <!-- scope: smoke/c001.js -->',
 482:       '- [ ] C002: 并发任务 A <!-- scope: smoke/c002.js -->',
 483:       '- [ ] C003: 并发任务 B <!-- scope: smoke/c003.js -->',
 484:       '- [ ] C004: 同步保留上下文 <!-- scope: smoke/c004.js -->',
 485:       '- [ ] C005: 同步改名旧任务 <!-- scope: smoke/c005.js -->',
 486:       '',
 487:     ].join('\n'),
 488:     'utf8',
 489:   );
 490: 
 491:   const now = nowIso();
 492:   const contextPlanId = db.insert(
 493:     `INSERT INTO plans (project_id, issue_hash, file_path, hash, status, total_tasks, completed_tasks, validation_passed, created_at, updated_at)
 494:      VALUES (?, ?, ?, ?, ?, ?, ?, ?, ?, ?)`,
 495:     [projectId, 'smoke-context-reuse', contextPlanRel, '', 'running', 0, 0, 0, now, now],
 496:   );
 497:   loop.syncPlanTasks(contextPlanId, contextPlanFile);
 498:   const contextPlan = db.get('SELECT * FROM plans WHERE id = ?', [contextPlanId]);
 499:   const contextTask = (taskKey) => db.get('SELECT * FROM plan_tasks WHERE plan_id = ? AND task_key = ?', [contextPlanId, taskKey]);
 500: 
 501:   const logDir = path.join(workspace, 'docs', 'progress', 'logs');
 502:   fs.mkdirSync(logDir, { recursive: true });
 503:   const fakeLogFile = path.join(logDir, 'context-reuse-smoke.log');
 504:   fs.writeFileSync(fakeLogFile, 'context reuse smoke', 'utf8');
 505: 
 506:   const retrySessionId = '11111111-1111-4111-8111-111111111111';
 507:   const parallelSessionA = '22222222-2222-4222-8222-222222222222';
 508:   const parallelSessionB = '33333333-3333-4333-8333-333333333333';
 509:   const syncKeptSessionId = '44444444-4444-4444-8444-444444444444';
 510:   const syncRenamedOldSessionId = '55555555-5555-4555-8555-555555555555';
 511:   const originalRunCodex = loop.runCodex.bind(loop);
 512: 
 513:   try {
 514:     const retryTask = contextTask('C001');
 515:     loop.runCodex = async (_workspace, prompt, label, operation = {}) => {
 516:       assert.equal(_workspace, workspace, '会话复用 smoke 应使用当前工作区');
 517:       assert.match(prompt, /只执行指定任务 C001/, '首次失败执行 prompt 应锁定 C001');
 518:       assert.equal(label, 'execute-C001', '首次失败执行 label 应包含任务 key');
 519:       assert.equal(operation.planId, contextPlanId, '首次失败执行 operation 应绑定 plan');
 520:       assert.equal(operation.taskId, retryTask.id, '首次失败执行 operation 应绑定 task');
 521:       assert.equal(operation.codexSessionId, undefined, '首次执行不应传入已有 session id');
 522:       await sleep(5);
 523:       return {
 524:         exitCode: 1,
 525:         logFile: fakeLogFile,
 526:         lastFile: path.join(logDir, 'context-c001-failed.txt'),
 527:         codexSessionId: retrySessionId,
 528:         codexSessionMode: 'new',
 529:       };
 530:     };
 531:     const failedResult = await loop.executeTask(workspace, contextPlan, retryTask);
 532:     assert.equal(failedResult.exitCode, 1, '会话复用 smoke 首次执行应模拟失败');
 533:     const failedTask = contextTask('C001');
 534:     assert.equal(failedTask.status, 'pending', '失败任务应回到 pending 以便重试');
 535:     assert.equal(failedTask.codex_session_id, retrySessionId, '失败后应保存首次捕获的 session id');
 536: 
 537:     loop.runCodex = async (_workspace, prompt, label, operation = {}) => {
 538:       assert.equal(_workspace, workspace, '重试执行应使用当前工作区');
 539:       assert.match(prompt, /只执行指定任务 C001/, '重试执行 prompt 应锁定 C001');
 540:       assert.equal(label, 'execute-C001', '重试执行 label 应包含任务 key');
 541:       assert.equal(operation.planId, contextPlanId, '重试执行 operation 应绑定 plan');
 542:       assert.equal(operation.taskId, retryTask.id, '重试执行 operation 应绑定 task');
 543:       assert.equal(operation.codexSessionId, retrySessionId, '失败后再次执行应传入同一个 session id');
 544:       await sleep(5);
 545:       return {
 546:         exitCode: 0,
 547:         logFile: fakeLogFile,
 548:         lastFile: path.join(logDir, 'context-c001-retry.txt'),
 549:         codexSessionId: retrySessionId,
 550:         codexSessionMode: 'resume',
 551:       };
 552:     };
 553:     const retryResult = await loop.executeTask(workspace, contextPlan, failedTask);
 554:     assert.equal(retryResult.exitCode, 0, '会话复用 smoke 重试应成功');
 555:     loop.completeTask(workspace, contextPlan, failedTask, retryResult);
 556:     const retriedTask = contextTask('C001');
 557:     assert.equal(retriedTask.status, 'completed', '重试成功后任务应完成');
 558:     assert.equal(retriedTask.codex_session_id, retrySessionId, '重试成功后应保留同一个 session id');
 559: 
 560:     const parallelTasks = [contextTask('C002'), contextTask('C003')];
 561:     const parallelSessions = new Map([
 562:       [parallelTasks[0].id, parallelSessionA],
 563:       [parallelTasks[1].id, parallelSessionB],
 564:     ]);
 565:     const seenParallelTaskIds = new Set();
 566:     loop.runCodex = async (_workspace, prompt, label, operation = {}) => {
 567:       const currentTask = parallelTasks.find((task) => task.id === operation.taskId);
 568:       assert.ok(currentTask, '并发执行 operation 应绑定当前任务');
 569:       assert.match(prompt, new RegExp(`只执行指定任务 ${currentTask.task_key}`), '并发执行 prompt 应锁定当前任务');
 570:       assert.equal(label, `execute-${currentTask.task_key}`, '并发执行 label 应包含当前任务 key');
 571:       assert.equal(operation.planId, contextPlanId, '并发执行 operation 应绑定 plan');
 572:       assert.equal(operation.parallel, true, '并发执行 operation 应标记 parallel');
 573:       assert.equal(operation.codexSessionId, undefined, '同一 plan 的不同任务首次执行不应复用其它 session id');
 574:       seenParallelTaskIds.add(operation.taskId);
 575:       await sleep(currentTask.task_key === 'C002' ? 10 : 1);
 576:       return {
 577:         exitCode: 0,
 578:         logFile: fakeLogFile,
 579:         lastFile: path.join(logDir, `context-${currentTask.task_key}.txt`),
 580:         codexSessionId: parallelSessions.get(currentTask.id),
 581:         codexSessionMode: 'new',
 582:       };
 583:     };
 584:     const parallelResults = await loop.executeTaskBatch(workspace, contextPlan, parallelTasks);
 585:     assert.deepEqual(
 586:       parallelResults.map(({ result }) => result.exitCode),
 587:       [0, 0],
 588:       '并发会话 smoke 应全部执行成功',
 589:     );
 590:     assert.equal(seenParallelTaskIds.size, 2, '并发执行应覆盖两个独立任务');
 591:     const parallelTaskA = contextTask('C002');
 592:     const parallelTaskB = contextTask('C003');
 593:     assert.equal(parallelTaskA.codex_session_id, parallelSessionA, '并发任务 A 应保存自己的 session id');
 594:     assert.equal(parallelTaskB.codex_session_id, parallelSessionB, '并发任务 B 应保存自己的 session id');
 595:     assert.notEqual(parallelTaskA.codex_session_id, parallelTaskB.codex_session_id, '并发任务 session id 应彼此独立');
 596:     assert.notEqual(parallelTaskA.codex_session_id, retrySessionId, '并发任务 A 不应复用重试任务 session id');
 597:     assert.notEqual(parallelTaskB.codex_session_id, retrySessionId, '并发任务 B 不应复用重试任务 session id');
 598: 
 599:     const syncKeptTask = contextTask('C004');
 600:     const syncRenamedTask = contextTask('C005');
 601:     loop.updateTaskCodexSession(syncKeptTask.id, syncKeptSessionId);
 602:     loop.updateTaskCodexSession(syncRenamedTask.id, syncRenamedOldSessionId);
 603:     fs.writeFileSync(
 604:       contextPlanFile,
 605:       [
 606:         '# Context reuse smoke',
 607:         '',
 608:         '- [x] C001: 失败后复用上下文 <!-- scope: smoke/c001.js -->',
 609:         '- [x] C002: 并发任务 A <!-- scope: smoke/c002.js -->',
 610:         '- [x] C003: 并发任务 B <!-- scope: smoke/c003.js -->',
 611:         '- [ ] C004: 同步保留上下文已更新 <!-- scope: smoke/c004-updated.js -->',
 612:         '- [ ] C105: 同步改名新任务 <!-- scope: smoke/c105.js -->',
 613:         '- [ ] C006: 同步新增任务 <!-- scope: smoke/c006.js -->',
 614:         '',
 615:       ].join('\n'),
 616:       'utf8',
 617:     );
 618:     loop.syncPlanTasks(contextPlanId, contextPlanFile);
 619:     const keptAfterSync = contextTask('C004');
 620:     const renamedAfterSync = contextTask('C105');
 621:     const addedAfterSync = contextTask('C006');
 622:     assert.equal(keptAfterSync.id, syncKeptTask.id, 'sync 后同一 task_key 应保留原任务记录');
 623:     assert.equal(keptAfterSync.codex_session_id, syncKeptSessionId, 'sync 后同一 task_key 应保留上下文');
 624:     assert.match(keptAfterSync.raw_line, /c004-updated\.js/, 'sync 后同一 task_key 应更新 raw line');

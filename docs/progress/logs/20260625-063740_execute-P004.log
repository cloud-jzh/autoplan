const path = require('node:path');
const { app, BrowserWindow } = require('electron');

const root = process.cwd();
const preload = process.env.P004_PRELOAD;

function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

async function waitFor(win, predicate, timeoutMs, label) {
  const started = Date.now();
  while (Date.now() - started < timeoutMs) {
    const value = await win.webContents.executeJavaScript("'`(${predicate})()`, true);
    if (value) return value;
    await sleep(50);
  }
  throw new Error(`Timed out waiting for ${label}`);
}

async function logState(win) {
  return win.webContents.executeJavaScript(`(() => {
    const el = document.querySelector('"'.codex-log');
    return {
      scrollTop: el.scrollTop,
      scrollHeight: el.scrollHeight,
      clientHeight: el.clientHeight,
      distanceFromBottom: el.scrollHeight - el.clientHeight - el.scrollTop,
      textTail: el.textContent.slice(-120),
    };
  })()"'`, true);
}

function assertNearBottom(state, label) {
  if (state.distanceFromBottom > 28) {
    throw new Error(`${label}: expected near bottom, got ${JSON.stringify(state)}`);
  }
}

function assertStayedAwayFromBottom(state, previousTop, label) {
  if (Math.abs(state.scrollTop - previousTop) > 2) {
    throw new Error(`${label}: expected stable scrollTop ${previousTop}, got ${JSON.stringify(state)}`);
  }
  if (state.distanceFromBottom <= 28) {
    throw new Error(`${label}: expected away from bottom, got ${JSON.stringify(state)}`);
  }
}

async function verifyMode(win, raw) {
  const mode = raw ? '"'raw' : 'activity';
  await win.webContents.executeJavaScript("'`window.__p004LogTest.emit(window.__p004LogTest.makeSnapshot(60, { raw: ${raw} }))`, true);
  await sleep(150);
  let state = await logState(win);
  assertNearBottom(state, `${mode} initial render`);

  await win.webContents.executeJavaScript(`window.__p004LogTest.emit(window.__p004LogTest.makeSnapshot(70, { raw: ${raw} }))`, true);
  await sleep(150);
  state = await logState(win);
  assertNearBottom(state, `${mode} append while bottom`);

  const previousTop = await win.webContents.executeJavaScript(`(() => {
    const el = document.querySelector('"'.codex-log');
    el.scrollTop = 40;
    el.dispatchEvent(new Event('scroll', { bubbles: true }));
    return el.scrollTop;
  })()"'`, true);
  await win.webContents.executeJavaScript(`window.__p004LogTest.emit(window.__p004LogTest.makeSnapshot(80, { raw: ${raw} }))`, true);
  await sleep(150);
  state = await logState(win);
  assertStayedAwayFromBottom(state, previousTop, `${mode} append while reading history`);

  await win.webContents.executeJavaScript(`(() => {
    const el = document.querySelector('"'.codex-log');
    el.scrollTop = el.scrollHeight;
    el.dispatchEvent(new Event('scroll', { bubbles: true }));
  })()"'`, true);
  await win.webContents.executeJavaScript(`window.__p004LogTest.emit(window.__p004LogTest.makeSnapshot(90, { raw: ${raw} }))`, true);
  await sleep(150);
  state = await logState(win);
  assertNearBottom(state, `${mode} append after returning bottom`);

  return { mode, final: state };
}

async function main() {
  await app.whenReady();
  const win = new BrowserWindow({
    show: false,
    width: 1220,
    height: 820,
    webPreferences: {
      preload,
      contextIsolation: true,
      nodeIntegration: false,
    },
  });
  await win.loadFile(path.join(root, '"'dist', 'index.html'), { hash: '/projects/1' });
  await waitFor(win, "'`() => document.querySelector('"'.codex-log')"'`, 10000, '"'codex log');
  const activity = await verifyMode(win, false);
  const raw = await verifyMode(win, true);
  console.log(JSON.stringify({ ok: true, activity, raw }, null, 2));
  await app.quit();
}

main().catch(async (error) => {
  console.error(error && error.stack ? error.stack : error);
  await app.quit();
  process.exit(1);
});

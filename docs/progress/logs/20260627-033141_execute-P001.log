 637:   finishTaskRun(taskId, status, finishedAt = nowIso(), options = {}) {
 638:     const task = this.db.get('SELECT * FROM plan_tasks WHERE id = ?', [taskId]);
 639:     if (!task) return null;
 640:     const isRunning = task.status === TASK_EVENT_STATUS.RUNNING;
 641:     if (options.onlyIfRunning && !isRunning) return withTaskDurationMeta(task);
 642: 
 643:     const runDurationMs = isRunning ? taskRunDurationMs(task.started_at, finishedAt) : undefined;
 644:     const durationMs = normalizeDurationMs(task.duration_ms) + (runDurationMs || 0);
 645:     this.db.run(
 646:       `UPDATE plan_tasks
 647:        SET status = ?, duration_ms = ?, finished_at = ?, updated_at = ?
 648:        WHERE id = ?`,
 649:       [status, durationMs, finishedAt, finishedAt, taskId],
 650:     );
 651:     return withTaskDurationMeta(

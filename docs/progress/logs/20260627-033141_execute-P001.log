 531:   validatedParallelTaskBatches(workspace, plan, confirmedBatches) {
 532:     const batches = normalizeConfirmedTaskBatches(confirmedBatches);
 533:     if (!batches.length) throw new Error('未选择并发任务批次');
 534:     const seenTaskIds = new Set();
 535:     return batches.map((batchTaskIds, batchIndex) => {
 536:       if (batchTaskIds.length < 2) throw new Error(`第 ${batchIndex + 1} 批至少需要 2 个任务`);
 537:       if (batchTaskIds.length > MAX_PARALLEL_TASKS) {
 538:         throw new Error(`第 ${batchIndex + 1} 批超过最大并发数 ${MAX_PARALLEL_TASKS}`);
 539:       }
 540:       const usedScopes = new Set();
 541:       return batchTaskIds.map((taskId) => {
 542:         if (seenTaskIds.has(taskId)) throw new Error('同一任务不能重复出现在并发批次中');
 543:         seenTaskIds.add(taskId);
 544:         const task = this.db.get(
 545:           'SELECT * FROM plan_tasks WHERE id = ? AND plan_id = ?',
 546:           [taskId, plan.id],
 547:         );
 548:         if (!task) throw new Error('任务不存在或不属于当前计划');
 549:         if (task.status !== TASK_EVENT_STATUS.PENDING) {
 550:           throw new Error(`${task.task_key} 当前状态不是 pending，不能并发执行`);
 551:         }
 552:         const analysis = taskConcurrencyAnalysis(workspace, task);
 553:         if (!analysis.canRunInParallel) {
 554:           throw new Error(`${task.task_key} 不可并发：${analysis.reason}`);
 555:         }
 556:         const conflictScope = analysis.scopes.find((scope) => usedScopes.has(scope));
 557:         if (conflictScope) {
 558:           throw new Error(`第 ${batchIndex + 1} 批存在 scope 冲突：${conflictScope}`);
 559:         }
 560:         for (const scope of analysis.scopes) usedScopes.add(scope);
 561:         return task;
 562:       });
 563:     });
 564:   }

   1: const nodeUrl = require('node:url');
   2: const { contextBridge, ipcRenderer, webUtils } = require('electron');
   3: 
   4: function toFileUrl(filePath) {
   5:   const value = String(filePath || '').trim();
   6:   if (!value || /^file:\/\//i.test(value)) return value;
   7:   if (isPersistedAttachmentPath(value)) return `autoplan-file://attachment/${encodeURIComponent(value)}`;
   8:   if (typeof nodeUrl.pathToFileURL === 'function') {
   9:     return nodeUrl.pathToFileURL(value).toString();
  10:   }
  11:   return fallbackPathToFileUrl(value);
  12: }
  13: 
  14: function isPersistedAttachmentPath(filePath) {
  15:   return /[\\/]data[\\/]attachments[\\/]/i.test(filePath);
  16: }
  17: 
  18: function fallbackPathToFileUrl(filePath) {
  19:   const normalized = filePath.replace(/\\/g, '/');
  20:   if (normalized.startsWith('//')) {
  21:     const [host, ...segments] = normalized.replace(/^\/+/, '').split('/');
  22:     return `file://${encodeURIComponent(host)}/${segments.map(encodeURIComponent).join('/')}`;
  23:   }
  24: 
  25:   const pathname = normalized.startsWith('/') ? normalized : `/${normalized}`;
  26:   const encodedPath = pathname
  27:     .split('/')
  28:     .map((segment, index) => (index === 1 && /^[A-Za-z]:$/.test(segment) ? segment : encodeURIComponent(segment)))
  29:     .join('/');
  30:   return `file://${encodedPath}`;
  31: }

 267: function classifyTaskEvent(event: AppEvent, meta: EventMetaRecord | null): TaskEventTone {
 268:   const eventText = `${event.type || ''} ${readMetaText(meta, ['status', 'taskStatus', 'task_status'])}`.toLowerCase();
 269:   if (includesAny(eventText, ['stop_requested', 'stop-requested', 'stop.requested', 'request_stop', 'stopping'])) {
 270:     return 'stopping';
 271:   }
 272:   if (includesAny(eventText, ['fail', 'error', 'errored'])) return 'failed';
 273:   if (includesAny(eventText, ['stop', 'interrupt', 'cancel'])) return 'stopped';
 274:   if (includesAny(eventText, ['start', 'begin', 'running'])) return 'start';
 275:   if (includesAny(eventText, ['complete', 'finish', 'success', 'succeed', 'executed', 'done'])) return 'success';
 276:   return 'updated';
 277: }

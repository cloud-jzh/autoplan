 375: function hasPlanReaderUpdate(
 376:   readingPlan: Plan | null,
 377:   latestPlan: Plan | null | undefined,
 378:   result: WorkspacePlanReadState['result'],
 379: ) {
 380:   if (!readingPlan || !latestPlan) return false;
 381:   if (readingPlan.id !== latestPlan.id || readingPlan.project_id !== latestPlan.project_id) return false;
 382: 
 383:   const readFilePath = result?.file_path || readingPlan.file_path || '';
 384:   const readHash = result?.hash || readingPlan.hash || '';
 385:   const readUpdatedAt = result?.updated_at || readingPlan.updated_at || '';
 386:   return (
 387:     (latestPlan.file_path || '') !== readFilePath ||
 388:     (latestPlan.hash || '') !== readHash ||
 389:     (latestPlan.updated_at || '') !== readUpdatedAt ||
 390:     (latestPlan.status || '') !== (readingPlan.status || '')
 391:   );
 392: }
 393: 
 394: const PLAN_READER_FOCUSABLE_SELECTOR = [
 395:   'a[href]',
 396:   'button:not([disabled])',
 397:   'input:not([disabled]):not([type="hidden"])',
 398:   'select:not([disabled])',
 399:   'textarea:not([disabled])',
 400:   '[tabindex]:not([tabindex="-1"])',
 401: ].join(',');
 402: 
 403: function getPlanReaderFocusableElements(container: HTMLElement) {
 404:   return Array.from(container.querySelectorAll<HTMLElement>(PLAN_READER_FOCUSABLE_SELECTOR)).filter(
 405:     (element) => element.getClientRects().length > 0 && element.getAttribute('aria-hidden') !== 'true',
 406:   );
 407: }
 408: 
 409: function parallelRunDisabledReason(plan: Plan, hasRunningTask: boolean) {
 410:   if (hasRunningTask) return '该计划已有任务执行中';
 411:   if (plan.validation_passed || plan.status === 'completed') return '计划已完成';
 412:   if (!plan.concurrency_suggestion?.hasSafeParallelBatches) return '暂无安全可并发批次';
 413:   return '';
 414: }
 415: 
 416: function scopeFileLabel(file: PlanTask['scope_files'][number]) {
 417:   if (file.isUnknown) return 'unknown';
 418:   if (file.isValidation) return 'validation';
 419:   return file.path;
 420: }


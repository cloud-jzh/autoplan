1046: function filterItemsBySearchGroup<T extends { id: number }>(
1047:   items: T[],
1048:   groups: WorkspaceSearchGroup[],
1049:   source: WorkspaceSearchSourceType,
1050: ) {
1051:   const group = groups.find((item) => item.source === source);
1052:   if (!group?.results.length) return [];
1053: 
1054:   const recordIds = new Set(group.results.map((result) => result.recordId));
1055:   return items.filter((item) => recordIds.has(item.id));
1056: }
1057: 
1058: function filterTasksBySearchGroups(
1059:   tasks: PlanTask[],
1060:   plans: Plan[],
1061:   groups: WorkspaceSearchGroup[],
1062: ) {
1063:   const directTasks = filterItemsBySearchGroup(tasks, groups, WORKSPACE_SEARCH_SOURCE_TYPES.TASK);
1064:   if (!plans.length) return directTasks;
1065: 
1066:   const taskIds = new Set(directTasks.map((task) => task.id));
1067:   const planIds = new Set(plans.map((plan) => plan.id));
1068:   const planFilePaths = new Set(plans.map((plan) => plan.file_path).filter(Boolean));
1069:   const planTasks = tasks.filter(
1070:     (task) => planIds.has(task.plan_id) || (!!task.file_path && planFilePaths.has(task.file_path)),
1071:   );
1072: 
1073:   return [...directTasks, ...planTasks.filter((task) => !taskIds.has(task.id))];
1074: }
1075: 
1076: function withTaskCliProviderTitle(task: PlanTask, fallbackProvider?: string | null): PlanTask {

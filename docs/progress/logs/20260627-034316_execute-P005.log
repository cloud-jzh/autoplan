+    projectId,
+    validationCommand: '',
+    provider: 'codex',
+    effort: 'low',
+  }, '验收命令从非空保存为空结果');
+  assertLoopConfigRow(db, projectId, {
+    validationCommand: '',
+    provider: 'codex',
+    effort: 'low',
+  }, '验收命令从非空保存为空数据库记录');

 426: function assertSearchHit(searchState, source, field, valuePattern, label) {
 427:   assert.ok(searchState.total > 0, `${label}：应返回搜索结果`);
 428:   const result = searchState.results.find(
 429:     (item) => item.source === source && item.matches.some((match) => match.field === field),
 430:   );
 431:   assert.ok(result, `${label}：应包含 ${source}/${field} 命中`);
 432:   const match = result.matches.find((item) => item.field === field);
 433:   assert.match(match.value, valuePattern, `${label}：命中值应包含关键字`);
 434:   assert.match(match.snippet, valuePattern, `${label}：摘要片段应包含关键字`);
 435:   assert.ok(
 436:     searchState.groups.some((group) => group.source === source && group.count > 0),
 437:     `${label}：来源分组应统计命中数量`,
 438:   );
 439: }

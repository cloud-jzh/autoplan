 638: function insertProject(db, loop, name, workspacePath) {
 639:   const now = nowIso();
 640:   const id = db.insert(
 641:     `INSERT INTO projects (name, workspace_path, description, created_at, updated_at)
 642:      VALUES (?, ?, ?, ?, ?)`,
 643:     [name, workspacePath, '', now, now],

 378: async function assertFinalAcceptanceTaskSmoke(db, loop, workspace, projectId) {
 379:   const planRel = path.join('docs', 'plan', 'final-acceptance-smoke.md');
 380:   const planFile = path.join(workspace, planRel);
 381:   fs.mkdirSync(path.dirname(planFile), { recursive: true });
 382:   fs.writeFileSync(
 383:     planFile,
 384:     [
 385:       '# Final acceptance smoke',
 386:       '',
 387:       '## 任务计划',
 388:       '- [x] P001: 完成开发修改 <!-- scope: smoke/dev.js -->',
 389:       '- [ ] P002: 完整验收 <!-- scope: validation -->',
 390:       '',
 391:       '## 总体验收标准',
 392:       '- 最后节点执行完整验收命令。',
 393:       '',
 394:     ].join('\n'),
 395:     'utf8',
 396:   );
 397:   const planId = insertPlan(db, projectId, planRel, 'final-acceptance-smoke');
 398:   loop.syncPlanTasks(planId, planFile);
 399:   const acceptanceTask = db.get('SELECT * FROM plan_tasks WHERE plan_id = ? AND task_key = ?', [planId, 'P002']);
 400:   assert.equal(acceptanceTask.scope, 'validation', 'final acceptance task should use validation scope');
 401: 
 402:   const originalRunCodex = loop.runCodex.bind(loop);
 403:   let codexCalled = false;
 404:   try {
 405:     loop.runCodex = async () => {
 406:       codexCalled = true;
 407:       return { exitCode: 1, output: 'unexpected codex execution' };
 408:     };
 409:     await loop.processPlan(workspace, db.get('SELECT * FROM plans WHERE id = ?', [planId]));
 410:   } finally {
 411:     loop.runCodex = originalRunCodex;
 412:   }
 413: 
 414:   assert.equal(codexCalled, false, 'final acceptance task should run validation directly instead of Codex');
 415:   const acceptedPlan = db.get('SELECT * FROM plans WHERE id = ?', [planId]);
 416:   const acceptedTask = db.get('SELECT * FROM plan_tasks WHERE id = ?', [acceptanceTask.id]);
 417:   assert.equal(acceptedPlan.status, 'completed', 'final acceptance task should complete the plan');
 418:   assert.equal(acceptedPlan.validation_passed, 1, 'final acceptance task should mark validation_passed');
 419:   assert.equal(acceptedTask.status, 'completed', 'final acceptance task should be completed');
 420:   assert.match(fs.readFileSync(planFile, 'utf8'), /- \[x\] P002: 完整验收/, 'final acceptance checkbox should be checked');
 421:   const acceptanceEvents = taskEventsByKey(loop.snapshot(projectId), 'P002');
 422:   assertTaskEventOrder(acceptanceEvents, ['task.succeeded', 'task.started'], 'final acceptance task events');
 423:   assert.equal(acceptanceEvents[0].meta.acceptanceTask, true, 'final acceptance success event should be marked');
 424: }

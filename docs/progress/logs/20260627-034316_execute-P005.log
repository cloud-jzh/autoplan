 566: function loadRendererTsModule(modulePath, cache = new Map()) {
 567:   const absolutePath = path.resolve(modulePath);
 568:   const cachedModule = cache.get(absolutePath);
 569:   if (cachedModule) return cachedModule.exports;
 570: 
 571:   const ts = require('typescript');
 572:   const module = { exports: {} };
 573:   cache.set(absolutePath, module);
 574: 
 575:   const source = fs.readFileSync(absolutePath, 'utf8');
 576:   const transpiled = ts.transpileModule(source, {
 577:     fileName: absolutePath,
 578:     compilerOptions: {
 579:       module: ts.ModuleKind.CommonJS,
 580:       target: ts.ScriptTarget.ES2022,
 581:       jsx: ts.JsxEmit.ReactJSX,
 582:       esModuleInterop: true,
 583:     },
 584:     reportDiagnostics: true,
 585:   });
 586:   const diagnostics = (transpiled.diagnostics || []).filter(
 587:     (diagnostic) => diagnostic.category === ts.DiagnosticCategory.Error,
 588:   );
 589:   assert.deepEqual(
 590:     diagnostics.map((diagnostic) => ts.flattenDiagnosticMessageText(diagnostic.messageText, '\n')),
 591:     [],
 592:     `${absolutePath} 应能被 TypeScript 转译`,
 593:   );
 594: 
 595:   const rendererRoot = path.join(__dirname, '..', 'src', 'renderer');
 596:   const localRequire = (request) => {
 597:     if (request.startsWith('.') || path.isAbsolute(request)) {
 598:       return loadRendererTsModule(resolveRendererModule(path.dirname(absolutePath), request, rendererRoot), cache);
 599:     }
 600:     return require(request);
 601:   };
 602: 
 603:   const script = new vm.Script(transpiled.outputText, { filename: absolutePath });
 604:   script.runInNewContext({
 605:     require: localRequire,
 606:     module,
 607:     exports: module.exports,
 608:     __dirname: path.dirname(absolutePath),
 609:     __filename: absolutePath,
 610:     console,
 611:   });
 612:   return module.exports;
 613: }
 614: 
 615: function resolveRendererModule(fromDir, request, rendererRoot) {
 616:   const basePath = path.resolve(fromDir, request);
 617:   const candidates = [
 618:     basePath,
 619:     `${basePath}.ts`,
 620:     `${basePath}.tsx`,
 621:     `${basePath}.js`,
 622:     `${basePath}.jsx`,
 623:     path.join(basePath, 'index.ts'),
 624:     path.join(basePath, 'index.tsx'),
 625:     path.join(basePath, 'index.js'),
 626:   ];
 627:   const resolvedPath = candidates.find((candidate) => fs.existsSync(candidate) && fs.statSync(candidate).isFile());
 628:   assert.ok(resolvedPath, `应能解析前端模块 ${request}`);
 629: 
 630:   const relativePath = path.relative(rendererRoot, resolvedPath);
 631:   assert.ok(
 632:     relativePath && !relativePath.startsWith('..') && !path.isAbsolute(relativePath),
 633:     `前端 smoke 模块应限制在 renderer 目录内：${request}`,
 634:   );
 635:   return resolvedPath;
 636: }

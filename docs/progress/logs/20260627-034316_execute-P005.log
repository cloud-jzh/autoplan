+  }, '非空验收命令与 high 思考深度刷新快照');
+
+  configuredSnapshot = configureLoop(null, {
+    projectId,
+    validation_command: '',
+    agentCliProvider: 'codex',
+    codexReasoningEffort: 'low',
+  });

+    validationCommand: 'npm run smoke:config',
+    agentCliProvider: 'codex',
+    codexReasoningEffort: 'high',
+  });
+  assertLoopConfigSnapshot(configuredSnapshot, {
+    projectId,
+    validationCommand: 'npm run smoke:config',
+    provider: 'codex',
+    effort: 'high',
+  }, '非空验收命令与 high 思考深度保存结果');
+  assertLoopConfigRow(db, projectId, {

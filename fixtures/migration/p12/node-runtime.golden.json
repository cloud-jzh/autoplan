{
  "schema_version": 1,
  "kind": "p12-node-script-executor-runtime-golden",
  "generator": "scripts/migration-p12/generate-node-golden.js",
  "source": "sanitized-static-contract-only",
  "safety": {
    "electron_started": false,
    "database_opened": false,
    "process_started": false,
    "external_workspace_read": false,
    "environment_values_recorded": false,
    "fixture_values": "identifiers, timestamps, paths, logs and secrets are placeholders only"
  },
  "deterministic_replay": {
    "rule": "A normalized request with the same persisted project/resource identity and idempotency key resolves to the same operation; generated operation ids, timestamps, pid and executor run ids are normalized to placeholders.",
    "forbidden_fixture_values": [
      "real path",
      "environment value",
      "command body",
      "argument value",
      "pid",
      "credential",
      "secret"
    ]
  },
  "runtime_actions": [
    {
      "id": "script.run",
      "legacy_ipc": "scripts:run",
      "legacy_return": "ScriptRunResult",
      "go_command": "script.run",
      "feature_flag": "go_scripts_api",
      "resource": "script"
    },
    {
      "id": "script.stop",
      "legacy_ipc": "scripts:stop",
      "legacy_return": "AppSnapshot",
      "go_command": "script.stop",
      "feature_flag": "go_scripts_api",
      "resource": "script"
    },
    {
      "id": "executor.run",
      "legacy_ipc": "executors:run",
      "legacy_return": "ExecutorRunResult",
      "go_command": "executor.run",
      "feature_flag": "go_executors_api",
      "resource": "executor"
    },
    {
      "id": "executor.stop",
      "legacy_ipc": "executors:stop",
      "legacy_return": "AppSnapshot",
      "go_command": "executor.stop",
      "feature_flag": "go_executors_api",
      "resource": "executor"
    },
    {
      "id": "executor.action",
      "legacy_ipc": "executors:runAction",
      "legacy_return": "ExecutorRunResult",
      "go_command": "executor.action",
      "feature_flag": "go_executors_api",
      "resource": "executor"
    }
  ],
  "dto_compatibility": {
    "identifiers": {
      "request_input": [
        "projectId",
        "scriptId|executorId",
        "action only for executor.action"
      ],
      "persisted_storage": [
        "project_id",
        "script_id|executor_id"
      ],
      "snapshot_aliases": [
        "executor.projectId/project_id",
        "executor.lastStatus/last_status",
        "executor.lastExitCode/last_exit_code",
        "executor.lastDurationMs/last_duration_ms",
        "executor.lastLog/last_log",
        "executor.lastRunAt/last_run_at"

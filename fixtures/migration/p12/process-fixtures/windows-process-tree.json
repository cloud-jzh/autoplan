{
  "schema_version": 1,
  "platform": "windows",
  "kind": "fake-process-tree",
  "launch": {
    "executable": "<fake-executable>",
    "args": ["--parent", "--child", "--grandchild"],
    "shell": false,
    "cwd": "<fixture-workspace>"
  },
  "tree": {"parent": 1, "children": [2], "grandchildren": [3]},
  "scenarios": [
    {"id": "cancel", "expected_signal": "CTRL_BREAK", "expected_reaped": [1, 2, 3], "zombies": 0},
    {"id": "timeout_force", "expected_signal": "TERMINATE_TREE", "expected_reaped": [1, 2, 3], "zombies": 0},
    {"id": "output_pressure", "max_combined_bytes": 65536, "raw_output_persisted": false, "zombies": 0},
    {"id": "restart_recovery", "expected_reaped": [1, 2, 3], "zombies": 0}
  ]
}
